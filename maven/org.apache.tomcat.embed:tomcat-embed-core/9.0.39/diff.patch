+                synchronized (stateLock) {
+                    // Check the session has not been closed in another thread
+                    // while the timeout was being processed.
+                    if (state == State.OUTPUT_CLOSED) {
+                        state = State.CLOSED;
+                        closeConnection();
+                    }
+                }
+            }
+        }
+    }
