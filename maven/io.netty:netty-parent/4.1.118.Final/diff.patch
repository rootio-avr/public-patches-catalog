+        } else {
+            for (int i = 0; i < parameter.length(); i++) {
+                char c = parameter.charAt(i);
+                if (c == '\r' || c == '\n') {
+                    throw new IllegalArgumentException("SMTP parameter contains CRLF characters: " + parameter);
+                }
+            }
+        }
