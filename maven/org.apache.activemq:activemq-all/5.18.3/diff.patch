+            assertTrue(e.getCause() instanceof URISyntaxException);
+        }
+    }
+
+    private static void assertNotAllowed(String expected, Callable<?> callable) {
+        try {
+            callable.call();
+            fail("Should have failed with Exception");
+        } catch (Exception e) {
+            assertTrue(e instanceof IllegalArgumentException);
+            assertEquals(expected, e.getMessage());
+        }
+    }
+}
diff --git a/activemq-spring/src/test/java/org/apache/activemq/xbean/XBeanBrokerFactoryTest.java b/activemq-spring/src/test/java/org/apache/activemq/xbean/XBeanBrokerFactoryTest.java
new file mode 100644
index 0000000..b6aa826
--- /dev/null
+++ b/activemq-spring/src/test/java/org/apache/activemq/xbean/XBeanBrokerFactoryTest.java
@@ -0,0 +1,246 @@
+/*
