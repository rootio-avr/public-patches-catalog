+        parameterSets.add(new String[] { "aaa\n\naaa", "aaa\\u000A\\u000Aaaa" });
+
+        // End
+        parameterSets.add(new String[] { "aaa\n", "aaa\\u000A" });
+        parameterSets.add(new String[] { "aaa\n\n", "aaa\\u000A\\u000A" });
+
+        // Start, middle and end
