--- a/src/java/org/apache/commons/beanutils/PropertyUtilsBean.java
+++ b/src/java/org/apache/commons/beanutils/PropertyUtilsBean.java
@@ -900,6 +900,26 @@
         descriptors = beanInfo.getPropertyDescriptors();
         if (descriptors == null) {
             descriptors = new PropertyDescriptor[0];
         }
+
+        // CVE-2019-10086: Suppress the "class" property to prevent
+        // access to the classloader via Object.getClass()
+        int filteredCount = 0;
+        for (int i = 0; i < descriptors.length; i++) {
+            if (!"class".equals(descriptors[i].getName())) {
+                filteredCount++;
+            }
+        }
+        if (filteredCount != descriptors.length) {
+            PropertyDescriptor[] filtered = new PropertyDescriptor[filteredCount];
+            int j = 0;
+            for (int i = 0; i < descriptors.length; i++) {
+                if (!"class".equals(descriptors[i].getName())) {
+                    filtered[j++] = descriptors[i];
+                }
+            }
+            descriptors = filtered;
+        }
+
         descriptorsCache.put(beanClass, descriptors);
         return (descriptors);
