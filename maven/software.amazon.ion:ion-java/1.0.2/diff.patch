+    @Test(expected = IonException.class)
+    public void maximumDepthExceeded() {
+        // Build an Ion struct nested deeper than the hard-coded MAX_COMPARISON_DEPTH
+        // (1000) and verify that comparing two equal copies of it throws IonException
+        // rather than blowing the JVM stack (CVE-2024-21634).
+        StringBuilder open = new StringBuilder();
+        StringBuilder close = new StringBuilder();
+        for (int i = 0; i < 1100; i++) {
+            open.append("{a:");
+            close.append("}");
+        }
+        open.append("1");
+        IonStruct struct1 = (IonStruct) ion(open.toString() + close.toString());
+        IonStruct struct2 = (IonStruct) struct1.clone();
+        Equivalence.ionEquals(struct1, struct2);
+    }
+
+    @Test
+    public void maximumDepthNotExceeded() {
+        // A modest nesting (well under MAX_COMPARISON_DEPTH) must still compare equal.
+        IonStruct struct1 = (IonStruct) ion("{foo: {bar: {baz: {zar: 123}}}}");
+        IonStruct struct2 = (IonStruct) struct1.clone();
+        assertTrue(Equivalence.ionEquals(struct1, struct2));
     }
