+    /**
+     * Return the expected parameter type for a complex property, based on
+     * the setter or adder method signature. This is used to restrict object
+     * creation to the expected supertype during Joran configuration processing.
+     *
+     * @param name             the property name
+     * @param aggregationType  the aggregation type (AS_COMPLEX_PROPERTY or AS_COMPLEX_PROPERTY_COLLECTION)
+     * @return the expected parameter type, or null if not found
+     */
+    public Class<?> getTypeForComplexProperty(String name, AggregationType aggregationType) {
+        Method relevantMethod = getRelevantMethod(name, aggregationType);
+        if (relevantMethod == null) {
+            return null;
+        }
+        Class<?> paramType = getParameterClassForMethod(relevantMethod);
+        if (paramType == null) {
+            return null;
+        }
+        return paramType;
+    }
+
 }
