+package ch.qos.logback.core.model.processor;
+
+import ch.qos.logback.core.Context;
+import ch.qos.logback.core.model.AppenderModel;
+import ch.qos.logback.core.model.Model;
+
+import java.util.HashSet;
+import java.util.Set;
+
+/**
+ * The AppenderDeclarationAnalyser class is responsible for analyzing the availability
+ * of appenders. By available, we mean whether an appender with a given name is declared
+ * somewhere in the configuration. This availability information is later used by
+ * AppenderRefModelHandler to attempt to attach only those appenders that were previously
+ * declared.
+ *
+ * @since 1.5.19
+ */
+public class AppenderDeclarationAnalyser extends ModelHandlerBase {
+
+    private static final String DECLARED_APPENDERS_KEY = "DECLARED_APPENDERS";
+
+    public AppenderDeclarationAnalyser(Context context) {
+        super(context);
+    }
+
+    @Override
+    protected Class<? extends Model> getSupportedModelClass() {
+        return AppenderModel.class;
+    }
+
+    @Override
+    public void handle(ModelInterpretationContext mic, Model model) throws ModelHandlerException {
+        AppenderModel appenderModel = (AppenderModel) model;
+        String appenderName = mic.subst(appenderModel.getName());
+        if (appenderName != null && !appenderName.isEmpty()) {
+            getDeclaredAppenders(mic).add(appenderName);
+            addInfo("Declared appender named [" + appenderName + "]");
+        }
+    }
+
+    @SuppressWarnings("unchecked")
+    private static Set<String> getDeclaredAppenders(ModelInterpretationContext mic) {
+        Set<String> set = (Set<String>) mic.getObjectMap().get(DECLARED_APPENDERS_KEY);
+        if (set == null) {
+            set = new HashSet<>();
+            mic.getObjectMap().put(DECLARED_APPENDERS_KEY, set);
+        }
+        return set;
+    }
+
+    /**
+     * Checks whether an appender with the given name has been declared in the configuration.
+     *
+     * @param mic the model interpretation context
+     * @param appenderName the name of the appender to check
+     * @return true if the appender is declared, false otherwise
+     */
+    public static boolean isAppenderDeclared(ModelInterpretationContext mic, String appenderName) {
+        return getDeclaredAppenders(mic).contains(appenderName);
+    }
+
+}
