+    /**
+     * Determine the expected property type for a complex property, based on the
+     * setter or adder method's parameter type. This is used to validate that an
+     * object being created during configuration parsing is of the expected type.
+     *
+     * @param nestedElementTagName the tag name of the nested element
+     * @param aggregationType the aggregation type (AS_COMPLEX_PROPERTY or AS_COMPLEX_PROPERTY_COLLECTION)
+     * @return the expected Class type for the property
+     */
+    public Class<?> getTypeForComplexProperty(String nestedElementTagName, AggregationType aggregationType) {
+        Method aMethod = null;
+        String cName = capitalizeFirstLetter(nestedElementTagName);
+        switch (aggregationType) {
+        case AS_COMPLEX_PROPERTY:
+            aMethod = findSetterMethod(nestedElementTagName);
+            break;
+        case AS_COMPLEX_PROPERTY_COLLECTION:
+            aMethod = findAdderMethod(cName);
+            break;
+        default:
+            break;
+        }
+
+        if (aMethod == null) {
+            addError("Could not find method for property [" + nestedElementTagName + "].");
+            return null;
+        }
+
+        Class<?> paramType = getParameterClassForMethod(aMethod);
+        if (paramType == null) {
+            addError("Could not determine parameter type for property [" + nestedElementTagName + "].");
+            return null;
+        }
+
+        return paramType;
+    }
