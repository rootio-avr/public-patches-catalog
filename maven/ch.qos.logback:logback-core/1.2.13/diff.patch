+    /**
+     * Instantiate an object of the given class, but only if it is assignable to the
+     * expected superclass. This restricts object creation to the expected type,
+     * preventing instantiation of arbitrary classes during configuration parsing.
+     *
+     * @param classObj the class to instantiate
+     * @param superClass the expected supertype that classObj must be assignable to
+     * @return a new instance of classObj
+     * @throws IncompatibleClassException if classObj is not assignable to superClass
+     * @throws DynamicClassLoadingException if instantiation fails
+     */
+    public static Object instantiateClassWithSuperclassRestriction(Class<?> classObj, Class<?> superClass)
+                    throws IncompatibleClassException, DynamicClassLoadingException {
+        if (!superClass.isAssignableFrom(classObj)) {
+            throw new IncompatibleClassException(superClass, classObj);
+        }
+        try {
+            return classObj.newInstance();
+        } catch (Throwable t) {
+            throw new DynamicClassLoadingException("Failed to instantiate type " + classObj.getName(), t);
+        }
+    }

