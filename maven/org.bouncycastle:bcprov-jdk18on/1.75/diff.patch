+        {
+            errorSign |= (buf[i] & 0xFF) - 1;
+        }
+
+        // Last pad byte should be zero
+        errorSign |= -(buf[lastPadPos] & 0xFF);
+
+        return errorSign >> 31;
+    }
+
+    private static BigInteger convertInput(BigInteger modulus, byte[] input)
