+
+    // [GHSA-72hv-8253-57qq] Enforce maxNumberLength on the async parser path.
+    // Mirrors StreamReadConstraints.validateIntegerLength / validateFPLength
+    // (added upstream in 2.15+) but uses a hardcoded limit of 1000 to avoid
+    // pulling in the StreamReadConstraints / StreamConstraintsException API.
+    private void _setIntLength(final int len) throws IOException {
+        if (len > MAX_NUMBER_LENGTH) {
+            _reportError("Number length (%d) exceeds the maximum length (%d)",
+                    Integer.valueOf(len), Integer.valueOf(MAX_NUMBER_LENGTH));
+        }
+        _intLength = len;
+    }
+
+    private void _setFractLength(final int len) throws IOException {
+        // assumes that the _intLength has been updated first
+        final int total = _intLength + len;
+        if (total > MAX_NUMBER_LENGTH) {
+            _reportError("Number length (%d) exceeds the maximum length (%d)",
+                    Integer.valueOf(total), Integer.valueOf(MAX_NUMBER_LENGTH));
+        }
+        _fractLength = len;
+    }
+
+    private void _setExpLength(final int len) throws IOException {
+        // assumes that the _intLength and _fractLength have been updated already
+        final int total = _intLength + _fractLength + len;
+        if (total > MAX_NUMBER_LENGTH) {
+            _reportError("Number length (%d) exceeds the maximum length (%d)",
+                    Integer.valueOf(total), Integer.valueOf(MAX_NUMBER_LENGTH));
+        }
+        _expLength = len;
