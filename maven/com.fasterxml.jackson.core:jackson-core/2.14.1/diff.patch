+    // GHSA-72hv-8253-57qq: max number length validation for async parser
+    private static final int MAX_NUM_LEN = 1000;
+
+    private void _setIntLength(final int len) throws IOException {
+        if (len > MAX_NUM_LEN) {
+            _reportError("Number value length (%d) exceeds the maximum allowed (%d)",
+                    len, MAX_NUM_LEN);
+        }
+        _intLength = len;
+    }
+
+    private void _setFractLength(final int len) throws IOException {
+        // assumes that the _intLength has been updated first
+        if ((_intLength + len) > MAX_NUM_LEN) {
+            _reportError("Number value length (%d) exceeds the maximum allowed (%d)",
+                    _intLength + len, MAX_NUM_LEN);
+        }
+        _fractLength = len;
+    }
+
+    private void _setExpLength(final int len) throws IOException {
+        // assumes that the _intLength and _fractLength have been updated already
+        if ((_intLength + _fractLength + len) > MAX_NUM_LEN) {
+            _reportError("Number value length (%d) exceeds the maximum allowed (%d)",
+                    _intLength + _fractLength + len, MAX_NUM_LEN);
+        }
+        _expLength = len;
+    }
