+
+    // [CVE-2025-49128 / jackson-core#652] Verify that source-snippet
+    // generation honors the supplied offset/length window and does not
+    // leak unrelated bytes from the start of a pooled/reused buffer.
+    public void testContentSnippetWithOffset() throws Exception
+    {
+        final String json = a2q("{'k1':'v1'}\n[broken]\n");
+        final byte[] jsonB = utf8Bytes(json);
+        final int lfIndex = json.indexOf("\n");
+        final int start = lfIndex + 1;
+        final int len = json.length() - start;
+
+        // Place a "secret" sentinel before the logical window to mimic
+        // residual data in a recycled buffer.
+        final String secret = "SECRET_RESIDUAL";
+        final byte[] padded = new byte[secret.length() + jsonB.length];
+        System.arraycopy(secret.getBytes("UTF-8"), 0, padded, 0, secret.length());
+        System.arraycopy(jsonB, 0, padded, secret.length(), jsonB.length);
+
+        JsonParser p = JSON_F.createParser(padded, secret.length() + start, len);
+        _verifyNoSecretLeak(p, secret);
+        p.close();
+
+        final char[] paddedC = new char[secret.length() + json.length()];
+        secret.getChars(0, secret.length(), paddedC, 0);
+        json.getChars(0, json.length(), paddedC, secret.length());
+
+        p = JSON_F.createParser(paddedC, secret.length() + start, len);
+        _verifyNoSecretLeak(p, secret);
+        p.close();
+    }
+
+    private void _verifyNoSecretLeak(final JsonParser p, String secret) throws Exception
+    {
+        assertToken(JsonToken.START_ARRAY, p.nextToken());
+        try {
+            p.nextToken();
+            fail("Should not pass");
+        } catch (StreamReadException e) {
+            verifyException(e, "Unrecognized token 'broken'");
+            JsonLocation loc = e.getLocation();
+            final String srcDesc = loc.sourceDescription();
+            // Vulnerable build would include the residual bytes that
+            // precede the supplied offset; fixed build must not.
+            assertFalse("Source description leaked residual buffer bytes: " + srcDesc,
+                    srcDesc.contains(secret));
+        }
+    }
 }

