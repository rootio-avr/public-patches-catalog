diff --git a/src/main/java/com/fasterxml/jackson/core/base/ParserBase.java b/src/main/java/com/fasterxml/jackson/core/base/ParserBase.java
index a6956a4..001ce05 100644
--- a/src/main/java/com/fasterxml/jackson/core/base/ParserBase.java
+++ b/src/main/java/com/fasterxml/jackson/core/base/ParserBase.java
@@ -1259,4 +1259,28 @@ public abstract class ParserBase extends ParserMinimalBase
 
     // Can't declare as deprecated, for now, but shouldn't be needed
     protected void _finishString() throws IOException { }
+
+    /**
+     * Maximum allowed JSON nesting depth before parsing is aborted with a
+     * {@link JsonParseException}. Mirrors the upstream 2.15.0 default of
+     * {@code StreamReadConstraints.DEFAULT_MAX_DEPTH} introduced as the
+     * fix for CVE-2025-52999.
+     */
+    protected static final int MAX_NESTING_DEPTH = 1000;
+
+    protected final void createChildArrayContext(final int lineNr, final int colNr) throws IOException {
+        _parsingContext = _parsingContext.createChildArrayContext(lineNr, colNr);
+        _validateNestingDepth(_parsingContext.getNestingDepth());
+    }
+
+    protected final void createChildObjectContext(final int lineNr, final int colNr) throws IOException {
+        _parsingContext = _parsingContext.createChildObjectContext(lineNr, colNr);
+        _validateNestingDepth(_parsingContext.getNestingDepth());
+    }
+
+    private void _validateNestingDepth(int depth) throws IOException {
+        if (depth > MAX_NESTING_DEPTH) {
+            _reportError(String.format("Depth (%d) exceeds the maximum allowed nesting depth (%d)", depth, MAX_NESTING_DEPTH));
+        }
+    }
 }
