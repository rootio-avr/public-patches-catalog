     /* Internal methods, other
     /**********************************************************************
      */
+
+    // Backport of upstream PR #1555 (GHSA-72hv-8253-57qq):
+    // Enforce a hard cap on numeric token length for the non-blocking parser
+    // to prevent unbounded resource consumption from very long numeric tokens.
+    // Default cap (1000 chars) matches StreamReadConstraints.DEFAULT_MAX_NUM_LEN
+    // introduced upstream in 2.15.0.
+    private static final int MAX_NUMBER_LENGTH = 1000;
+
+    private void _setIntLength(final int len) throws IOException {
+        if (len > MAX_NUMBER_LENGTH) {
+            _reportError("Number length ("+len+") exceeds the maximum length ("+MAX_NUMBER_LENGTH+")");
+        }
+        _intLength = len;
+    }
+
+    private void _setFractLength(final int len) throws IOException {
+        if ((_intLength + len) > MAX_NUMBER_LENGTH) {
+            _reportError("Number length ("+(_intLength + len)+") exceeds the maximum length ("+MAX_NUMBER_LENGTH+")");
+        }
+        _fractLength = len;
+    }
+
+    private void _setExpLength(final int len) throws IOException {
+        if ((_intLength + _fractLength + len) > MAX_NUMBER_LENGTH) {
+            _reportError("Number length ("+(_intLength + _fractLength + len)+") exceeds the maximum length ("+MAX_NUMBER_LENGTH+")");
+        }
+        _expLength = len;
+    }
