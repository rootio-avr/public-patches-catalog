+package com.fasterxml.jackson.core.read;
+
+import com.fasterxml.jackson.core.BaseTest;
+import com.fasterxml.jackson.core.JsonFactory;
+import com.fasterxml.jackson.core.JsonParseException;
+import com.fasterxml.jackson.core.JsonParser;
+import com.fasterxml.jackson.core.JsonToken;
+
+/**
+ * Tests for the nesting-depth limit introduced as a backport of the
+ * upstream fix for CVE-2025-52999 (jackson-core 2.15
+ * {@code StreamReadConstraints.maxNestingDepth}).
+ *
+ * <p>The 2.10.1 backport hard-codes the limit to 1000 (matching upstream's
+ * default) and rejects deeper input with a {@link JsonParseException}
+ * carrying the message
+ * {@code "Depth (N) exceeds the maximum allowed nesting depth (1000)"}.
+ */
+public class DeepNestingParserTest extends BaseTest
+{
+    private static final int LIMIT = 1000;
+
+    public void testDeepNestingArraysStream() throws Exception {
+        _testDeepNestingThrows(MODE_INPUT_STREAM);
+    }
+
+    public void testDeepNestingArraysReader() throws Exception {
+        _testDeepNestingThrows(MODE_READER);
+    }
+
+    public void testDeepNestingArraysDataInput() throws Exception {
+        _testDeepNestingThrows(MODE_DATA_INPUT);
+    }
+
+    public void testNestingAtLimitOk() throws Exception {
+        // exactly LIMIT levels deep must still parse cleanly
+        final String DOC = repeat('[', LIMIT) + repeat(']', LIMIT);
+        JsonParser p = createParser(new JsonFactory(), MODE_READER, DOC);
+        try {
+            JsonToken t;
+            while ((t = p.nextToken()) != null) {
+                // drain
+            }
+        } finally {
+            p.close();
+        }
+    }
+
+    private void _testDeepNestingThrows(int mode) throws Exception {
+        // LIMIT + 50 unclosed `[` should trip the guard at depth LIMIT + 1
+        final String DOC = repeat('[', LIMIT + 50);
+        JsonParser p = createParser(new JsonFactory(), mode, DOC);
+        try {
+            while (p.nextToken() != null) {
+                // keep advancing until the guard fires
+            }
+            fail("Expected JsonParseException for deeply nested input (mode=" + mode + ")");
+        } catch (JsonParseException e) {
+            verifyException(e, "exceeds the maximum allowed nesting depth");
+            verifyException(e, String.valueOf(LIMIT));
+        } finally {
+            p.close();
+        }
+    }
+
+    private static String repeat(char c, int n) {
+        StringBuilder sb = new StringBuilder(n);
+        for (int i = 0; i < n; i++) {
+            sb.append(c);
+        }
+        return sb.toString();
+    }
+}

