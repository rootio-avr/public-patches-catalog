+    // Backport of GHSA-72hv-8253-57qq: enforce a hard cap on number length
+    // in the async parser path. Mirrors upstream commit b0c428e6 (PR #1555).
+    // Upstream uses StreamReadConstraints which does not exist in 2.12.x.
+    private static final int MAX_NUMBER_LENGTH = 1000;
+
+    private void _setIntLength(final int len) throws IOException {
+        if (len > MAX_NUMBER_LENGTH) {
+            _reportError("Number value length (" + len
+                    + ") exceeds the maximum allowed (" + MAX_NUMBER_LENGTH + ")");
+        }
+        _intLength = len;
+    }
+
+    private void _setFractLength(final int len) throws IOException {
+        // assumes that _intLength has been updated first
+        if (_intLength + len > MAX_NUMBER_LENGTH) {
+            _reportError("Number value length (" + (_intLength + len)
+                    + ") exceeds the maximum allowed (" + MAX_NUMBER_LENGTH + ")");
+        }
+        _fractLength = len;
+    }
+
+    private void _setExpLength(final int len) throws IOException {
+        // assumes that _intLength and _fractLength have been updated already
+        if (_intLength + _fractLength + len > MAX_NUMBER_LENGTH) {
+            _reportError("Number value length (" + (_intLength + _fractLength + len)
+                    + ") exceeds the maximum allowed (" + MAX_NUMBER_LENGTH + ")");
+        }
+        _expLength = len;
+    }
