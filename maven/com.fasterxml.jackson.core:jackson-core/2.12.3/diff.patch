+package com.fasterxml.jackson.core.io;
+
+/**
+ * Internal helper used to carry a parsed-content source reference together
+ * with the (offset, length) sub-region that was actually parsed.
+ *<p>
+ * Backport of the upstream {@code ContentReference} abstraction (jackson-core
+ * 2.13+) introduced as part of the fix for CVE-2025-49128
+ * (GHSA-wf8f-6423-gfxg). When a parser is constructed via one of the
+ * {@code createParser(byte[], int, int)} or {@code createParser(char[], int, int)}
+ * factory methods, the source description used in {@link
+ * com.fasterxml.jackson.core.JsonLocation} previously read from index 0 of the
+ * underlying buffer regardless of the supplied offset, which could leak
+ * unrelated bytes (for example, residual data sitting in a pooled buffer)
+ * through exception messages. This wrapper makes the parsed sub-region
+ * available to JsonLocation so the snippet is bounded to (offset, offset+length).
+ *
+ * @since 2.12 (backport)
+ */
+public final class ContentReference
+{
+    /**
+     * Raw content reference (a {@code byte[]}, {@code char[]},
+     * {@link CharSequence}, or other object as supplied by the caller).
+     */
+    private final Object _rawContent;
+
+    /**
+     * Offset of the first content byte/char actually parsed within
+     * {@link #_rawContent}; -1 if unknown.
+     */
+    private final int _offset;
+
+    /**
+     * Length, in bytes/chars, of the content actually parsed starting at
+     * {@link #_offset}; -1 if unknown.
+     */
+    private final int _length;
+
+    public ContentReference(Object rawContent, int offset, int length) {
+        _rawContent = rawContent;
+        _offset = offset;
+        _length = length;
+    }
+
+    public Object getRawContent() { return _rawContent; }
+    public int contentOffset() { return _offset; }
+    public int contentLength() { return _length; }
+
+    public boolean hasTextualContent() {
+        return (_rawContent instanceof CharSequence)
+                || (_rawContent instanceof char[])
+                || (_rawContent instanceof byte[]);
+    }
+
+    /**
+     * Returns the type name to use when rendering the source description.
+     */
+    public String typeName() {
+        if (_rawContent == null) return "UNKNOWN";
+        if (_rawContent instanceof byte[]) return "byte[]";
+        if (_rawContent instanceof char[]) return "char[]";
+        Class<?> c = (_rawContent instanceof Class<?>)
+                ? (Class<?>) _rawContent : _rawContent.getClass();
+        return c.getName().startsWith("java.") ? c.getSimpleName() : c.getName();
+    }
