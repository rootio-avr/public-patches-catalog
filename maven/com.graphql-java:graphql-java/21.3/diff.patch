+    /**
+     * Checks if an introspection query is sensible and should be allowed to proceed.
+     * If the query contains introspection fields (__schema or __type), it will be
+     * validated by {@link GoodFaithIntrospection} to ensure it doesn't create
+     * excessive ENFs that could cause DoS.
+     *
+     * @param mergedSelectionSet the merged selection set of the operation
+     * @param executionContext   the execution context
+     * @return an Optional containing an error result if the introspection is not sensible,
+     *         or empty if the query should proceed
+     */
+    public static Optional<ExecutionResult> isIntrospectionSensible(MergedSelectionSet mergedSelectionSet, ExecutionContext executionContext) {
+        GraphQLContext graphQLContext = executionContext.getGraphQLContext();
+
+        boolean isIntrospection = false;
+        for (String key : mergedSelectionSet.getKeys()) {
+            String fieldName = mergedSelectionSet.getSubField(key).getName();
+            if (fieldName.equals(SchemaMetaFieldDef.getName())
+                    || fieldName.equals(TypeMetaFieldDef.getName())) {
+                if (!isIntrospectionEnabled(graphQLContext)) {
+                    return mkDisabledError(mergedSelectionSet.getSubField(key));
+                }
+                isIntrospection = true;
+                break;
+            }
+        }
+        if (isIntrospection) {
+            return GoodFaithIntrospection.checkIntrospection(executionContext);
+        }
+        return Optional.empty();
+    }
+
+    private static boolean isIntrospectionEnabled(GraphQLContext graphQlContext) {
+        return !graphQlContext.getOrDefault(GoodFaithIntrospection.GOOD_FAITH_INTROSPECTION_DISABLED, false);
+    }
+
+    private static Optional<ExecutionResult> mkDisabledError(MergedField field) {
+        return Optional.of(ExecutionResult.newExecutionResult()
+                .addError(new GoodFaithIntrospection.BadFaithIntrospectionError(field.getName()))
+                .build());
+    }
