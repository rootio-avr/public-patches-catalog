+                    if (matchOutputLimit > fastOutputLimit) {
+                        while (output < fastOutputLimit) {
+                            UNSAFE.putLong(outputBase, output, UNSAFE.getLong(outputBase, matchAddress));
+                            matchAddress += SIZE_OF_LONG;
+                            output += SIZE_OF_LONG;
+                        }
