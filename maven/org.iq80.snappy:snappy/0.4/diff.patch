+            int trailerBytes = entry >>> 11;
+            int trailer = 0;
+            if (input + SIZE_OF_INT < inputLimit) {
+                trailer = UNSAFE.getInt(inputBase, input) & wordmask[trailerBytes];
+            }
+            else {
