+                    throw new CorruptionException(input - inputAddress);
+                }
+                switch (trailerBytes) {
+                    case 4:
+                        trailer = (UNSAFE.getByte(inputBase, input + 3) & 0xff) << 24;
+                    case 3:
+                        trailer |= (UNSAFE.getByte(inputBase, input + 2) & 0xff) << 16;
+                    case 2:
