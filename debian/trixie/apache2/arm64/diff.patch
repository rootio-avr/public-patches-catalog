Description: CVE-2026-42535 - mod_dav_fs: disallow access to DAV state directory
 A path handling issue in mod_dav_fs in Apache HTTP Server 2.4.67 and
 earlier allows a WebDAV content author to directly manipulate the
 trusted DAV property/lock databases that mod_dav_fs stores under the
 DAV_FS_STATE_DIR (".DAV") subdirectory of each DAV-enabled location.
 By writing crafted content into those database files (or into files
 within the state directory), an attacker with WebDAV write access can
 corrupt mod_dav_fs's internal state and trigger child-process crashes,
 yielding integrity and availability impact (CVSS 9.1, CWE-668).
 .
 This patch backports the upstream 2.4.x fix (commit 56bfb12, merging
 trunk r1935009) to apache2 2.4.67 as shipped in Debian trixie. The
 fix extends dav_fs_get_resource() to compute the leaf and parent
 directory names of the resolved on-disk path and refuse any request
 whose path is, or descends into, the DAV_FS_STATE_DIR. Such requests
 are logged at APLOG_ERR and answered with HTTP 403 Forbidden
 ("Access to the state directory denied."). Case-insensitive
 comparison is used on case-blind filesystems.
 .
 The fix introduces no API/ABI changes: it only adds two local
 variables, an additional include of apr_lib.h (already linked by
 mod_dav_fs), and a self-contained guard block. All referenced
 helpers (apr_filepath_name_get, ap_make_dirstr_parent,
 ap_cstr_casecmp, dav_new_error, ap_log_rerror) and the
 DAV_FS_STATE_DIR macro already exist in the target tree.
Origin: upstream, https://github.com/apache/httpd/commit/56bfb12
Bug: https://security-tracker.debian.org/tracker/CVE-2026-42535
Author: Joe Orton <jorton@apache.org>
Last-Update: 2026-06-10
---
--- a/modules/dav/fs/repos.c
+++ b/modules/dav/fs/repos.c
@@ -22,6 +22,7 @@
 #include "apr_file_io.h"
 #include "apr_strings.h"
 #include "apr_buckets.h"
+#include "apr_lib.h"
 
 #if APR_HAVE_UNISTD_H
 #include <unistd.h>             /* for getpid() */
@@ -673,8 +674,8 @@ static dav_error * dav_fs_get_resource(
 {
     dav_resource_private *ctx;
     dav_resource *resource;
-    char *s;
-    char *filename;
+    char *s, *parent;
+    const char *filename, *dirname;
     apr_size_t len;
 
     /* ### optimize this into a single allocation! */
@@ -708,6 +709,30 @@ static dav_error * dav_fs_get_resource(
     if (len > 1 && s[len - 1] == '/') {
         s[len - 1] = '\0';
     }
+
+    /* Deny any access to, or within, the state directory. */
+    filename = apr_filepath_name_get(s);
+    parent = ap_make_dirstr_parent(r->pool, s);
+    /* Strip the trailing slash and extract the leaf directory name. */
+    len = strlen(parent);
+    if (len > 1 && parent[len - 1] == '/') {
+        parent[len - 1] = '\0';
+    }
+    dirname = apr_filepath_name_get(parent);
+#ifdef CASE_BLIND_FILESYSTEM
+    if (ap_cstr_casecmp(filename, DAV_FS_STATE_DIR) == 0
+        || ap_cstr_casecmp(dirname, DAV_FS_STATE_DIR) == 0) {
+#else
+    if (strcmp(filename, DAV_FS_STATE_DIR) == 0
+        || strcmp(dirname, DAV_FS_STATE_DIR) == 0) {
+#endif
+        ap_log_rerror(APLOG_MARK, APLOG_ERR, 0, r,
+                      "access to " DAV_FS_STATE_DIR " state directory "
+                      "denied for %s", r->filename);
+        return dav_new_error(r->pool, HTTP_FORBIDDEN, 0, 0,
+                             "Access to the state directory denied.");
+    }
+
     ctx->pathname = s;
 
     /* Create resource descriptor */
Description: CVE-2026-29167 - Fix use-after-free in mod_ldap per-directory context
 Use After Free vulnerability in Apache HTTP Server with mod_ldap in
 per-directory configuration. Cached LDAP connections retained pointers
 into a potentially short-lived per-directory config pool (specifically
 the client cert list including path and password strings), creating a
 dangling-pointer / use-after-free hazard.
 .
 The fix deep-copies the client cert list (path and password strings)
 into the long-lived connection pool in uldap_connection_find(), so the
 cached connection no longer retains pointers into the per-dir pool.
Origin: upstream, https://github.com/apache/httpd/commit/2cf9b3f393633f43746047e779fdf265a1ad8016
Author: Joe Orton <jorton@apache.org>
Bug: https://bugs.debian.org/cgi-bin/bugreport.cgi?bug=1139340
Last-Update: 2026-06-10
---
--- a/modules/ldap/util_ldap.c
+++ b/modules/ldap/util_ldap.c
@@ -897,8 +897,23 @@ static util_ldap_connection_t *
          */
         l->secure = secureflag;
 
-        /* save away a copy of the client cert list that is presently valid */
-        l->client_certs = apr_array_copy_hdr(l->pool, dc->client_certs);
+        /* Deep-copy the client cert list into the connection pool so that
+         * the cached connection does not retain pointers into the
+         * (potentially short-lived) per-directory config pool.
+         */
+        l->client_certs = apr_array_copy(l->pool, dc->client_certs);
+        if (!apr_is_empty_array(l->client_certs)) {
+            int i;
+            apr_ldap_opt_tls_cert_t *certs;
+
+            certs = (apr_ldap_opt_tls_cert_t *)l->client_certs->elts;
+            for (i = 0; i < l->client_certs->nelts; i++) {
+                if (certs[i].path)
+                    certs[i].path = apr_pstrdup(l->pool, certs[i].path);
+                if (certs[i].password)
+                    certs[i].password = apr_pstrdup(l->pool, certs[i].password);
+            }
+        }
 
         /* whether or not to keep this connection in the pool when it's returned */
         l->keep = (st->connection_pool_ttl == 0) ? 0 : 1;
