Description: Fix possible buffer overflow when reading mask image
 When reading a mask image, the memcpy used data.size() as the copy length
 which could exceed the allocated buffer. This fixes it by using the actual
 image dimensions (width * height) and corrects the stride comparison cast.
Origin: upstream, https://github.com/strukturag/libheif/commit/123694271ac02f2de68a3ccdc5d483eb8a2ae593
Author: Dirk Farin <dirk.farin@gmail.com>
Last-Update: 2026-03-05

--- a/libheif/image-items/mask_image.cc
+++ b/libheif/image-items/mask_image.cc
@@ -113,8 +113,8 @@

   size_t stride;
   uint8_t* dst = img->get_plane(heif_channel_Y, &stride);
-  if (((uint32_t)stride) == width) {
-    memcpy(dst, data.data(), data.size());
+  if (stride == static_cast<size_t>(width)) {
+    memcpy(dst, data.data(), static_cast<size_t>(width) * height);
   }
   else
   {
