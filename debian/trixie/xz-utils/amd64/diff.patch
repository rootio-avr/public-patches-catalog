Description: CVE-2026-34743 - Fix a buffer overflow in lzma_index_append()
 If lzma_index_decoder() was used to decode an Index that contained no
 Records, the resulting lzma_index had an invalid internal "prealloc"
 value. If lzma_index_append() was called on this lzma_index, too
 little memory would be allocated and a buffer overflow would occur.
Origin: upstream, https://github.com/tukaani-project/xz/commit/c8c22869e780ff57c96b46939c3d79ff99395f87
Author: Lasse Collin <lasse.collin@tukaani.org>
Last-Update: 2026-04-04

Also includes an override_dh_installdocs in debian/rules so a build
with nocheck in DEB_BUILD_OPTIONS (or any path where Doxygen output is
absent) does not fail: liblzma-doc.docs requires usr/share/doc/xz/api.
(Second hunk, os-patcher 2026-04-24)

--- a/src/liblzma/common/index.c
+++ b/src/liblzma/common/index.c
@@ -433,6 +433,26 @@
 	if (records > PREALLOC_MAX)
 		records = PREALLOC_MAX;

+	// If index_decoder.c calls us with records == 0, it's decoding
+	// an Index that has no Records. In that case the decoder won't call
+	// lzma_index_append() at all, and i->prealloc isn't used during
+	// the Index decoding either.
+	//
+	// Normally the first lzma_index_append() call from the Index decoder
+	// would reset i->prealloc to INDEX_GROUP_SIZE. With no Records,
+	// lzma_index_append() isn't called and the resetting of prealloc
+	// won't occur either. Thus, if records == 0, use the default value
+	// INDEX_GROUP_SIZE instead.
+	//
+	// NOTE: lzma_index_append() assumes i->prealloc > 0. liblzma <= 5.8.2
+	// didn't have this check and could set i->prealloc = 0, which would
+	// result in a buffer overflow if the application called
+	// lzma_index_append() after decoding an empty Index. Appending
+	// Records after decoding an Index is a rare thing to do, but
+	// it is supposed to work.
+	if (records == 0)
+		records = INDEX_GROUP_SIZE;
+
 	i->prealloc = (size_t)(records);
 	return;
 }
@@ -685,6 +705,7 @@
 		++g->last;
 	} else {
 		// We need to allocate a new group.
+		assert(i->prealloc > 0);
 		g = lzma_alloc(sizeof(index_group)
 				+ i->prealloc * sizeof(index_record),
 				allocator);
--- a/debian/rules
+++ b/debian/rules
@@ -111,6 +111,17 @@
     MAKEFLAGS += --quiet
 endif
 
+
+override_dh_installdocs:
+	# When Doxygen is skipped (e.g. nocheck in DEB_BUILD_OPTIONS), the
+	# directory listed in liblzma-doc.docs never appears under debian/tmp.
+	# Add a placeholder tree so dh_installdocs does not abort.
+	if [ ! -e debian/tmp/usr/share/doc/xz/api ] && [ ! -d usr/share/doc/xz/api ]; then \
+		mkdir -p debian/tmp/usr/share/doc/xz/api; \
+		printf '%s\n' 'Placeholder: Doxygen API HTML was not built (e.g. nocheck in DEB_BUILD_OPTIONS skips the indep configure; full docs need doxygen and graphviz). See upstream xz-utils in a full indep+arch build.' > debian/tmp/usr/share/doc/xz/api/README; \
+	fi
+	dh_installdocs
+
 override_dh_makeshlibs:
 	dh_makeshlibs --add-udeb=liblzma5-udeb
