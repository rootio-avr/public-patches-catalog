Description: CVE-2026-56362 - reset channel map when cache resources are exhausted
 ImageMagick before 7.1.2-15 contains a heap-buffer-overflow read in
 GetPixelIndex caused by OpenPixelCache updating image channel metadata
 before pixel cache memory allocation succeeded. When memory/disk resource
 acquisition failed, image->channel_map still referenced pixel channels the
 (now torn-down) cache never allocated, so any writer that later called
 GetPixelIndex performed an out-of-bounds read.
 .
 This patch zeroes image->channel_map on every CacheResourcesExhausted exit
 in OpenPixelCache() (two paths) and in PersistPixelCache() (one path),
 matching the upstream fix. The PersistPixelCache path also sets
 cache_info->type=UndefinedCache (already implicit in the two OpenPixelCache
 paths).
 .
 Backport note: the two OpenPixelCache changes are combined into a single
 hunk with wider context, because trixie's cache.c contains two adjacent
 code blocks with identical short-context, and splitting them causes
 `patch` to misalign them. Wider context uses the surrounding "Create pixel
 cache on disk." comment as an anchor for disambiguation.
Origin: upstream, https://github.com/ImageMagick/ImageMagick/commit/364606e5cb955b622b13015814e255e1dadd701b
Author: Cristy <urban-warrior@imagemagick.org>
Last-Update: 2026-07-12

--- a/MagickCore/cache.c
+++ b/MagickCore/cache.c
@@ -3971,32 +3971,36 @@ static MagickBooleanType OpenPixelCache(Image *image,const MapMode mode,
                     RelinquishPixelCachePixels(&source_info);
                   cache_info->type=UndefinedCache;
                   return(MagickFalse);
                 }
               return(MagickTrue);
             }
         }
       if ((source_info.storage_class != UndefinedClass) && (mode != ReadMode))
         RelinquishPixelCachePixels(&source_info);
       cache_info->type=UndefinedCache;
+      (void) memset(image->channel_map,0,MaxPixelChannels*
+        sizeof(*image->channel_map));
       (void) ThrowMagickException(exception,GetMagickModule(),CacheError,
         "CacheResourcesExhausted","`%s'",image->filename);
       return(MagickFalse);
     }
   /*
     Create pixel cache on disk.
   */
   if (status == MagickFalse)
     {
       if ((source_info.storage_class != UndefinedClass) && (mode != ReadMode))
         RelinquishPixelCachePixels(&source_info);
       cache_info->type=UndefinedCache;
+      (void) memset(image->channel_map,0,MaxPixelChannels*
+        sizeof(*image->channel_map));
       (void) ThrowMagickException(exception,GetMagickModule(),CacheError,
         "CacheResourcesExhausted","`%s'",image->filename);
       return(MagickFalse);
     }
   if ((source_info.storage_class != UndefinedClass) && (mode != ReadMode) &&
       (cache_info->mode != PersistMode))
     {
       (void) ClosePixelCacheOnDisk(cache_info);
       *cache_info->cache_filename='\0';
     }
@@ -4190,20 +4194,23 @@ MagickExport MagickBooleanType PersistPixelCache(Image *image,
       *offset=(*offset+(MagickOffsetType) cache_info->length+page_size-
         ((MagickOffsetType) cache_info->length % page_size));
       return(MagickTrue);
     }
   /*
     Clone persistent pixel cache.
   */
   status=AcquireMagickResource(DiskResource,cache_info->length);
   if (status == MagickFalse)
     {
+      cache_info->type=UndefinedCache;
+      (void) memset(image->channel_map,0,MaxPixelChannels*
+        sizeof(*image->channel_map));
       (void) ThrowMagickException(exception,GetMagickModule(),CacheError,
         "CacheResourcesExhausted","`%s'",image->filename);
       return(MagickFalse);
     }
   clone_info=(CacheInfo *) ClonePixelCache(cache_info);
   clone_info->type=DiskCache;
   (void) CopyMagickString(clone_info->cache_filename,filename,MagickPathExtent);
   clone_info->file=(-1);
   clone_info->storage_class=cache_info->storage_class;
   clone_info->colorspace=cache_info->colorspace;
Description: Fix CVE-2026-56374 heap buffer overflow (OOB read) in FTXT encoder
 The FTXT encoder in coders/ftxt.c lacked a boundary check when parsing the
 ftxt:format parameter, causing WriteFTXTImage to advance pFmt past the
 terminating NUL byte and resulting in an out-of-bounds read on the format
 string. A crafted FTXT image / format parameter could trigger the OOB read,
 leading to denial of service or information disclosure (CWE-125).
 .
 This backport guards the pFmt++ increment with an `if (*pFmt)` check so the
 pointer never advances past the string terminator. The hunk 1 signature
 reformat is preserved from upstream to keep context stable and to minimise
 divergence from the upstream tree.
Origin: upstream, https://github.com/ImageMagick/ImageMagick/commit/22aef933133770706caafb93f814f5306dcca345
Bug: https://github.com/ImageMagick/ImageMagick/security/advisories/GHSA-w54j-7wpm-crhj
Author: Cristy <urban-warrior@imagemagick.org>
Last-Update: 2026-07-12
---
--- a/coders/ftxt.c
+++ b/coders/ftxt.c
@@ -831,8 +831,8 @@ ModuleExport void UnregisterFTXTImage(vo
 %    o exception: return any errors or warnings in this structure.
 %
 */
-static MagickBooleanType WriteFTXTImage(const ImageInfo *image_info,Image *image,
-  ExceptionInfo *exception)
+static MagickBooleanType WriteFTXTImage(const ImageInfo *image_info,
+  Image *image,ExceptionInfo *exception)
 {
   char
     buffer[MaxTextExtent],
@@ -1038,7 +1038,8 @@ static MagickBooleanType WriteFTXTImage(
               buffer[1]='\0';
               (void) WriteBlobString(image,buffer);
             }
-          pFmt++;
+          if (*pFmt)
+            pFmt++;
         }
         p+=(ptrdiff_t) GetPixelChannels(image);
       }
