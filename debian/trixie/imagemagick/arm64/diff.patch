Description: CVE-2026-46522 - Fix infinite loop in MIFF decoder
 When length == 0, BZip2, LZMA, and Zlib decompression paths in the MIFF
 decoder could enter an infinite loop causing CPU exhaustion. Add explicit
 checks to abort with a CorruptImageError when this condition is detected.
Origin: upstream, https://github.com/ImageMagick/ImageMagick/commit/e8431d4a282013851cb698fdf29b1d7ad80ad7cb
Author: Cristy <urban-warrior@imagemagick.org>
Last-Update: 2026-05-24

--- a/coders/miff.c
+++ b/coders/miff.c
@@ -1497,6 +1497,11 @@
                     ThrowMIFFException(CorruptImageError,
                       "UnableToReadImageData");
                   }
+                if (length == 0)
+                  {
+                    (void) BZ2_bzDecompressEnd(&bzip_info);
+                    ThrowMIFFException(CorruptImageError,"UnexpectedEndOfFile");
+                  }
               }
             code=BZ2_bzDecompress(&bzip_info);
             if ((code != BZ_OK) && (code != BZ_STREAM_END))
@@ -1536,6 +1541,11 @@
                     ThrowMIFFException(CorruptImageError,
                       "UnableToReadImageData");
                   }
+                if (length == 0)
+                  {
+                    lzma_end(&lzma_info);
+                    ThrowMIFFException(CorruptImageError,"UnexpectedEndOfFile");
+                  }
               }
             code=(int) lzma_code(&lzma_info,LZMA_RUN);
             if (code == LZMA_STREAM_END)
@@ -1578,6 +1588,11 @@
                     ThrowMIFFException(CorruptImageError,
                       "UnableToReadImageData");
                   }
+                if (length == 0)
+                  {
+                    (void) inflateEnd(&zip_info);
+                    ThrowMIFFException(CorruptImageError,"UnexpectedEndOfFile");
+                  }
               }
             code=inflate(&zip_info,Z_SYNC_FLUSH);
             if ((code != Z_OK) && (code != Z_STREAM_END))
Description: CVE-2026-42326 - Fix heap buffer over-read in IPTC encoder
