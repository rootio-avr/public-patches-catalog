Description: CVE-2026-32636 - Fix out-of-bounds write in ConvertUTF16ToUTF8
 ImageMagick contains a heap-buffer-overflow in the ConvertUTF16ToUTF8
 helper function in MagickCore/xml-tree.c. The buffer is resized to
 exactly *length bytes but a null terminator is written at utf8[*length],
 one byte past the end of the allocated buffer. This corrects the
 off-by-one by allocating (*length+1) bytes.
Origin: upstream, commit:361b42c91d173cfb4bd8f39898c599feef6a1e55
Author: Dirk Lemstra <dirk@lemstra.org>
Last-Update: 2026-03-24

--- a/MagickCore/xml-tree.c
+++ b/MagickCore/xml-tree.c
@@ -1276,7 +1276,7 @@ static char *ConvertUTF16ToUTF8(const ch
     }
   }
   *length=(size_t) j;
-  utf8=(char *) ResizeQuantumMemory(utf8,*length,sizeof(*utf8));
+  utf8=(char *) ResizeQuantumMemory(utf8,(*length+1),sizeof(*utf8));
   if (utf8 != (char *) NULL)
     utf8[*length]='\0';
   return(utf8);
