Description: CVE-2026-9538 - Cap Archive::Tar entry size during read to prevent memory DoS
 Archive::Tar's _read_tar() previously allocated a Perl scalar of the
 attacker-controlled, header-declared entry size before reading the body,
 allowing a small crafted tar archive to trigger multi-GB allocation
 (CWE-789). This backport introduces $MAX_FILE_SIZE (default 1 GiB) and
 refuses entries whose declared size exceeds the cap.
 .
 Backported from upstream Archive-Tar 3.10
 (jib/archive-tar-new commit f9af01426038e29d9578825a0cd3626946ab08c7)
 to the Archive::Tar 3.02 bundled in Debian trixie's perl 5.40.1-6.
 The `use vars` and variable-init hunks are adapted because target 3.02
 lacks $EXTRACT_HARDLINK; the security check and POD hunks are unchanged.
Origin: upstream, https://github.com/jib/archive-tar-new/commit/f9af01426038e29d9578825a0cd3626946ab08c7
Author: Stig Palmquist <stig@stig.io>
Last-Update: 2026-05-27
---
--- a/cpan/Archive-Tar/lib/Archive/Tar.pm
+++ b/cpan/Archive-Tar/lib/Archive/Tar.pm
@@ -24,7 +24,7 @@ use strict;
 use vars qw[$DEBUG $error $VERSION $WARN $FOLLOW_SYMLINK $CHOWN $CHMOD
             $DO_NOT_USE_PREFIX $HAS_PERLIO $HAS_IO_STRING $SAME_PERMISSIONS
             $INSECURE_EXTRACT_MODE $ZERO_PAD_NUMBERS @ISA @EXPORT $RESOLVE_SYMLINK
-            $EXTRACT_BLOCK_SIZE
+            $EXTRACT_BLOCK_SIZE $MAX_FILE_SIZE
          ];

 @ISA                    = qw[Exporter];
@@ -41,6 +41,7 @@ $INSECURE_EXTRACT_MODE  = 0;
 $ZERO_PAD_NUMBERS       = 0;
 $RESOLVE_SYMLINK        = $ENV{'PERL5_AT_RESOLVE_SYMLINK'} || 'speed';
 $EXTRACT_BLOCK_SIZE     = 1024 * 1024 * 1024;
+$MAX_FILE_SIZE          = 1024 * 1024 * 1024;

 BEGIN {
     use Config;
@@ -444,6 +445,14 @@ sub _read_tar {

             my $block = BLOCK_SIZE->( $entry->size );

+            if ( $MAX_FILE_SIZE && $entry->size > $MAX_FILE_SIZE ) {
+                $self->_error( qq[Entry '] . $entry->full_path .
+                    qq[' declared size ] . $entry->size .
+                    qq[ bytes exceeds \$Archive::Tar::MAX_FILE_SIZE ] .
+                    qq[($MAX_FILE_SIZE); refusing to allocate] );
+                next LOOP;
+            }
+
             $data = $entry->get_content_by_ref;

 	    my $skip = 0;
@@ -2187,6 +2196,13 @@ cannot be arbitrarily large since some operating systems limit the number of
 bytes that can be written in one call to C<write(2)>, so if this is too large,
 extraction may fail with an error.

+=head2 $Archive::Tar::MAX_FILE_SIZE
+
+This variable holds an upper bound on the per-entry declared size that
+C<Archive::Tar> will accept when reading an archive. Entries whose header
+claims a larger size are refused with an error before any read allocation.
+Defaults to 1 GiB. Set to 0 to disable the cap.
+
 =cut

 =head1 FAQDescription: CVE-2026-7010 - Validate request URI, method, and header values
 HTTP::Tiny did not validate header field values processed by the
 control-headers loop in write_header_lines, nor the request URI or method
 passed to write_request_header. An attacker controlling those inputs could
 inject extra headers or smuggle a second request to the upstream server.
 .
 This backports both hunks of upstream commit d73c7651 (HTTP-Tiny 0.093):
   * write_header_lines: add a Field_Content / Printable check inside the
     first ("control headers") loop covering host, cache-control, expect,
     max-forwards, pragma, range, te. The bundled HTTP-Tiny 0.090 already
     has the equivalent check on the second ("other headers") loop, so we
     only need to add it in the first loop.
   * write_request_header: reject any \\x00-\\x20 / \\x7F characters in the
     method and request-URI before they are written to the wire.
 .
 Also adds the upstream regression tests from commit 207890b6 covering the
 new validation logic (CRLF / NUL / trailing-space in method, CRLF / space
 in request-URI, and CRLF in control / generic header values).
Origin: upstream, https://github.com/Perl-Toolchain-Gang/HTTP-Tiny/commit/d73c7651e82ace02693842df55928b6c3ae7c38d
Origin: upstream, https://github.com/Perl-Toolchain-Gang/HTTP-Tiny/commit/207890b6dab21c9db314af50d63202d13f317e2a
Author: Stig Palmquist <git@stig.io>
Last-Update: 2026-06-09
---
--- a/cpan/HTTP-Tiny/lib/HTTP/Tiny.pm
+++ b/cpan/HTTP-Tiny/lib/HTTP/Tiny.pm
@@ -1383,4 +1383,6 @@ sub write_header_lines {
         for (ref $v eq 'ARRAY' ? @$v : $v) {
+            die(qq/Invalid HTTP header field value ($field_name): / . $Printable->($_). "\n")
+              unless $_ eq '' || /\A $Field_Content \z/xo;
             $_ = '' unless defined $_;
             $buf .= "$field_name: $_\x0D\x0A";
         }
@@ -1573,4 +1575,10 @@ sub write_request_header {
     my ($self, $method, $request_uri, $headers, $header_case) = @_;

+    die (q/Invalid characters in Request-URI /. $Printable->($request_uri). "\n")
+      if $request_uri =~ /[\x00-\x20\x7F]/;
+
+    die (q/Invalid characters in Method /. $Printable->($method). "\n")
+      if $method =~ /[\x00-\x20\x7F]/;
+
     return $self->write_header_lines($headers, $header_case, "$method $request_uri HTTP/1.1\x0D\x0A");
 }
