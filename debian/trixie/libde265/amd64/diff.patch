Description: CVE-2026-33164 - Fix reallocation of metadata array when ctb size changes
 A malformed H.265 PPS NAL unit causes a segmentation fault in
 pic_parameter_set::set_derived_values() in libde265 versions prior to
 1.0.17. The fix adds a check for ctb size changes during metadata array
 reallocation and narrows the log2unitSize type from int to uint8_t.
Origin: upstream, https://github.com/strukturag/libde265/commit/c7891e412106130b83f8e8ea8b7f907e9449b658
Author: Dirk Farin <dirk.farin@gmail.com>
Last-Update: 2026-03-31

--- a/libde265/image.cc
+++ b/libde265/image.cc
@@ -452,8 +452,9 @@

     // CTB info

-    if (ctb_info.width_in_units != sps->PicWidthInCtbsY ||
-        ctb_info.height_in_units != sps->PicHeightInCtbsY)
+    if (ctb_info.width_in_units  != sps->PicWidthInCtbsY  ||
+        ctb_info.height_in_units != sps->PicHeightInCtbsY ||
+        ctb_info.log2unitSize    != sps->Log2CtbSizeY)
       {
         delete[] ctb_progress;

--- a/libde265/image.h
+++ b/libde265/image.h
@@ -149,7 +149,7 @@
   // private:
   DataUnit* data;
   int data_size;
-  int log2unitSize;
+  uint8_t log2unitSize;
   int width_in_units;
   int height_in_units;
 };
