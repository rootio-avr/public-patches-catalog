Description: CVE-2026-4437, CVE-2026-4438 - Fix DNS response parsing in gethostbyaddr
 The answer section boundary was previously ignored, and the code in
 getanswer_ptr would iterate past the last resource record, but not
 beyond the end of the returned data. This could lead to subsequent data
 being interpreted as answer records, thus violating the DNS
 specification (CVE-2026-4437). Additionally, the processed hostname in
 getanswer_ptr was checked against the wrong variable, allowing invalid
 characters including shell metacharacters (CVE-2026-4438).
Origin: upstream, https://inbox.sourceware.org/libc-alpha/20260320194250.1089143-1-carlos@redhat.com/
Bug: https://sourceware.org/bugzilla/show_bug.cgi?id=34014
Author: Carlos O'Donell <carlos@redhat.com>
Last-Update: 2026-03-31

--- a/resolv/nss_dns/dns-host.c
+++ b/resolv/nss_dns/dns-host.c
@@ -820,7 +820,7 @@ getanswer_ptr (unsigned char *packet, size_t packetlen,
   /* expected_name may be updated to point into this buffer.  */
   unsigned char name_buffer[NS_MAXCDNAME];

-  while (ancount > 0)
+  for (; ancount > 0; --ancount)
     {
       struct ns_rr_wire rr;
       if (!__ns_rr_cursor_next (&c, &rr))
@@ -866,7 +866,7 @@ getanswer_ptr (unsigned char *packet, size_t packetlen,
 	  char hname[MAXHOSTNAMELEN + 1];
 	  if (__ns_name_unpack (c.begin, c.end, rr.rdata,
 				name_buffer, sizeof (name_buffer)) < 0
-	      || !__res_binary_hnok (expected_name)
+	      || !__res_binary_hnok (name_buffer)
 	      || __ns_name_ntop (name_buffer, hname, sizeof (hname)) < 0)
 	    {
 	      *h_errnop = NO_RECOVERY;
Description: CVE-2026-4046 - Fix assertion failure in IBM1390/IBM1399 iconv modules
 The iconv() function may crash due to a reachable assertion when converting
 inputs from the IBM1390 or IBM1399 character sets. A crafted input sequence
 that maps to the combined character range but has an invalid (zero) entry in
 the combined lookup table triggers assert(cmbp->res1 != 0 && cmbp->res2 != 0)
 in the SUB_COMBINED_UCS_FROM_IBM13XX macro. Replace the assertion with proper
 error handling to return GCONV_ILLEGAL_INPUT instead of crashing.
Origin: upstream, https://sourceware.org/bugzilla/show_bug.cgi?id=33980
Author: ROOT.io Security <security@root.io>
Last-Update: 2026-04-02

--- a/iconvdata/ibm1364.c
+++ b/iconvdata/ibm1364.c
@@ -128,12 +128,24 @@
 									      \
 	const struct divide *cmbp					      \
 	  = &DB_TO_UCS4_COMB[ch - __TO_UCS4_COMBINED_MIN];		      \
-	assert (cmbp->res1 != 0 && cmbp->res2 != 0);			      \
+	if (__glibc_unlikely (cmbp->res1 == 0 || cmbp->res2 == 0))	      \
+	  {								      \
+	    /* This is an illegal character.  */			      \
+	    if (! ignore_errors_p ())					      \
+	      {								      \
+		result = __gconv_mark_illegal_input (step_data);	      \
+		break;							      \
+	      }								      \
+	    ++*irreversible;						      \
+	  }								      \
+	else								      \
+	  {								      \
+	    put32 (outptr, cmbp->res1);				      \
+	    outptr += 4;						      \
+	    put32 (outptr, cmbp->res2);				      \
+	    outptr += 4;						      \
+	  }								      \
 									      \
-	put32 (outptr, cmbp->res1);					      \
-	outptr += 4;							      \
-	put32 (outptr, cmbp->res2);					      \
-	outptr += 4;							      \
       }									      \
   }
 #else
