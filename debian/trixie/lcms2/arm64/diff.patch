Description: CVE-2026-41254 - Fix integer overflow in CubeSize()
 Little CMS (lcms2) through 2.18 has an integer overflow in CubeSize()
 in cmslut.c. The variable rv is declared as cmsUInt32Number which can
 overflow during multiplication, and the overflow check is performed
 after the multiplication rather than before it. This patch widens rv
 to cmsUInt64Number and reorders the overflow check to occur before the
 multiplication.
Origin: upstream, https://github.com/mm2/Little-CMS/commit/da6110b1d14abc394633a388209abd5ebedd7ab0
Bug: https://github.com/mm2/Little-CMS/issues/539
Author: Marti Maria <info@littlecms.com>
Last-Update: 2026-04-21

--- a/src/cmslut.c
+++ b/src/cmslut.c
@@ -460,20 +460,21 @@
 static
 cmsUInt32Number CubeSize(const cmsUInt32Number Dims[], cmsUInt32Number b)
 {
-    cmsUInt32Number rv, dim;
+    cmsUInt32Number dim;
+    cmsUInt64Number rv;

     _cmsAssert(Dims != NULL);

     for (rv = 1; b > 0; b--) {

         dim = Dims[b-1];
-        if (dim <= 1) return 0;  // Error
-
-        rv *= dim;
+        if (dim <= 1) return 0;

         // Check for overflow
         if (rv > UINT_MAX / dim) return 0;
+
+        rv *= dim;
     }

     // Again, prevent overflow
     if (rv > UINT_MAX / 15) return 0;

-    return rv;
+    return (cmsUInt32Number) rv;
 }
