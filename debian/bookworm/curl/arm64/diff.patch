           continue;
 
+      if(data->set.use_ssl >= CURLUSESSL_CONTROL &&
+         !check->bits.tls_upgraded)
+        /* do not reuse a non-TLS STARTTLS connection if TLS is required */
+        continue;
+
 #ifndef CURL_DISABLE_PROXY
