+    CURLU *orig_url;
     uc = curl_url_get(data->state.uh, CURLUPART_URL, &newurl, 0);
     if(uc)
       return Curl_uc_to_curlcode(uc);
 
-    /* Clear auth if this redirects to a different port number or protocol,
-       unless permitted */
-    if(!data->set.allow_auth_to_other_hosts && (type != FOLLOW_FAKE)) {
-      char *portnum;
-      int port;
-      bool clear = FALSE;
-
-      if(data->set.use_port && data->state.allow_port)
-        /* a custom port is used */
-        port = (int)data->set.use_port;
-      else {
-        uc = curl_url_get(data->state.uh, CURLUPART_PORT, &portnum,
-                          CURLU_DEFAULT_PORT);
-        if(uc) {
-          free(newurl);
-          return Curl_uc_to_curlcode(uc);
-        }
-        port = atoi(portnum);
-        free(portnum);
-      }
-      if(port != data->info.conn_remote_port) {
-        infof(data, "Clear auth, redirects to port from %u to %u",
-              data->info.conn_remote_port, port);
-        clear = TRUE;
+    /* Check if this is a same-origin redirect by comparing the original
+       URL's scheme, host and port with the redirect target */
+    orig_url = curl_url();
+    if(orig_url) {
+      uc = curl_url_set(orig_url, CURLUPART_URL, data->state.url,
+                        CURLU_URLENCODE | CURLU_ALLOW_SPACE);
+      if(!uc) {
+        char *orig_scheme = NULL, *orig_host = NULL, *orig_port = NULL;
+        char *redir_scheme = NULL, *redir_host = NULL, *redir_port = NULL;
+        curl_url_get(orig_url, CURLUPART_SCHEME, &orig_scheme, 0);
+        curl_url_get(orig_url, CURLUPART_HOST, &orig_host, 0);
+        curl_url_get(orig_url, CURLUPART_PORT, &orig_port,
+                     CURLU_DEFAULT_PORT);
+        curl_url_get(data->state.uh, CURLUPART_SCHEME, &redir_scheme, 0);
+        curl_url_get(data->state.uh, CURLUPART_HOST, &redir_host, 0);
+        curl_url_get(data->state.uh, CURLUPART_PORT, &redir_port,
+                     CURLU_DEFAULT_PORT);
+        if(orig_scheme && orig_host && orig_port &&
+           redir_scheme && redir_host && redir_port &&
+           strcasecompare(orig_scheme, redir_scheme) &&
+           strcasecompare(orig_host, redir_host) &&
+           strcasecompare(orig_port, redir_port))
+          same_origin = TRUE;
+        free(orig_scheme);
+        free(orig_host);
+        free(orig_port);
+        free(redir_scheme);
+        free(redir_host);
+        free(redir_port);
       }
-      else {
-        char *scheme;
-        const struct Curl_handler *p;
-        uc = curl_url_get(data->state.uh, CURLUPART_SCHEME, &scheme, 0);
-        if(uc) {
-          free(newurl);
-          return Curl_uc_to_curlcode(uc);
-        }
+      curl_url_cleanup(orig_url);
+    }
 
-        p = Curl_builtin_scheme(scheme, CURL_ZERO_TERMINATED);
-        if(p && (p->protocol != data->info.conn_protocol)) {
-          infof(data, "Clear auth, redirects scheme from %s to %s",
