Description: CVE-2025-15649 - Fix _dosToUnixTime to handle zero and invalid datetime values
 The _dosToUnixTime helper in IO::Uncompress::Unzip used to trust the raw
 datetime word from the ZIP central directory. When the datetime field was
 zero (some zip producers leave it unset) or contained values that did not
 expand into a valid calendar date, the value could be mishandled by callers
 listing or extracting the archive (denial of service via a crafted zip file).
 .
 This bookworm backport:
   * returns 0 immediately when $dt is zero;
   * validates the decoded DOS datetime with Time::Local before using
     bookworm's existing POSIX::mktime conversion, so malformed fields are
     rejected instead of being normalized into a different timestamp.
Origin: upstream, https://github.com/pmqs/IO-Compress/commit/fd28c1d2374eee9811f6d0c5bddc0957abdf1da8
Author: Paul Marquess <pmqs@cpan.org>
Last-Update: 2026-06-09

--- a/cpan/IO-Compress/lib/IO/Uncompress/Unzip.pm
+++ b/cpan/IO-Compress/lib/IO/Uncompress/Unzip.pm
@@ -790,6 +790,9 @@ sub filterUncompressed
 sub _dosToUnixTime
 {
 	my $dt = shift;
+
+    # some zip files don't populate the datetime field at all
+    return 0 if ! $dt;
 
 	my $year = ( ( $dt >> 25 ) & 0x7f ) + 80;
 	my $mon  = ( ( $dt >> 21 ) & 0x0f ) - 1;
@@ -799,6 +802,13 @@ sub _dosToUnixTime
 	my $min  = ( ( $dt >> 5 ) & 0x3f );
 	my $sec  = ( ( $dt << 1 ) & 0x3e );
 
+    # mktime normalizes invalid fields, so validate them first.
+    require Time::Local;
+    return 0 if ! eval {
+        Time::Local::timelocal( $sec, $min, $hour, $mday, $mon, $year );
+        1;
+    };
+
     use POSIX 'mktime';
 
     my $time_t = mktime( $sec, $min, $hour, $mday, $mon, $year, 0, 0, -1 );
