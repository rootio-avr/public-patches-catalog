Description: CVE-2026-27135 - Fix missing iframe->state validations to avoid assertion failure
 nghttp2 prior to v1.68.1 has missing internal state validation. After
 nghttp2_session_terminate_session or nghttp2_session_terminate_session2
 is called, the library keeps reading data. Receiving a malformed frame
 that causes FRAME_SIZE_ERROR then triggers an assertion failure, enabling
 remote denial-of-service. This patch adds NGHTTP2_IB_IGN_ALL state checks
 after function calls that may set this state, preventing the assertion.
Origin: upstream, https://github.com/nghttp2/nghttp2/commit/5c7df8fa815ac1004d9ecb9d1f7595c4d37f46e1
Author: nghttp2 developers
Last-Update: 2026-03-31

--- a/lib/nghttp2_session.c
+++ b/lib/nghttp2_session.c
@@ -6085,6 +6085,10 @@ ssize_t nghttp2_session_mem_recv(nghttp2_session *session,
         if (nghttp2_is_fatal(rv)) {
           return rv;
         }
+
+        if (iframe->state == NGHTTP2_IB_IGN_ALL) {
+          return (ssize_t)inlen;
+        }

         on_begin_frame_called = 1;

@@ -6452,6 +6456,10 @@ ssize_t nghttp2_session_mem_recv(nghttp2_session *session,
           if (nghttp2_is_fatal(rv)) {
             return rv;
           }
+
+          if (iframe->state == NGHTTP2_IB_IGN_ALL) {
+            return (ssize_t)inlen;
+          }
         }
       }

@@ -6707,6 +6715,10 @@ ssize_t nghttp2_session_mem_recv(nghttp2_session *session,
         if (nghttp2_is_fatal(rv)) {
           return rv;
         }
+
+        if (iframe->state == NGHTTP2_IB_IGN_ALL) {
+          return (ssize_t)inlen;
+        }

         session_inbound_frame_reset(session);

@@ -7005,6 +7017,10 @@ ssize_t nghttp2_session_mem_recv(nghttp2_session *session,
         if (nghttp2_is_fatal(rv)) {
           return rv;
         }
+
+        if (iframe->state == NGHTTP2_IB_IGN_ALL) {
+          return (ssize_t)inlen;
+        }
       } else {
         iframe->state = NGHTTP2_IB_IGN_HEADER_BLOCK;
       }
@@ -7177,6 +7193,10 @@ ssize_t nghttp2_session_mem_recv(nghttp2_session *session,
             if (nghttp2_is_fatal(rv)) {
               return NGHTTP2_ERR_CALLBACK_FAILURE;
             }
+
+            if (iframe->state == NGHTTP2_IB_IGN_ALL) {
+              return (ssize_t)inlen;
+            }
           }
         }
       }
@@ -7256,6 +7276,10 @@ ssize_t nghttp2_session_mem_recv(nghttp2_session *session,
         if (nghttp2_is_fatal(rv)) {
           return rv;
         }
+
+        if (iframe->state == NGHTTP2_IB_IGN_ALL) {
+          return (ssize_t)inlen;
+        }

         if (rv != 0) {
           busy = 1;
@@ -7274,6 +7298,10 @@ ssize_t nghttp2_session_mem_recv(nghttp2_session *session,
       if (nghttp2_is_fatal(rv)) {
         return rv;
       }
+
+      if (iframe->state == NGHTTP2_IB_IGN_ALL) {
+        return (ssize_t)inlen;
+      }

       session_inbound_frame_reset(session);

@@ -7302,6 +7330,10 @@ ssize_t nghttp2_session_mem_recv(nghttp2_session *session,
       if (nghttp2_is_fatal(rv)) {
         return rv;
       }
+
+      if (iframe->state == NGHTTP2_IB_IGN_ALL) {
+        return (ssize_t)inlen;
+      }

       session_inbound_frame_reset(session);
