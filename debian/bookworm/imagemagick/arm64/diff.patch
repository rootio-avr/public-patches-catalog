-        object[first].merge=MagickFalse;
+        if ((first >= 0) &&
+           (first < (ssize_t) component_image->colors))
+         object[first].merge=MagickFalse;
     }
   artifact=GetImageArtifact(image,"connected-components:keep-top");
   if (artifact != (const char *) NULL)
