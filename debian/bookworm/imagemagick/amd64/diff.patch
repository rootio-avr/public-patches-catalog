Description: CVE-2026-46522 - Fix infinite loop in MIFF decoder
 When length == 0, BZip2, LZMA, and Zlib decompression paths
 could enter an infinite loop. Add explicit checks to abort
 with an error when this condition is detected.
Origin: upstream, https://github.com/ImageMagick/ImageMagick6/commit/466237e1116b46abde8af0f1794b42f1110e04b5
Author: Cristy <urban-warrior@imagemagick.org>
Last-Update: 2026-05-13

--- a/coders/miff.c
+++ b/coders/miff.c
@@ -1477,6 +1477,11 @@
                     ThrowMIFFException(CorruptImageError,
                       "UnableToReadImageData");
                   }
+                if (length == 0)
+                  {
+                    (void) BZ2_bzDecompressEnd(&bzip_info);
+                    ThrowMIFFException(CorruptImageError,"UnexpectedEndOfFile");
+                  }
               }
             code=BZ2_bzDecompress(&bzip_info);
             if ((code != BZ_OK) && (code != BZ_STREAM_END))
@@ -1516,6 +1521,11 @@
                     ThrowMIFFException(CorruptImageError,
                       "UnableToReadImageData");
                   }
+                if (length == 0)
+                  {
+                    lzma_end(&lzma_info);
+                    ThrowMIFFException(CorruptImageError,"UnexpectedEndOfFile");
+                  }
               }
             code=lzma_code(&lzma_info,LZMA_RUN);
             if ((code != LZMA_OK) && (code != LZMA_STREAM_END))
@@ -1558,6 +1568,11 @@
                     ThrowMIFFException(CorruptImageError,
                       "UnableToReadImageData");
                   }
+                if (length == 0)
+                  {
+                    (void) inflateEnd(&zip_info);
+                    ThrowMIFFException(CorruptImageError,"UnexpectedEndOfFile");
+                  }
               }
             code=inflate(&zip_info,Z_SYNC_FLUSH);
             if ((code != Z_OK) && (code != Z_STREAM_END))
