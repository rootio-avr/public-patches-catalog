2.39.5

Description: CVE-2026-34475 - Handle absolute form with empty path
 Varnish Cache before 8.0.1 mishandles absolute-form URIs with an empty
 path (e.g. http://example.com?/foo), potentially leading to cache
 poisoning or authentication bypass. This patch fixes dissection of
 absolute-form URIs by using strpbrk to also detect '?' as a path
 delimiter, and normalizes the URL by prepending '/' when the path
 component is empty or starts with a query string.
Origin: upstream, https://github.com/varnishcache/varnish-cache/commit/f27e9550aa30ad18e5196371d583e7131745088e
Author: Nils Goroll <nils.goroll@uplex.de>
Last-Update: 2026-05-06

--- a/bin/varnishd/http1/cache_http1_proto.c
+++ b/bin/varnishd/http1/cache_http1_proto.c
@@ -355,6 +355,7 @@ HTTP1_DissectRequest(struct http_conn *htc, struct http *hp)
 {
 	uint16_t retval;
 	const char *p;
+	char c = '\0';
 	const char *b = NULL, *e;

 	CHECK_OBJ_NOTNULL(htc, HTTP_CONN_MAGIC);
@@ -375,11 +376,27 @@ HTTP1_DissectRequest(struct http_conn *htc, struct http *hp)
 	    http_scheme_at(hp->hd[HTTP_HDR_URL].b, https))
 		b = hp->hd[HTTP_HDR_URL].b + 8;
 	if (b) {
-		e = strchr(b, '/');
-		if (e) {
-			http_Unset(hp, H_Host);
-			http_PrintfHeader(hp, "Host: %.*s", (int)(e - b), b);
-			hp->hd[HTTP_HDR_URL].b = e;
+		e = strpbrk(b, "/?");
+		if (e == NULL)
+			e = hp->hd[HTTP_HDR_URL].e;
+		else
+			c = *e;
+		if (e == b) {
+			/* rfc9110 4.2.1 4.2.2 reject empty host */
+			return (400);
+		}
+		http_Unset(hp, H_Host);
+		http_PrintfHeader(hp, "Host: %.*s", (int)(e - b), b);
+		hp->hd[HTTP_HDR_URL].b = e;
+		if (Tlen(hp->hd[HTTP_HDR_URL]) == 0) {
+			/* empty path */
+			hp->hd[HTTP_HDR_URL].b = "/";
+			hp->hd[HTTP_HDR_URL].e =
+			    hp->hd[HTTP_HDR_URL].b + 1;
+		} else if (c == '?') {
+			hp->hd[HTTP_HDR_URL].b--;
+			char *t = TRUST_ME(hp->hd[HTTP_HDR_URL].b);
+			*t = '/';
 		}
 	}

From fff49aae4c4b870c9350037234b3b4406d2bb8e5 Mon Sep 17 00:00:00 2001
From: Dridi Boukelmoune <dridi.boukelmoune@gmail.com>
Date: Thu, 16 Nov 2023 14:52:49 +0100
Subject: [PATCH 7/7] http2_proto: Enforce session timeouts in h2_sweep()

The new meaning for h2->sess->t_idle is now the time since the last
complete frame, except before the first frame where it corresponds to
the creation of the session.
---
 bin/varnishd/http2/cache_http2_proto.c | 71 ++++++++++++--------------
 1 file changed, 33 insertions(+), 38 deletions(-)

diff --git a/bin/varnishd/http2/cache_http2_proto.c b/bin/varnishd/http2/cache_http2_proto.c
index 3a3347982..566409fde 100644
--- a/bin/varnishd/http2/cache_http2_proto.c
+++ b/bin/varnishd/http2/cache_http2_proto.c
@@ -1268,33 +1268,38 @@ h2_stream_tmo(struct h2_sess *h2, const struct h2_req *r2, vtim_real now)
 	return (r);
 }
 
-static int
+static h2_error
 h2_stream_tmo_unlocked(struct h2_sess *h2, const struct h2_req *r2)
 {
 	int r;
+	h2_error h2e = NULL;
 
 	Lck_Lock(&h2->sess->mtx);
-	r = h2_stream_tmo(h2, r2, h2->sess->t_idle);
+	if (r2->error != NULL)
+		h2e = r2->error;
+	else {
+		r = h2_stream_tmo(h2, r2, h2->sess->t_idle);
+		if (r != 0)
+			h2e = H2SE_BROKE_WINDOW;
+	}
 	Lck_Unlock(&h2->sess->mtx);
 
-	return (r);
+	return (h2e);
 }
 
 /*
  * This is the janitorial task of cleaning up any closed & refused
  * streams, and checking if the session is timed out.
  */
-static int
+static h2_error
 h2_sweep(struct worker *wrk, struct h2_sess *h2)
 {
-	int tmo = 0;
 	struct h2_req *r2, *r22;
-	h2_error h2e;
+	h2_error h2e = NULL, tmo;
 	vtim_real now;
 
 	ASSERT_RXTHR(h2);
 
-	h2e = h2->error;
 	now = VTIM_real();
 	if (h2e == NULL && h2->open_streams == 0 &&
 	    h2->sess->t_idle + cache_param->timeout_idle < now)
@@ -1323,10 +1328,9 @@ h2_sweep(struct worker *wrk, struct h2_sess *h2)
 			/* FALLTHROUGH */
 		case H2_S_CLOS_LOC:
 		case H2_S_OPEN:
-			if (h2_stream_tmo_unlocked(h2, r2)) {
-				tmo = 1;
-				continue;
-			}
+			tmo = h2_stream_tmo_unlocked(h2, r2);
+			if (h2e == NULL)
+				h2e = tmo;
 			break;
 		case H2_S_IDLE:
 			/* Current code make this unreachable: h2_new_req is
@@ -1338,9 +1342,7 @@ h2_sweep(struct worker *wrk, struct h2_sess *h2)
 			break;
 		}
 	}
-	if (tmo)
-		return (0);
-	return (h2->refcnt > 1);
+	return (h2e);
 }
 
 
@@ -1365,41 +1367,33 @@ h2_rxframe(struct worker *wrk, struct h2_sess *h2)
 	enum htc_status_e hs;
 	h2_frame h2f;
 	h2_error h2e;
-	const char *s = NULL;
-	char b[8];
 
 	ASSERT_RXTHR(h2);
 	VTCP_blocking(*h2->htc->rfd);
-	h2->sess->t_idle = VTIM_real();
-	hs = HTC_RxStuff(h2->htc, h2_frame_complete,
-	    NULL, NULL, NAN,
-	    h2->sess->t_idle + SESS_TMO(h2->sess, timeout_idle),
-	    NAN, h2->local_settings.max_frame_size + 9);
+	hs = HTC_RxStuff(h2->htc, h2_frame_complete, NULL, NULL, NAN,
+	    VTIM_real() + 0.5, NAN, h2->local_settings.max_frame_size + 9);
+
+	h2e = NULL;
 	switch (hs) {
 	case HTC_S_COMPLETE:
+		h2->sess->t_idle = VTIM_real();
+		if (h2->do_sweep)
+			h2e = h2_sweep(wrk, h2);
 		break;
 	case HTC_S_TIMEOUT:
-		if (h2_sweep(wrk, h2))
-			return (1);
-
-		/* FALLTHROUGH */
+		h2e = h2_sweep(wrk, h2);
+		break;
 	default:
-		/* XXX: HTC_S_OVERFLOW / FRAME_SIZE_ERROR handling */
-#define HTC_STATUS(e, n, d, l)			\
-		do {				\
-			if (hs == HTC_S_ ## e)	\
-				s = #e;		\
-		} while (0);
-#include "tbl/htc.h"
-		Lck_Lock(&h2->sess->mtx);
-		VSLb(h2->vsl, SLT_Debug, "H2: No frame (hs=%s)", s);
-		h2->error = H2CE_NO_ERROR;
-		Lck_Unlock(&h2->sess->mtx);
+		h2e = H2CE_ENHANCE_YOUR_CALM;
+	}
+
+	if (h2e != NULL && h2e->connection) {
+		h2->error = h2e;
 		return (0);
 	}
 
-	if (h2->do_sweep)
-		(void)h2_sweep(wrk, h2);
+	if (hs != HTC_S_COMPLETE)
+		return (1);
 
 	h2->rxf_len = vbe32dec(h2->htc->rxbuf_b) >> 8;
 	h2->rxf_type = h2->htc->rxbuf_b[3];
@@ -1445,6 +1439,7 @@ h2_rxframe(struct worker *wrk, struct h2_sess *h2)
 
 	h2e = h2_procframe(wrk, h2, h2f);
 	if (h2->error == 0 && h2e) {
+		char b[8];
 		h2->error = h2e;
 		vbe32enc(b, h2->highest_stream);
 		vbe32enc(b + 4, h2e->val);

diff --git a/bin/varnishd/http2/cache_http2.h b/bin/varnishd/http2/cache_http2.h
