+++ b/bin/varnishtest/tests/r03996.vtc
@@ -0,0 +1,39 @@
+varnishtest "h2: Test h2_rapid_reset_limit"
+
+server s1 {
+	rxreq
+	txresp
+} -start
+
+varnish v1 -cliok "param.set feature +http2"
+varnish v1 -cliok "param.set h2_rapid_reset_limit 3"
