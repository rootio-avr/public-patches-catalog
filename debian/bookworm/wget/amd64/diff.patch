Description: CVE-2021-31879 - Prevent credential leakage on cross-origin redirects
 GNU Wget does not omit the Authorization header upon a redirect to a different
 origin, allowing remote servers to obtain sensitive credentials. This patch
 adds filtering for Authorization and Cookie headers during HTTP redirects.
 The unredirectable_headerline() function checks if a header line contains
 Authorization or Cookie headers which should not be propagated on redirects.
Origin: vendor, https://build.opensuse.org/package/show/openSUSE:Factory/wget
Author: SUSE Security Team
Last-Update: 2025-12-24

--- a/src/http.c
+++ b/src/http.c
@@ -3152,6 +3152,33 @@ fail:
 }
 #endif /* HAVE_METALINK */

+/*
+ * Check if the corresponding header line should not
+ * be sent after a redirect
+ */
+static inline int
+unredirectable_headerline(char *line)
+{
+    static struct {
+        size_t len;
+        char *name;
+    } field_name[] = {
+        { 14, "Authorization:" },
+        { 7, "Cookie:" },
+        { 0, NULL }
+    };
+    int i;
+
+    /*
+     * Note: According to RFC 2616, Field names are case-insensitive.
+     */
+    for (i = 0; field_name[i].name != NULL; i++)
+        if (strncasecmp(line, field_name[i].name, field_name[i].len) == 0)
+            return 1;
+
+    return 0;
+}
+
