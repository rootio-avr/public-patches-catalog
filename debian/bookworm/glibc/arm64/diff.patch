Description: CVE-2026-0915 - Fix stack contents leak in getnetbyaddr
 The getnetbyaddr or getnetbyaddr_r functions in glibc version 2.0 through
 2.42 leak stack contents to a configured DNS resolver when nsswitch.conf
 is configured to use the DNS backend for network queries. Specifically,
 querying for zero-valued networks can expose uninitialized stack memory.
 .
 The solution is to provide a default query for the case where net is zero.
Origin: upstream, commit:453e6b8dbab935257eb0802b0c97bca6b67ba30e
Bug: https://sourceware.org/bugzilla/show_bug.cgi?id=33802
Author: Carlos O'Donell <carlos@redhat.com>
Last-Update: 2026-01-17
---

--- a/resolv/nss_dns/dns-network.c
+++ b/resolv/nss_dns/dns-network.c
@@ -207,6 +207,10 @@
       sprintf (qbuf, "%u.%u.%u.%u.in-addr.arpa", net_bytes[3], net_bytes[2],
 	       net_bytes[1], net_bytes[0]);
       break;
+    default:
+      /* Default network (net is originally zero).  */
+      strcpy (qbuf, "0.0.0.0.in-addr.arpa");
+      break;
     }

   net_buffer.buf = orig_net_buffer = (querybuf *) alloca (1024);
--- a/resolv/tst-resolv-network.c
+++ b/resolv/tst-resolv-network.c
@@ -46,6 +46,9 @@
 {
   switch (code)
     {
+    case 0:
+      send_ptr (b, qname, qclass, qtype, "0.in-addr.arpa");
+      break;
     case 1:
       send_ptr (b, qname, qclass, qtype, "1.in-addr.arpa");
       break;
@@ -265,6 +268,9 @@
                 "error: TRY_AGAIN\n");

   /* Lookup by address, success cases.  */
+  check_reverse (0,
+                 "name: 0.in-addr.arpa\n"
+                 "net: 0x00000000\n");
   check_reverse (1,
