new file mode 100644
index 00000000..edc19de2
--- /dev/null
+++ b/resolv/tst-resolv-byaddr-invalid.c
@@ -0,0 +1,145 @@
+/* Test that gethostbyaddr rejects invalid PTR record hostnames (CVE-2026-4438).
+   Copyright (C) 2026 Free Software Foundation, Inc.
+   This file is part of the GNU C Library.
+
+   The GNU C Library is free software; you can redistribute it and/or
+   modify it under the terms of the GNU Lesser General Public
+   License as published by the Free Software Foundation; either
+   version 2.1 of the License, or (at your option) any later version.
+
+   The GNU C Library is distributed in the hope that it will be useful,
+   but WITHOUT ANY WARRANTY; without even the implied warranty of
+   MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE.  See the GNU
+   Lesser General Public License for more details.
+
+   You should have received a copy of the GNU Lesser General Public
+   License along with the GNU C Library; if not, see
+   <https://www.gnu.org/licenses/>.  */
+
+/* Regression test for CVE-2026-4438.  The getanswer_ptr function was
+   checking __res_binary_hnok on expected_name (the compressed query
+   name) instead of name_buffer (the unpacked PTR record target).
+   Because expected_name is always a valid reverse-lookup name like
+   "1.2.0.192.in-addr.arpa", the check always passed, allowing
+   syntactically invalid hostnames (e.g. those containing shell
+   metacharacters or starting with '-') to be returned to the caller.
+
+   This test verifies that a PTR response carrying an invalid hostname
+   is rejected with NO_RECOVERY rather than returned to the caller.  */
+
+#include <arpa/inet.h>
+#include <netdb.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <support/check.h>
+#include <support/check_nss.h>
+#include <support/resolv_test.h>
+#include <support/support.h>
+
+/* Each test case is identified by the last octet of the 192.0.2.0/24
+   address being looked up.  The response callback maps the octet to
+   the PTR hostname that the mock DNS server should return.  */
+struct test_case
+{
+  /* Last octet of the IPv4 address to look up.  */
+  int octet;
+  /* Hostname the mock DNS server returns in the PTR record.  */
+  const char *ptr_target;
+  /* Expected output from check_hostent.  */
+  const char *expected;
+};
+
+static const struct test_case tests[] =
+{
+  /* Sanity check: a valid PTR hostname is returned successfully.  */
+  { 1, "valid.example.com",
+    "name: valid.example.com\naddress: 192.0.2.1\n" },
+
+  /* PTR target starts with '-': rejected by __res_binary_hnok because
+     binary_leading_dash() returns true.  */
+  { 2, "-invalid.example.com",
+    "error: NO_RECOVERY\n" },
+
+  /* PTR target contains '*': not in [0-9A-Za-z_-], rejected by
+     binary_hnok().  */
+  { 3, "*.example.com",
+    "error: NO_RECOVERY\n" },
+
+  /* PTR target contains '$': shell metacharacter, also not in the
+     accepted set.  */
+  { 4, "bad$host.example.com",
+    "error: NO_RECOVERY\n" },
+};
+
+/* Number of test cases.  */
+#define NTESTS (sizeof (tests) / sizeof (tests[0]))
+
+static void
+response (const struct resolv_response_context *ctx,
+          struct resolv_response_builder *b,
+          const char *qname, uint16_t qclass, uint16_t qtype)
+{
+  TEST_COMPARE (qclass, C_IN);
+  TEST_COMPARE (qtype, T_PTR);
+
+  /* Parse the last octet from the QNAME "N.2.0.192.in-addr.arpa".  */
+  unsigned int octet;
+  char *tail;
+  if (sscanf (qname, "%u.%ms", &octet, &tail) != 2)
+    FAIL_EXIT1 ("unexpected QNAME: %s", qname);
+  TEST_COMPARE_STRING (tail, "2.0.192.in-addr.arpa");
+  free (tail);
+
+  /* Find the matching test case.  */
+  const char *ptr_target = NULL;
+  for (size_t i = 0; i < NTESTS; ++i)
+    if ((unsigned int) tests[i].octet == octet)
+      {
+        ptr_target = tests[i].ptr_target;
+        break;
+      }
+  if (ptr_target == NULL)
+    FAIL_EXIT1 ("no test case for octet %u (qname: %s)", octet, qname);
+
+  struct resolv_response_flags flags = {};
+  resolv_response_init (b, flags);
+  resolv_response_add_question (b, qname, qclass, qtype);
+  resolv_response_section (b, ns_s_an);
+  resolv_response_open_record (b, qname, qclass, T_PTR, 60);
+  resolv_response_add_name (b, ptr_target);
+  resolv_response_close_record (b);
+}
+
+/* Perform a gethostbyaddr lookup for 192.0.2.OCTET and check that the
+   result matches EXPECTED.  */
+static void
+check (int octet, const char *expected)
+{
+  char address[16];
+  snprintf (address, sizeof (address), "192.0.2.%d", octet);
+
+  unsigned char bytes[4];
+  TEST_COMPARE (inet_pton (AF_INET, address, bytes), 1);
+
+  struct hostent *e = gethostbyaddr (bytes, 4, AF_INET);
+  check_hostent (address, e, expected);
+}
+
+static int
+do_test (void)
+{
+  struct resolv_test *obj = resolv_test_start
+    ((struct resolv_redirect_config)
+     {
+       .response_callback = response
+     });
+
+  for (size_t i = 0; i < NTESTS; ++i)
+    check (tests[i].octet, tests[i].expected);
+
+  resolv_test_end (obj);
+  return 0;
+}
+
+#include <support/test-driver.c>
