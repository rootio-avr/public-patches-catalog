+static int
+do_test (void)
+{
+  int fd = memfd_create ("test", MFD_CLOEXEC);
+  TEST_VERIFY (fd != -1);
+  TEST_COMPARE (write (fd, (unsigned char[]){ 'A', 0, 0, 0 }, 4), 4);
+  TEST_COMPARE (lseek (fd, 0, SEEK_SET), 0);
