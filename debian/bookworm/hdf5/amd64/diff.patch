From 7619d1cdc4c2f96e8ac79dd01f7e5cfc70e35299 Mon Sep 17 00:00:00 2001
Date: Tue, 16 Sep 2025 14:30:23 +0530
Subject: [PATCH] Backport CVE-2024-32605 fix to HDF5 1.10.8

- Add buffer size validation for compact datasets in H5D__open_oid()
- Prevents heap-based buffer over-read in H5VM_memcpyvv when called from H5D__compact_readvv
- Validates that compact dataset buffer size matches expected data size
- Updated RELEASE.txt with CVE fix documentation

This addresses CVE-2024-32605: HDF5 Library through 1.14.3 has a heap-based buffer over-read
in H5VM_memcpyvv in H5VM.c (called from H5D__compact_readvv in H5Dcompact.c).

Backported from HDF5 1.14.4 (commit 4dfa4443a1)
---
 release_docs/RELEASE.txt | 16 ++++++++++++++++
 src/H5Dint.c             | 27 +++++++++++++++++++++++++++
 2 files changed, 43 insertions(+)

diff --git a/release_docs/RELEASE.txt b/release_docs/RELEASE.txt
index 1f69197827..3632be2a52 100644
--- a/release_docs/RELEASE.txt
+++ b/release_docs/RELEASE.txt
@@ -479,6 +479,22 @@ Bug Fixes since HDF5-1.10.7 release
 
         (BMR - 2021/10/21, HDFFV-10590)
 
+    - Fixed CVE-2024-32605
+
+        HDF5 Library through 1.14.3 has a heap-based buffer over-read in
+        H5VM_memcpyvv in H5VM.c (called from H5D__compact_readvv in H5Dcompact.c).
+
+        The vulnerability occurs when a malformed HDF5 file contains a compact
+        dataset with corrupted object header information that specifies a buffer
+        size that doesn't match the actual data size. This can lead to heap-based
+        buffer over-read, potentially causing denial of service or code execution.
+
+        The fix adds validation to ensure that the size of the internal buffer
+        allocated for compact dataset's raw data matches the expected size
+        calculated from the dataset's dataspace and datatype information.
+
+        (Backported from HDF5 1.14.4 - 2024/12/19)
+
     - Fixed a segmentation fault
 
         A segmentation fault occurred with a corrupted file.
diff --git a/src/H5Dint.c b/src/H5Dint.c
index caed38a5da..796a2d6cac 100644
--- a/src/H5Dint.c
+++ b/src/H5Dint.c
@@ -1710,6 +1710,33 @@ H5D__open_oid(H5D_t *dataset, hid_t dapl_id)
     /* Indicate that the layout information was initialized */
     layout_init = TRUE;
 
+    /*
+     * Now that we've read the dataset's datatype, dataspace and
+     * layout information, perform a quick check for compact datasets
+     * to ensure that the size of the internal buffer that was
+     * allocated for the dataset's raw data matches the size of
+     * the data. A corrupted file can cause a mismatch between the
+     * two, which might result in buffer overflows during future
+     * I/O to the dataset.
+     */
+    if (H5D_COMPACT == dataset->shared->layout.type) {
+        hssize_t dset_nelemts   = 0;
+        size_t   dset_type_size = H5T_GET_SIZE(dataset->shared->type);
+        size_t   dset_data_size = 0;
+
+        HDassert(H5D_COMPACT == dataset->shared->layout.storage.type);
+
+        if ((dset_nelemts = H5S_GET_EXTENT_NPOINTS(dataset->shared->space)) < 0)
+            HGOTO_ERROR(H5E_DATASET, H5E_CANTGET, FAIL, "can't get number of elements in dataset's dataspace")
+
+        dset_data_size = (size_t)dset_nelemts * dset_type_size;
+
+        if (dataset->shared->layout.storage.u.compact.size != dset_data_size)
+            HGOTO_ERROR(H5E_DATASET, H5E_BADVALUE, FAIL,
+                        "bad value from dataset header - size of compact dataset's data buffer doesn't match "
+                        "size of dataset data");
+    }
+
     /* Set up flush append property */
     if (H5D__append_flush_setup(dataset, dapl_id))
         HGOTO_ERROR(H5E_DATASET, H5E_CANTSET, FAIL, "unable to set up flush append property")
