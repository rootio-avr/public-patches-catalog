2.43.0

Description: Backport fix for CVE-2025-7069 from upstream PR #5722
 A heap-based buffer overflow exists in H5FS__sect_link_size at
 src/H5FSsection.c due to a corrupted file providing an invalid
 page_size value (zero or excessively large). This patch adds a
 sanity check on page_size immediately after decoding the file space
 info message, and zero-initializes the fsinfo struct to ensure a
 clean state before reading.
Origin: backport, https://github.com/HDFGroup/hdf5/commit/54f404b5ad8e63d99e3283646b543b2842a22fd3
Bug: https://github.com/HDFGroup/hdf5/issues/5550
Last-Update: 2026-03-24

--- a/src/H5Ofsinfo.c
+++ b/src/H5Ofsinfo.c
@@ -164,6 +164,9 @@
         H5F_DECODE_LENGTH(f, p, fsinfo->threshold);     /* Free-space section threshold */
 
         H5F_DECODE_LENGTH(f, p, fsinfo->page_size); /* File space page size */
+        /* Basic sanity check */
+        if (fsinfo->page_size == 0 || fsinfo->page_size > H5F_FILE_SPACE_PAGE_SIZE_MAX)
+            HGOTO_ERROR(H5E_OHDR, H5E_BADVALUE, NULL, "invalid page size in file space info")
         UINT16DECODE(p, fsinfo->pgend_meta_thres);  /* Page end metdata threshold */
         H5F_addr_decode(f, &p,
                         &(fsinfo->eoa_pre_fsm_fsalloc)); /* EOA before free-space header and section info */
--- a/src/H5Fsuper.c
+++ b/src/H5Fsuper.c
@@ -779,6 +779,8 @@
             if (!(flags & H5O_MSG_FLAG_WAS_UNKNOWN)) {
                 H5O_fsinfo_t fsinfo;                /* File space info message from superblock extension */
                 hbool_t      null_fsm_addr = FALSE; /* Whether to drop free-space to the floor */
+
