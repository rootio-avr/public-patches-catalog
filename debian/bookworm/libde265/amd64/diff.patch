Description: CVE-2026-33165 - Fix out-of-bounds heap write when Log2CtbSizeY changes between SPS updates
 Ensure CTU metadata reallocation on ctb_info.log2unitSize mismatch.
 A crafted HEVC bitstream can trigger an out-of-bounds heap write when an
 SPS change alters Log2CtbSizeY while picture dimensions in CTU units
 remain constant. The stale metadata (ctb_info.log2unitSize) is then used
 in set_SliceHeaderIndex to calculate an array index, writing past the
 allocated heap buffer. The fix adds a check for log2unitSize mismatch
 to the reallocation condition and changes the field type to uint8_t.
Origin: upstream, https://github.com/strukturag/libde265/commit/c7891e412106130b83f8e8ea8b7f907e9449b658
Author: Dirk Farin <dirk.farin@gmail.com>
Bug: https://github.com/strukturag/libde265/security/advisories/GHSA-653q-9f73-8hvg
Last-Update: 2026-07-15

--- a/libde265/image.cc
+++ b/libde265/image.cc
@@ -445,8 +445,9 @@

     // CTB info

-    if (ctb_info.width_in_units != sps->PicWidthInCtbsY ||
-        ctb_info.height_in_units != sps->PicHeightInCtbsY)
+    if (ctb_info.width_in_units  != sps->PicWidthInCtbsY  ||
+        ctb_info.height_in_units != sps->PicHeightInCtbsY ||
+        ctb_info.log2unitSize    != sps->Log2CtbSizeY)
       {
         delete[] ctb_progress;

--- a/libde265/image.h
+++ b/libde265/image.h
@@ -149,7 +149,7 @@
   // private:
   DataUnit* data;
   int data_size;
-  int log2unitSize;
+  uint8_t log2unitSize;
   int width_in_units;
   int height_in_units;
 };
From 221e767136b8c46c748ae35b79ec9b976b3da301 Mon Sep 17 00:00:00 2001
From: Dirk Farin <dirk.farin@gmail.com>
Date: Sat, 4 Nov 2023 15:13:36 +0100
Subject: [PATCH] check validity of conformance window parameters (fixes #427)

---
 libde265/image.cc | 8 ++++++++
 1 file changed, 8 insertions(+)

diff --git a/libde265/image.cc b/libde265/image.cc
index c28c5771..4876b05b 100644
--- a/libde265/image.cc
+++ b/libde265/image.cc
@@ -330,6 +330,14 @@ de265_error de265_image::alloc_image(int w,int h, enum de265_chroma c,
   int top    = sps ? sps->conf_win_top_offset : 0;
   int bottom = sps ? sps->conf_win_bottom_offset : 0;
 
+  if ((left+right)*WinUnitX >= width) {
+    return DE265_ERROR_CODED_PARAMETER_OUT_OF_RANGE;
+  }
+
+  if ((top+bottom)*WinUnitX >= height) {
+    return DE265_ERROR_CODED_PARAMETER_OUT_OF_RANGE;
+  }
+
   width_confwin = width - (left+right)*WinUnitX;
   height_confwin= height- (top+bottom)*WinUnitY;
   chroma_width_confwin = chroma_width -left-right;
Description: CVE-2026-49295 - bound aggregate short-term RPS size
 libde265 (H.265 video codec) has an out-of-bounds array write in
 decoder_context::process_reference_picture_set() at libde265/decctx.cc:1376.
 A crafted H.265 bitstream can trigger the OOB write because, while individual
 short-term reference-picture-set list sizes are validated, the combined count
 after predicted RPS construction can exceed the 16-entry PocStFoll array
 (write at index 16). Reject such sets after compute_derived_values() by
 checking NumDeltaPocs against MAX_NUM_REF_PICS and emitting the existing
 DE265_WARNING_MAX_NUM_REF_PICS_EXCEEDED warning.
 .
 Fixes GHSA-g2rg-wj66-w594 (CVE-2026-49295). Upstream-fixed in 1.0.20 / 1.1.x.
Origin: upstream, https://github.com/strukturag/libde265/commit/691f3a3c55b3d32478c4a49895dee061a282652b
Bug: https://github.com/strukturag/libde265/security/advisories/GHSA-g2rg-wj66-w594
Bug-Debian: https://bugs.debian.org/1140431
Author: Dirk Farin <dirk.farin@gmail.com>
Last-Update: 2026-07-08
---
--- a/libde265/refpic.cc
+++ b/libde265/refpic.cc
@@ -318,6 +318,22 @@ bool read_short_term_ref_pic_set(error_

   out_set->compute_derived_values();

+  // The unused short-term references are all collected into a single PocStFoll array
+  // of MAX_NUM_REF_PICS entries (see decoder_context::process_reference_picture_set).
+  // While each individual list is bounded above, the predicted-RPS construction can
+  // append the current-picture delta to an already-full source set, pushing the
+  // combined count past MAX_NUM_REF_PICS. Reject such sets to avoid an out-of-bounds
+  // write when filling PocStFoll.
+  if (out_set->NumDeltaPocs > MAX_NUM_REF_PICS) {
+    out_set->NumNegativePics = 0;
+    out_set->NumPositivePics = 0;
+    out_set->NumDeltaPocs = 0;
+    out_set->NumPocTotalCurr_shortterm_only = 0;
+
+    errqueue->add_warning(DE265_WARNING_MAX_NUM_REF_PICS_EXCEEDED, false);
+    return false;
+  }
+
   return true;
 }
Description: CVE-2026-49346 - Fix integer overflow in image plane allocation size
 The 32-bit int multiplications of stride*height in de265_alloc_image_plane()
 and luma_height*luma_bpl / chroma_height*chroma_bpl in de265_image_get_buffer()
 can wrap for large frames, producing an undersized allocation while
 fill_image() later writes the full size_t size, leading to a heap buffer
 overflow.
 .
 Widen the stride/height/bpl locals to uint32_t and cast one operand to size_t
 before multiplication so the size computation is performed in 64 bits.
 .
 Adapted from upstream commit 8a1b5cf to preserve bookworm's C-style casts and
 NULL usage (upstream simultaneously modernised to static_cast/nullptr; that
 cosmetic change is intentionally not backported).
 .
 GHSA-vv8h-932h-7r86
Origin: backport, https://github.com/strukturag/libde265/commit/8a1b5cf212f78e1c77cb46eb5d56e492a9336eb8
Bug: https://github.com/strukturag/libde265/security/advisories/GHSA-vv8h-932h-7r86
Bug-Debian: https://bugs.debian.org/1140431
Author: Dirk Farin <dirk.farin@gmail.com>
Last-Update: 2026-07-08
---
--- a/libde265/image.cc
+++ b/libde265/image.cc
@@ -71,10 +71,11 @@
                                            void* inputdata, int inputstride, void *userdata)
 {
   int alignment = STANDARD_ALIGNMENT;
-  int stride = (img->get_width(cIdx) + alignment-1) / alignment * alignment;
-  int height = img->get_height(cIdx);
+  uint32_t stride = (img->get_width(cIdx) + alignment-1) / alignment * alignment;
+  uint32_t height = img->get_height(cIdx);
 
-  uint8_t* p = (uint8_t *)ALLOC_ALIGNED_16(stride * height + MEMORY_PADDING);
+  // size computed in size_t: stride*height can exceed UINT32_MAX for large planes
+  uint8_t* p = (uint8_t *)ALLOC_ALIGNED_16((size_t)stride * height + MEMORY_PADDING);
 
   if (p==NULL) { return NULL; }
 
@@ -83,12 +84,14 @@
   // copy input data if provided
 
   if (inputdata != NULL) {
-    if (inputstride == stride) {
-      memcpy(p, inputdata, stride*height);
+    if (inputstride == (int)stride) {
+      memcpy(p, inputdata, (size_t)stride * height);
     }
     else {
-      for (int y=0;y<height;y++) {
-        memcpy(p+y*stride, ((char*)inputdata) + inputstride*y, inputstride);
+      for (uint32_t y=0;y<height;y++) {
+        memcpy(p + (size_t)y * stride,
+               ((char*)inputdata) + (size_t)inputstride * y,
+               inputstride);
       }
     }
   }
@@ -108,30 +111,35 @@
 static int  de265_image_get_buffer(de265_decoder_context* ctx,
                                    de265_image_spec* spec, de265_image* img, void* userdata)
 {
-  const int rawChromaWidth  = spec->width  / img->SubWidthC;
-  const int rawChromaHeight = spec->height / img->SubHeightC;
+  const uint32_t rawChromaWidth  = spec->width  / img->SubWidthC;
+  const uint32_t rawChromaHeight = spec->height / img->SubHeightC;
 
-  int luma_stride   = (spec->width    + spec->alignment-1) / spec->alignment * spec->alignment;
-  int chroma_stride = (rawChromaWidth + spec->alignment-1) / spec->alignment * spec->alignment;
+  uint32_t luma_stride   = (spec->width    + spec->alignment-1) / spec->alignment * spec->alignment;
+  uint32_t chroma_stride = (rawChromaWidth + spec->alignment-1) / spec->alignment * spec->alignment;
 
   assert(img->BitDepth_Y >= 8 && img->BitDepth_Y <= 16);
   assert(img->BitDepth_C >= 8 && img->BitDepth_C <= 16);
 
-  int luma_bpl   = luma_stride   * ((img->BitDepth_Y+7)/8);
-  int chroma_bpl = chroma_stride * ((img->BitDepth_C+7)/8);
+  uint32_t luma_bpl   = luma_stride   * ((img->BitDepth_Y+7)/8);
+  uint32_t chroma_bpl = chroma_stride * ((img->BitDepth_C+7)/8);
 
-  int luma_height   = spec->height;
-  int chroma_height = rawChromaHeight;
+  uint32_t luma_height   = spec->height;
+  uint32_t chroma_height = rawChromaHeight;
 
   bool alloc_failed = false;
 
+  // Compute the plane sizes in size_t. Each operand fits in uint32_t, but the
+  // height * bytes-per-line product can exceed UINT32_MAX for large frames, so
+  // the multiplication must be done in 64 bits. Computing it in 32 bits wraps
+  // the allocation size to a small value while fill_image() later writes the
+  // real (size_t) size -> heap buffer overflow (GHSA-vv8h-932h-7r86).
   uint8_t* p[3] = { 0,0,0 };
-  p[0] = (uint8_t *)ALLOC_ALIGNED_16(luma_height   * luma_bpl   + MEMORY_PADDING);
+  p[0] = (uint8_t *)ALLOC_ALIGNED_16((size_t)luma_height * luma_bpl + MEMORY_PADDING);
   if (p[0]==NULL) { alloc_failed=true; }
 
   if (img->get_chroma_format() != de265_chroma_mono) {
-    p[1] = (uint8_t *)ALLOC_ALIGNED_16(chroma_height * chroma_bpl + MEMORY_PADDING);
-    p[2] = (uint8_t *)ALLOC_ALIGNED_16(chroma_height * chroma_bpl + MEMORY_PADDING);
+    p[1] = (uint8_t *)ALLOC_ALIGNED_16((size_t)chroma_height * chroma_bpl + MEMORY_PADDING);
+    p[2] = (uint8_t *)ALLOC_ALIGNED_16((size_t)chroma_height * chroma_bpl + MEMORY_PADDING);
 
     if (p[1]==NULL || p[2]==NULL) { alloc_failed=true; }
   }
Description: Fix CVE-2026-49337 unbounded memory leak via orphaned slice headers
 A crafted sequence of H.265 NAL units can cause slice headers to be
 attached to a picture object with no active image unit, so the retained
 headers are never freed. Only hand the slice header to the picture when
 an active image unit will decode the slice; otherwise free the header
 (and the NAL) so a stream of non-first slice NALs cannot grow memory
 without bound.
 .
 Backported from upstream v1.0.20. The upstream commit also drops an
 entry_point_offset bounds-check block, but that block never landed in
 the 1.0.11 source, so only the three CVE-related edits are applied here.
Origin: upstream, https://github.com/strukturag/libde265/commit/683cb9fa603e35840642f98765ab95cdb71cadf9
Author: Dirk Farin <dirk.farin@gmail.com>
Bug: https://github.com/strukturag/libde265/security/advisories/GHSA-g5hj-rf9f-7vxm
Bug-Debian: https://bugs.debian.org/1140431
Last-Update: 2026-07-08

---
--- a/libde265/decctx.cc
+++ b/libde265/decctx.cc
@@ -653,8 +653,6 @@
       return err;
     }

-  this->img->add_slice_segment_header(shdr);
-
   skip_bits(&reader,1); // TODO: why?
   prepare_for_CABAC(&reader);

@@ -682,6 +680,13 @@

   if ( ! image_units.empty() ) {

+    // Hand the slice header to the picture (which takes ownership and frees it
+    // on release). Only do this when there is an active image unit to decode
+    // the slice; otherwise the header would be retained on img->slices forever,
+    // which a crafted stream of non-first slice NALs can exploit to grow memory
+    // without bound.
+    this->img->add_slice_segment_header(shdr);
+
     slice_unit* sliceunit = new slice_unit(this);
     sliceunit->nal = nal;
     sliceunit->shdr = shdr;
@@ -691,6 +696,10 @@


     image_units.back()->slice_units.push_back(sliceunit);
+  }
+  else {
+    nal_parser.free_NAL_unit(nal);
+    delete shdr;
   }

   bool did_work;
Description: CVE-2025-61147 - Fix segmentation fault in decoder_context::compute_framedrop_table()
 Replace unsafe atoi() calls with validated parse_param() function that
 checks for invalid input, out-of-range values, and enforces bounds on
 integer command line parameters. This prevents segmentation faults caused
 by malformed command line arguments.
 Adapted for C++11 compatibility by replacing std::optional with sentinel
 values (-1 means no bound).
Origin: upstream, https://github.com/strukturag/libde265/commit/8b17e0930f77db07f55e0b89399a8f054ddbecf7
Author: Dirk Farin <dirk.farin@gmail.com>
Last-Update: 2026-03-31

--- a/dec265/dec265.cc
+++ b/dec265/dec265.cc
@@ -27,6 +27,9 @@
 #define DO_MEMORY_LOGGING 0
 
 #include "de265.h"
+#include <stdexcept>
+#include <iostream>
+
 #ifdef HAVE_CONFIG_H
 #include "config.h"
 #endif
@@ -558,6 +561,40 @@
 #endif
 
 
+int parse_param(const char* arg, int lower_bound, int upper_bound, const char* arg_name)
+{
+  int value;
+
+  try {
+    size_t len;
+    value = std::stoi(arg, &len);
+    if (arg[len] != 0) {
+      std::cerr << "invalid argument to " << arg_name << "\n";
+      exit(5);
+    }
+  } catch (std::invalid_argument const& ex) {
+    std::cerr << "invalid argument to " << arg_name << "\n";
+    exit(5);
+  }
+  catch (std::out_of_range const& ex) {
+    std::cerr << "argument to " << arg_name << " is out of range\n";
+    exit(5);
+  }
+
+  if (lower_bound != -1 && value < lower_bound) {
+    std::cerr << "argument to " << arg_name << " may not be smaller than " << lower_bound << "\n";
+    exit(5);
+  }
+
+  if (upper_bound != -1 && value > upper_bound) {
+    std::cerr << "argument to " << arg_name << " may not be larger than " << upper_bound << "\n";
+    exit(5);
+  }
+
+  return value;
+}
+
+
 int main(int argc, char** argv)
 {
   while (1) {
@@ -573,9 +608,9 @@
 
     switch (c) {
     case 'q': quiet++; break;
-    case 't': nThreads=atoi(optarg); break;
+    case 't': nThreads=parse_param(optarg, 0, -1, "-t"); break;
     case 'c': check_hash=true; break;
-    case 'f': max_frames=atoi(optarg); break;
+    case 'f': max_frames=parse_param(optarg, 1, -1, "-f"); break;
     case 'o': write_yuv=true; output_filename=optarg; break;
     case 'h': show_help=true; break;
     case 'd': dump_headers=true; break;
@@ -587,7 +622,7 @@
     case 'm': measure_quality=true; reference_filename=optarg; break;
     case 's': show_ssim_map=true; break;
     case 'e': show_psnr_map=true; break;
-    case 'T': highestTID=atoi(optarg); break;
+    case 'T': highestTID=parse_param(optarg, 0, -1, "-T"); break;
     case 'v': verbosity++; break;
     }
   }
Description: CVE-2024-38949 - Fix SDL OOB on 4:4:4 streams and mid-stream resolution change
 Heap buffer overflow in display444as420 function when processing crafted
 HEVC bitstream input that changes resolution or chroma format mid-stream.
 The SDL display was only initialized once but never re-initialized when the
 stream parameters changed, causing out-of-bounds writes to the overlay buffer.
 .
 This patch moves chroma format detection outside the initialization-only block
 and adds re-initialization logic when resolution or chroma format changes,
 adapted for SDL 1.2 API (close + re-init instead of SDL2 resize).
Origin: upstream, https://github.com/strukturag/libde265/commit/4089de0845e0009e019be4ca5cbebaf2aee0a8ce
Author: Dirk Farin <dirk.farin@gmail.com>
Last-Update: 2026-07-15

--- a/dec265/dec265.cc
+++ b/dec265/dec265.cc
@@ -250,6 +250,8 @@
 #if HAVE_SDL
 SDL_YUV_Display sdlWin;
 bool sdl_active=false;
+int sdl_display_width=0, sdl_display_height=0;
+SDL_YUV_Display::SDL_Chroma sdl_display_chroma=SDL_YUV_Display::SDL_CHROMA_420;
 
 bool display_sdl(const struct de265_image* img)
 {
@@ -261,17 +263,33 @@ bool display_sdl(const struct de265_image* img)
 
   de265_chroma chroma = de265_get_chroma_format(img);
 
+  enum SDL_YUV_Display::SDL_Chroma sdlChroma;
+  switch (chroma) {
+  case de265_chroma_420:  sdlChroma = SDL_YUV_Display::SDL_CHROMA_420;  break;
+  case de265_chroma_422:  sdlChroma = SDL_YUV_Display::SDL_CHROMA_422;  break;
+  case de265_chroma_444:  sdlChroma = SDL_YUV_Display::SDL_CHROMA_444;  break;
+  case de265_chroma_mono: sdlChroma = SDL_YUV_Display::SDL_CHROMA_MONO; break;
+  default: sdlChroma = SDL_YUV_Display::SDL_CHROMA_MONO; break;
+  }
+
   if (!sdl_active) {
     sdl_active=true;
-    enum SDL_YUV_Display::SDL_Chroma sdlChroma;
-    switch (chroma) {
-    case de265_chroma_420:  sdlChroma = SDL_YUV_Display::SDL_CHROMA_420;  break;
-    case de265_chroma_422:  sdlChroma = SDL_YUV_Display::SDL_CHROMA_422;  break;
-    case de265_chroma_444:  sdlChroma = SDL_YUV_Display::SDL_CHROMA_444;  break;
-    case de265_chroma_mono: sdlChroma = SDL_YUV_Display::SDL_CHROMA_MONO; break;
-    }
-
-    sdlWin.init(width,height, sdlChroma);
+    if (!sdlWin.init(width,height, sdlChroma)) return true;
+    sdl_display_width = width;
+    sdl_display_height = height;
+    sdl_display_chroma = sdlChroma;
+  } else if (width != sdl_display_width || height != sdl_display_height ||
+             sdlChroma != sdl_display_chroma) {
+    // Re-initialize display on mid-stream resolution or chroma change.
+    // SDL 1.2 does not support resizing overlays, so close and re-init.
+    sdlWin.close();
+    if (!sdlWin.init(width,height, sdlChroma)) {
+      sdl_active = false;
+      return true;
+    }
+    sdl_display_width = width;
+    sdl_display_height = height;
+    sdl_display_chroma = sdlChroma;
   }
 
   int stride,chroma_stride;
Description: CVE-2026-33164 - Validate PPS header fields before set_derived_values()
 A malformed H.265 PPS NAL unit can cause a segmentation fault in
 pic_parameter_set::set_derived_values() when out-of-spec values for
 diff_cu_qp_delta_depth, reference index counts, tile geometry, or
 log2_parallel_merge_level are accepted. Reject invalid values during
 PPS parsing (per HEVC Sec. 7.4.3.3.1) and guard against a missing SPS
 before calling set_derived_values().
 .
 Backported from libde265 v1.0.17 input-validation hardening.
Origin: upstream, https://github.com/strukturag/libde265/releases/tag/v1.0.17
Author: Dirk Farin <dirk.farin@gmail.com>
Bug: https://github.com/strukturag/libde265/security/advisories/GHSA-wqrf-6rf5-v78r
Last-Update: 2026-07-15

--- a/libde265/pps.cc
+++ b/libde265/pps.cc
@@ -292,19 +292,19 @@
   num_extra_slice_header_bits = get_bits(br,3);
   sign_data_hiding_flag = get_bits(br,1);
   cabac_init_present_flag = get_bits(br,1);
-  num_ref_idx_l0_default_active = uvlc = get_uvlc(br);
-  if (uvlc == UVLC_ERROR) {
+  uvlc = get_uvlc(br);
+  if (uvlc == UVLC_ERROR || uvlc > 15) {
     ctx->add_warning(DE265_WARNING_PPS_HEADER_INVALID, false);
     return false;
   }
-  num_ref_idx_l0_default_active++;
+  num_ref_idx_l0_default_active = uvlc + 1;
 
-  num_ref_idx_l1_default_active = uvlc = get_uvlc(br);
-  if (uvlc == UVLC_ERROR) {
+  uvlc = get_uvlc(br);
+  if (uvlc == UVLC_ERROR || uvlc > 15) {
     ctx->add_warning(DE265_WARNING_PPS_HEADER_INVALID, false);
     return false;
   }
-  num_ref_idx_l1_default_active++;
+  num_ref_idx_l1_default_active = uvlc + 1;
 
 
   if (!ctx->has_sps(seq_parameter_set_id)) {
@@ -325,10 +325,13 @@
   cu_qp_delta_enabled_flag = get_bits(br,1);
 
   if (cu_qp_delta_enabled_flag) {
-    if ((diff_cu_qp_delta_depth = get_uvlc(br)) == UVLC_ERROR) {
+    // diff_cu_qp_delta_depth shall be in [0, log2_diff_max_min_luma_coding_block_size] (Sec. 7.4.3.3.1)
+    if ((uvlc = get_uvlc(br)) == UVLC_ERROR ||
+        uvlc > sps->log2_diff_max_min_luma_coding_block_size) {
       ctx->add_warning(DE265_WARNING_PPS_HEADER_INVALID, false);
       return false;
     }
+    diff_cu_qp_delta_depth = uvlc;
   } else {
     diff_cu_qp_delta_depth = 0;
   }
@@ -378,37 +381,29 @@
 
       for (int i=0; i<num_tile_columns-1; i++)
         {
-          colWidth[i] = get_uvlc(br);
-          if (colWidth[i] == UVLC_ERROR) {
+          uvlc = get_uvlc(br);
+          if (uvlc == UVLC_ERROR || uvlc >= lastColumnWidth) {
 	    ctx->add_warning(DE265_WARNING_PPS_HEADER_INVALID, false);
 	    return false;
 	  }
-          colWidth[i]++;
+          colWidth[i] = uvlc + 1;
 
           lastColumnWidth -= colWidth[i];
         }
 
-      if (lastColumnWidth <= 0) {
-        return false;
-      }
-
       colWidth[num_tile_columns-1] = lastColumnWidth;
 
       for (int i=0; i<num_tile_rows-1; i++)
         {
-          rowHeight[i] = get_uvlc(br);
-          if (rowHeight[i] == UVLC_ERROR) {
+          uvlc = get_uvlc(br);
+          if (uvlc == UVLC_ERROR || uvlc >= lastRowHeight) {
 	    ctx->add_warning(DE265_WARNING_PPS_HEADER_INVALID, false);
 	    return false;
 	  }
-          rowHeight[i]++;
+          rowHeight[i] = uvlc + 1;
           lastRowHeight -= rowHeight[i];
         }
 
-      if (lastRowHeight <= 0) {
-        return false;
-      }
-
 
       rowHeight[num_tile_rows-1] = lastRowHeight;
     }
@@ -485,12 +480,12 @@
 
 
   lists_modification_present_flag = get_bits(br,1);
-  log2_parallel_merge_level = get_uvlc(br);
-  if (log2_parallel_merge_level == UVLC_ERROR) {
+  uvlc = get_uvlc(br);
+  if (uvlc == UVLC_ERROR || uvlc > 4) {
     ctx->add_warning(DE265_WARNING_PPS_HEADER_INVALID, false);
     return false;
   }
-  log2_parallel_merge_level += 2;
+  log2_parallel_merge_level = uvlc + 2;
 
   if (log2_parallel_merge_level-2 > sps->log2_min_luma_coding_block_size-3 +1 +
       sps->log2_diff_max_min_luma_coding_block_size) {
@@ -525,6 +520,11 @@
   }
 
 
+  if (!sps) {
+    ctx->add_warning(DE265_WARNING_NONEXISTING_SPS_REFERENCED, false);
+    return false;
+  }
+
   set_derived_values(sps.get());
 
   pps_read = true;
