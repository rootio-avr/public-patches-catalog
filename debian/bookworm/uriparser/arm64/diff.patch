+static void dumpRange(const char * label, const UriTextRangeA * range) {
+	const int leftColumnMinWidthChars = 14;
+	const size_t labelLen = (label != NULL) ? strlen(label) : 0;
+	const int gapLenChars =
+			((size_t)(leftColumnMinWidthChars - 1) > labelLen)
+				? (int)(leftColumnMinWidthChars - labelLen - 1)
+				: 1;
+	fprintf(stdout, "%s:%*s", (label != NULL) ? label : "",
+			gapLenChars, "");
+	if ((range != NULL) && (range->first != NULL)
+			&& (range->afterLast >= range->first)) {
+		fwrite(range->first,
+				(size_t)(range->afterLast - range->first), 1, stdout);
+	}
+	fputc('\n', stdout);
+}
 
 
