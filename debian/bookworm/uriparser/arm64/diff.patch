Description: CVE-2026-42371 - Fix range-length truncation in CompareRange
 On 64-bit platforms the pointer-difference range lengths in
 uriCompareRange* were cast to int. Two URI text ranges that differed in
 length by 2^31 / 2^32 bytes could be treated as equal-length and then
 compared byte-by-byte, allowing an out-of-bounds read on crafted multi-
 gigabyte URI components (CVE-2026-42371, CWE-197 numeric truncation).
 .
 Use ptrdiff_t lengths and compare lengths before content; cast the
 length to size_t for URI_STRNCMP. Also add the upstream regression test
 (test/CompareRangeLengthWrap.cpp) and wire it into the testrunner build.
 .
 Backported from uriparser 1.0.1 (upstream commits 2b014fad and 47bab9f0).
 The hunks were regenerated against Debian's tab-indented 0.9.7+dfsg-2
 source so the patch applies cleanly without --ignore-whitespace.
Origin: backport, https://github.com/uriparser/uriparser/commit/2b014fad9ee69b0676a0a891ea21c7c3e8902f25
Origin: backport, https://github.com/uriparser/uriparser/commit/47bab9f00c4b6ad93bbe7f8571a4aff16476dfd2
Bug: https://github.com/uriparser/uriparser/pull/298
Bug-Debian: https://bugs.debian.org/1135109
Author: Joshua W. Windle <joshua.w.windle@gmail.com>
Last-Update: 2026-06-12

--- a/src/UriCommon.c
+++ b/src/UriCommon.c
@@ -64,6 +64,7 @@
 #ifndef URI_DOXYGEN
 # include <uriparser/Uri.h>
 # include "UriCommon.h"
+# include <stddef.h>  /* ptrdiff_t */
 #endif
 
 
@@ -88,6 +89,8 @@
 		const URI_TYPE(TextRange) * a,
 		const URI_TYPE(TextRange) * b) {
 	int diff;
+	ptrdiff_t lenA;
+	ptrdiff_t lenB;
 
 	/* NOTE: Both NULL means equal! */
 	if ((a == NULL) || (b == NULL)) {
@@ -99,14 +102,16 @@
 		return ((a->first == NULL) ? 0 : 1) - ((b->first == NULL) ? 0 : 1);
 	}
 
-	diff = ((int)(a->afterLast - a->first) - (int)(b->afterLast - b->first));
-	if (diff > 0) {
+	lenA = a->afterLast - a->first;
+	lenB = b->afterLast - b->first;
+
+	if (lenA > lenB) {
 		return 1;
-	} else if (diff < 0) {
+	} else if (lenA < lenB) {
 		return -1;
 	}
 
-	diff = URI_STRNCMP(a->first, b->first, (a->afterLast - a->first));
+	diff = URI_STRNCMP(a->first, b->first, (size_t)lenA);
 
 	if (diff > 0) {
 		return 1;
