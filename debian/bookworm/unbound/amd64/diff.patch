Description: Fix CVE-2026-33278 - possible RCE during DNSSEC validation
 Use-after-free in the NSEC3 validator when responses mix NSEC3 RRs from
 different NSEC3 chains (different algorithm/iterations/salt). The
 hardening adds a param_set_same() helper that verifies all NSEC3 RRs in
 a filter share identical parameters and rejects the proof as bogus
 otherwise. The helper is invoked from the five nsec3_prove_* entry
 points (nameerror, nodata, wildcard, nods, nxornodata) before any
 hash-based processing, preventing the corruption.
 .
 Note: the upstream commit also touches services/cache/dns.c
 (dns_msg_deepcopy_region) and ships .rpl regression test data added in
 a later release. Both are not applicable to the 1.17.1 codebase shipped
 in Debian 12 (the deepcopy helper does not yet exist) and are
 intentionally omitted from this backport.
Origin: upstream, https://github.com/NLnetLabs/unbound/commit/6a31e470f80a6e5c559ebe7fd4cfc0582d3b6d0a
Author: W.C.A. Wijngaards <wouter@nlnetlabs.nl>
Last-Update: 2026-06-03

--- a/validator/val_nsec3.c
+++ b/validator/val_nsec3.c
@@ -442,6 +442,67 @@ filter_init(struct nsec3_filter* filter, struct ub_packed_rrset_key** list,
 		}
 	}
 }
+/** Check if the NSEC3s have the same parameter set. */
+static int
+param_set_same(struct nsec3_filter* flt, char** reason)
+{
+	size_t rrsetnum;
+	int rrnum;
+	struct ub_packed_rrset_key* rrset;
+	int have_params = 0;
+	int first_algo = 0;
+	size_t first_iter = 0;
+	uint8_t* first_salt = NULL;
+	size_t first_saltlen = 0;
+
+	/* If the NSEC3 parameter sets have distinct values, then they are
+	 * from different NSEC3 chains, and we do not want that. */
+	for(rrset=filter_first(flt, &rrsetnum, &rrnum); rrset;
+		rrset=filter_next(flt, &rrsetnum, &rrnum)) {
+		if(!have_params) {
+			first_algo = nsec3_get_algo(rrset, rrnum);
+			first_iter = nsec3_get_iter(rrset, rrnum);
+			if(!nsec3_get_salt(rrset, rrnum, &first_salt,
+				&first_saltlen)) {
+				verbose(VERB_ALGO, "NSEC3 salt malformed");
+				if(reason)
+					*reason = "NSEC3 salt malformed";
+				return 0;
+			}
+			have_params = 1;
+		} else {
+			uint8_t* salt = NULL;
+			size_t saltlen = 0;
+			if(nsec3_get_algo(rrset, rrnum) != first_algo) {
+				verbose(VERB_ALGO, "NSEC3 algorithm mismatch");
+				if(reason)
+					*reason = "NSEC3 algorithm mismatch";
+				return 0;
+			}
+			if(nsec3_get_iter(rrset, rrnum) != first_iter) {
+				verbose(VERB_ALGO, "NSEC3 iterations mismatch");
+				if(reason)
+					*reason = "NSEC3 iterations mismatch";
+				return 0;
+			}
+			if(!nsec3_get_salt(rrset, rrnum, &salt, &saltlen)) {
+				verbose(VERB_ALGO, "NSEC3 salt malformed");
+				if(reason)
+					*reason = "NSEC3 salt malformed";
+				return 0;
+			}
+			if(saltlen != first_saltlen ||
+				memcmp(salt, first_salt, saltlen) != 0) {
+				verbose(VERB_ALGO, "NSEC3 salt mismatch");
+				if(reason)
+					*reason = "NSEC3 salt mismatch";
+				return 0;
+			}
+		}
+	}
+	return 1;
+}
+
 
 /**
  * Find max iteration count using config settings and key size
@@ -1075,6 +1136,8 @@ nsec3_prove_nameerror(struct module_env* env, struct val_env* ve,
 	filter_init(&flt, list, num, qinfo); /* init RR iterator */
 	if(!flt.zone)
 		return sec_status_bogus; /* no RRs */
+	if(!param_set_same(&flt, NULL))
+		return sec_status_bogus; /* nsec3 params from distinct chains*/
 	if(nsec3_iteration_count_high(ve, &flt, kkey))
 		return sec_status_insecure; /* iteration count too high */
 	log_nametypeclass(VERB_ALGO, "start nsec3 nameerror proof, zone", 
@@ -1234,6 +1297,8 @@ nsec3_prove_nodata(struct module_env* env, struct val_env* ve,
 	filter_init(&flt, list, num, qinfo); /* init RR iterator */
 	if(!flt.zone)
 		return sec_status_bogus; /* no RRs */
+	if(!param_set_same(&flt, NULL))
+		return sec_status_bogus; /* nsec3 params from distinct chains*/
 	if(nsec3_iteration_count_high(ve, &flt, kkey))
 		return sec_status_insecure; /* iteration count too high */
 	return nsec3_do_prove_nodata(env, &flt, &ct, qinfo);
@@ -1258,6 +1323,8 @@ nsec3_prove_wildcard(struct module_env* env, struct val_env* ve,
 	filter_init(&flt, list, num, qinfo); /* init RR iterator */
 	if(!flt.zone)
 		return sec_status_bogus; /* no RRs */
+	if(!param_set_same(&flt, NULL))
+		return sec_status_bogus; /* nsec3 params from distinct chains*/
 	if(nsec3_iteration_count_high(ve, &flt, kkey))
 		return sec_status_insecure; /* iteration count too high */
 
@@ -1341,6 +1408,8 @@
 		*reason = "no NSEC3 records";
 		return sec_status_bogus; /* no RRs */
 	}
+	if(!param_set_same(&flt, reason))
+		return sec_status_bogus; /* nsec3 params from distinct chains*/
 	if(nsec3_iteration_count_high(ve, &flt, kkey))
 		return sec_status_insecure; /* iteration count too high */
 
@@ -1421,6 +1490,8 @@ nsec3_prove_nxornodata(struct module_env* env, struct val_env* ve,
 	filter_init(&flt, list, num, qinfo); /* init RR iterator */
 	if(!flt.zone)
 		return sec_status_bogus; /* no RRs */
+	if(!param_set_same(&flt, NULL))
+		return sec_status_bogus; /* nsec3 params from distinct chains*/
 	if(nsec3_iteration_count_high(ve, &flt, kkey))
 		return sec_status_insecure; /* iteration count too high */
 
Description: CVE-2026-42944 - Heap overflow and crash with multiple nsid, cookie, padding EDNS options
 A remote attacker can craft a DNS query that contains multiple instances of
 the EDNS NSID, COOKIE, or PADDING options. When unbound encodes the reply,
 the per-option entries are accumulated in the outgoing EDNS option list
 without enforcing buffer bounds, which can lead to a heap buffer overflow
 or a crash.
 .
 This backport applies the upstream fix to the unbound 1.17.x series shipped
 in Debian bookworm:
   * util/data/msgencode.c: when serializing the outgoing EDNS option list
     in attach_edns_record_max_msg_sz(), check that there is enough room in
     the packet buffer for each option (header + opt_len) before writing,
     and only emit the trailing PADDING option when there is at least space
     for its 4-byte header.
   * util/data/msgparse.c: in parse_edns_options_from_query(), record
     whether NSID and PADDING options have already been processed for this
     query and ignore subsequent duplicates so that the response option
     list cannot be inflated by repeating these EDNS options. The COOKIE
     case from the upstream fix is intentionally omitted because the cookie
     handling code path does not exist in this branch.
 .
 The size_t signature changes for calc_edns_field_size / calc_ede_option_size
 and the extended_error_encode / ede_trim_text changes from the upstream
 commit are not applicable to this branch and have been omitted.
Origin: backport, https://github.com/NLnetLabs/unbound/commit/fe946ba4e935a1528e6866e108e5bc9e7533ae18
Author: W.C.A. Wijngaards <wouter@nlnetlabs.nl>
Last-Update: 2026-06-03
---
--- a/util/data/msgencode.c
+++ b/util/data/msgencode.c
@@ -835,6 +835,10 @@ attach_edns_record_max_msg_sz(sldns_buff
 			padding_option = opt;
 			continue;
 		}
+		if(sldns_buffer_position(pkt) + opt->opt_len + 4 > max_msg_sz)
+			break; /* no space for it */
+		if(!sldns_buffer_available(pkt, 4 + opt->opt_len))
+			break;
 		sldns_buffer_write_u16(pkt, opt->opt_code);
 		sldns_buffer_write_u16(pkt, opt->opt_len);
 		if(opt->opt_len != 0)
@@ -845,12 +849,18 @@ attach_edns_record_max_msg_sz(sldns_buff
 			padding_option = opt;
 			continue;
 		}
+		if(sldns_buffer_position(pkt) + opt->opt_len + 4 > max_msg_sz)
+			break; /* no space for it */
+		if(!sldns_buffer_available(pkt, 4 + opt->opt_len))
+			break;
 		sldns_buffer_write_u16(pkt, opt->opt_code);
 		sldns_buffer_write_u16(pkt, opt->opt_len);
 		if(opt->opt_len != 0)
 			sldns_buffer_write(pkt, opt->opt_data, opt->opt_len);
 	}
-	if (padding_option && edns->padding_block_size ) {
+	if (padding_option && edns->padding_block_size &&
+		sldns_buffer_position(pkt)+4 <= max_msg_sz &&
+		sldns_buffer_available(pkt, 4) /* if there is space for it */) {
 		size_t pad_pos = sldns_buffer_position(pkt);
 		size_t msg_sz = ((pad_pos + 3) / edns->padding_block_size + 1)
 		                               * edns->padding_block_size;
