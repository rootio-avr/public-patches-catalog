Description: Fix CVE-2026-41992 buffer over-read decompressing .lzh after .Z
 GNU gzip shares the global 'left' and 'right' arrays in unlzh.c between the
 LZW and LZH decoders. When decompressing an LZW (.Z) file followed by a
 crafted LZH (.lzh) file in a single 'gzip -d' invocation, the LZH decoder
 (read_c_len) can follow stale values left behind by the previous LZW
 decompression and read past the end of the allocated buffer.
 .
 This backport clears the shared 'left' and 'right' arrays in
 unlzh.c:read_c_len when n == 0, matching the upstream fix. The NEWS and
 THANKS entries from the upstream commit are omitted as documentation-only
 changes not relevant to the Debian package.
Origin: upstream, https://git.savannah.gnu.org/cgit/gzip.git/commit/?id=63dbf6b3b9e6e781df1a6a64e609b10e23969681
Author: Paul Eggert <eggert@cs.ucla.edu>
Bug: https://savannah.gnu.org/bugs/?66018
Last-Update: 2026-07-01

--- a/unlzh.c
+++ b/unlzh.c
@@ -242,6 +242,12 @@ local void read_c_len()
         c = getbits(CBIT);
         for (i = 0; i < NC; i++) c_len[i] = 0;
         for (i = 0; i < 4096; i++) c_table[i] = c;
+
+        /* Needed in case LEFT and RIGHT are reused from a previous
+           LZW decompression.  It may be overkill to clear all of both
+           arrays, but nobody has had time to analyze this carefully.  */
+        memzero(left, (2 * NC - 1) * sizeof *left);
+        memzero(right, (2 * NC - 1) * sizeof *left);
     } else {
         i = 0;
         while (i < n) {
