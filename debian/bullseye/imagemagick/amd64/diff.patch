Description: CVE-2026-32259 - Fix out of bounds write when color reduction fails
 Added extra check to prevent out of bounds write when color reduction
 fails. When a memory allocation fails in the sixel encoder, it is
 possible to write past the end of a buffer on the stack due to missing
 bounds check after color reduction. Replace hardcoded 256 with
 SIXEL_PALETTE_MAX and add an explicit bounds check before writing
 the SIXEL header.
Origin: upstream, https://github.com/ImageMagick/ImageMagick6/commit/812ff3ef91967d367aa7a087a31b94f3b2a267ee
Author: Dirk Lemstra <dirk@lemstra.org>
Last-Update: 2026-03-14

--- a/coders/sixel.c
+++ b/coders/sixel.c
@@ -1266,7 +1266,7 @@
   opacity=(-1);
   if (image->matte == MagickFalse)
     {
-      if ((image->storage_class == DirectClass) || (image->colors > 256))
+      if ((image->storage_class == DirectClass) || (image->colors > SIXEL_PALETTE_MAX))
         (void) SetImageType(image,PaletteType);
     }
   else
@@ -1278,7 +1278,7 @@
       /*
         Identify transparent colormap index.
       */
-      if ((image->storage_class == DirectClass) || (image->colors > 256))
+      if ((image->storage_class == DirectClass) || (image->colors > SIXEL_PALETTE_MAX))
         (void) SetImageType(image,PaletteBilevelMatteType);
       for (i=0; i < (ssize_t) image->colors; i++)
         if (image->colormap[i].opacity != OpaqueOpacity)
@@ -1317,6 +1317,8 @@
           image->colormap[opacity].blue=image->transparent_color.blue;
         }
     }
+  if (image->colors > SIXEL_PALETTE_MAX)
+    return(MagickFalse);
   /*
     SIXEL header.
   */
Description: CVE-2026-28494 - Fix stack buffer overflow in morphology kernel parsing
 ImageMagick contains a stack buffer overflow in morphology kernel parsing
 functions (ParseKernelArray and ParseKernelName in magick/morphology.c).
 User-controlled kernel strings exceeding the MaxTextExtent buffer size are
 copied into fixed-size stack buffers via memcpy without bounds checking,
 resulting in possible stack corruption. This patch adds MagickMin bounds
 checks to limit the copy length to sizeof(token)-1.
Origin: upstream, https://github.com/ImageMagick/ImageMagick6/commit/f6cd30e0493635eb0b8a4e3dd93c1ac14a35a7e9
Author: Dirk Lemstra <dirk@lemstra.org>
Last-Update: 2026-03-11

--- a/magick/morphology.c
+++ b/magick/morphology.c
@@ -234,6 +234,9 @@
   GeometryInfo
     args;

+  size_t
+    length;
+
   kernel=(KernelInfo *) AcquireMagickMemory(sizeof(*kernel));
   if (kernel == (KernelInfo *) NULL)
     return(kernel);
@@ -261,8 +264,9 @@
   if ( p != (char *) NULL && p < end)
     {
       /* ParseGeometry() needs the geometry separated! -- Arrgghh */
-      memcpy(token, kernel_string, (size_t) (p-kernel_string));
-      token[p-kernel_string] = '\0';
+      length=MagickMin((size_t) (p-kernel_string),sizeof(token)-1);
+      memcpy(token, kernel_string, length);
+      token[length] = '\0';
       SetGeometryInfo(&args);
       flags = ParseGeometry(token, &args);

@@ -387,6 +391,9 @@
   MagickStatusType
     flags;

+  size_t
+    length;
+
   ssize_t
     type;

@@ -405,8 +412,9 @@
     end = strchr(p, '\0');

   /* ParseGeometry() needs the geometry separated! -- Arrgghh */
-  memcpy(token, p, (size_t) (end-p));
-  token[end-p] = '\0';
+  length=MagickMin((size_t) (end-p),sizeof(token)-1);
+  memcpy(token, p, length);
+  token[length] = '\0';
   SetGeometryInfo(&args);
   flags = ParseGeometry(token, &args);

Description: CVE-2026-28686 - Fix heap buffer overflow in PCL RLE compression
 The buffer allocated for RLE compression in the PCL encoder was undersized.
 It was allocated as (length+256) bytes but RLE encoding can expand data by
 up to (length/127) bytes in the worst case, causing a heap-buffer-overflow.
 Fix the buffer allocation and memset to use (length+(length/127)+256).
Origin: upstream, https://github.com/ImageMagick/ImageMagick6/commit/6a602fb36f181a0089848344a3b0d79fc6155a2b
Author: ImageMagick Studio LLC
Last-Update: 2026-03-11

--- a/coders/pcl.c
+++ b/coders/pcl.c
@@ -829,15 +829,15 @@
       }
       case RLECompression:
       {
-        compress_pixels=(unsigned char *) AcquireQuantumMemory(length+256,
-          sizeof(*compress_pixels));
+        compress_pixels=(unsigned char *) AcquireQuantumMemory(length+
+          (length/127)+256,sizeof(*compress_pixels));
         if (compress_pixels == (unsigned char *) NULL)
           {
             pixels=(unsigned char *) RelinquishMagickMemory(pixels);
             ThrowWriterException(ResourceLimitError,"MemoryAllocationFailed");
           }
-        (void) memset(compress_pixels,0,(length+256)*
+        (void) memset(compress_pixels,0,(length+(length/127)+256)*
           sizeof(*compress_pixels));
         (void) FormatLocaleString(buffer,MaxTextExtent,"\033*b2M");
         (void) WriteBlobString(image,buffer);
Description: CVE-2026-30937 - Fix heap buffer overflow in XWD encoder
 ImageMagick prior to 6.9.13-41 has a 32-bit unsigned integer overflow
 in the XWD (X Windows) encoder. The CARD32 truncation check
 (image->columns != (CARD32) image->columns) is a no-op on platforms
 where size_t is 32-bit or where the compiler optimizes it away, leading
 to an undersized heap buffer allocation and out-of-bounds write.
 Replace the ineffective CARD32 truncation comparison with an explicit
 bounds check limiting dimensions to 65535.
Origin: upstream, https://github.com/ImageMagick/ImageMagick6/commit/42e5a37eeb60ca4fdede5060c0aa60802c2dc701
Author: Cristy <urban-warrior@imagemagick.org>
Last-Update: 2026-03-11

--- a/coders/xwd.c
+++ b/coders/xwd.c
@@ -804,8 +804,7 @@
   status=OpenBlob(image_info,image,WriteBinaryBlobMode,&image->exception);
   if (status == MagickFalse)
     return(status);
-  if ((image->columns != (CARD32) image->columns) ||
-      (image->rows != (CARD32) image->rows))
+  if ((image->columns > 65535UL) || (image->rows > 65535UL))
     ThrowWriterException(ImageError,"WidthOrHeightExceedsLimit");
   if ((image->storage_class == PseudoClass) && (image->colors > 256))
     (void) SetImageType(image,TrueColorType);
