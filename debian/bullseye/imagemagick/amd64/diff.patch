Description: CVE-2026-28687 - Fix heap use-after-free in MSL decoder
 A heap use-after-free vulnerability in ImageMagick's MSL decoder allows
 an attacker to trigger access to freed memory by crafting an MSL file.
 The fix addresses three issues: (1) an off-by-one array index in
 MSLPushImage when updating group_info numImages, (2) a missing NULL
 check after ResizeQuantumMemory in the "group" element handler of
 MSLStartElement, and (3) a missing bounds check for number_groups in
 MSLEndElement before accessing group_info array.
Origin: upstream, commit:0e328007d2eeefb9ae24bc3f4442b1a2469d772e
Author: Cristy <urban-warrior@imagemagick.org>
Last-Update: 2026-03-11

--- a/coders/msl.c
+++ b/coders/msl.c
@@ -588,8 +588,8 @@
       (msl_info->attributes[n] == (Image *) NULL))
     ThrowFatalException(ResourceLimitFatalError,"MemoryAllocationFailed");
   if (msl_info->number_groups != 0)
-    msl_info->group_info[msl_info->number_groups-1].numImages++;
+    msl_info->group_info[msl_info->number_groups].numImages++;
   return(n);
 }

 static void MSLPopImage(MSLInfo *msl_info)
@@ -3361,6 +3361,13 @@
       msl_info->group_info=(MSLGroupInfo *) ResizeQuantumMemory(
         msl_info->group_info,msl_info->number_groups+1UL,
         sizeof(*msl_info->group_info));
+      if (msl_info->group_info == (MSLGroupInfo *) NULL)
+        {
+          ThrowMSLException(ResourceLimitFatalError,"UnableToInterpretMSLImage",
+            tag);
+          break;
+        }
+      msl_info->group_info[msl_info->number_groups].numImages=0;
       break;
     }
       ThrowMSLException(OptionError,"UnrecognizedElement",(const char *) tag);
@@ -7409,7 +7416,8 @@
