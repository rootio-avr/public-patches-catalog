-        ldblk = (ssize_t) (8 * MATLAB_HDR.SizeX);
+        ldblk = (8 * (ssize_t) MATLAB_HDR.SizeX);
         break;
       case miSINGLE:
         sample_size = 32;
@@ -1177,7 +1177,7 @@
         if (MATLAB_HDR.StructureFlag & FLAG_COMPLEX)
