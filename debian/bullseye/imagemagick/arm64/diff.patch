Description: CVE-2026-53460 - Add maximum memory request check in AcquireAlignedMemory
 Extends the heap-overflow sanity check in AcquireAlignedMemory to also
 reject sizes exceeding GetMaxMemoryRequest(), returning NULL with
 errno=ENOMEM. Fixes GHSA-q62c-h75r-2xhc.
Origin: upstream, https://github.com/ImageMagick/ImageMagick6/commit/3396cbf4049c4576814b45bb6094ac3ad5493115
Author: Cristy <urban-warrior@imagemagick.org>
Last-Update: 2026-06-17
--- a/magick/memory.c
+++ b/magick/memory.c
@@ -367,7 +367,8 @@
   size_t
     size;
 
-  if (HeapOverflowSanityCheckGetSize(count,quantum,&size) != MagickFalse)
+  if ((HeapOverflowSanityCheckGetSize(count,quantum,&size) != MagickFalse) ||
+      (size > GetMaxMemoryRequest()))
     {
       errno=ENOMEM;
       return(NULL);
