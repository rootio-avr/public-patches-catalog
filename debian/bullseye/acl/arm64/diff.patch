--- a/libacl/acl_extended_file.c
+++ b/libacl/acl_extended_file.c
@@ -20,16 +20,92 @@
 */
 
 #include "config.h"
+#include <sys/types.h>
+#include <sys/stat.h>
 #include <unistd.h>
+#include <stdio.h>
+#include <fcntl.h>
 #include <sys/xattr.h>
 #include "libacl.h"
 
+#include "byteorder.h"
+#include "acl_ea.h"
 #include "__acl_extended_file.h"
 
+/*
+ * CVE-2026-54369: Open path_p safely (no symlink follow on the final
+ * component) and return an fd plus a /proc/self/fd/N path that the
+ * subsequent getxattr() probes can use atomically. Rejects symlinks
+ * with ENOTSUP and eliminates the TOCTOU between the two getxattr()
+ * calls below.
+ */
+static int
+__acl_safe_open(const char *path_p, char *proc_path, size_t proc_path_size)
+{
+	struct stat st;
+	int fd;
 
+	if (path_p == NULL) {
+		errno = EFAULT;
+		return -1;
+	}
+	fd = open(path_p, O_PATH | O_NOFOLLOW | O_CLOEXEC);
+	if (fd < 0)
+		return -1;
+	if (fstat(fd, &st) != 0) {
+		int saved = errno;
+		close(fd);
+		errno = saved;
+		return -1;
+	}
+	if (S_ISLNK(st.st_mode)) {
+		close(fd);
+		errno = ENOTSUP;
+		return -1;
+	}
+	if (snprintf(proc_path, proc_path_size, "/proc/self/fd/%d", fd)
+	    >= (int)proc_path_size) {
+		close(fd);
+		errno = ENAMETOOLONG;
+		return -1;
+	}
+	return fd;
+}
+
 int
 acl_extended_file(const char *path_p)
 {
-	return __acl_extended_file(path_p, getxattr);
+	int base_size = sizeof(acl_ea_header) + 3 * sizeof(acl_ea_entry);
+	int retval;
+	int fd;
+	int saved_errno;
+	int result = 0;
+	char proc_path[64];
+
+	fd = __acl_safe_open(path_p, proc_path, sizeof(proc_path));
+	if (fd < 0)
+		return -1;
+
+	retval = getxattr(proc_path, ACL_EA_ACCESS, NULL, 0);
+	if (retval < 0 && errno != ENOATTR && errno != ENODATA) {
+		result = -1;
+		goto out;
+	}
+	if (retval > base_size) {
+		result = 1;
+		goto out;
+	}
+	retval = getxattr(proc_path, ACL_EA_DEFAULT, NULL, 0);
+	if (retval < 0 && errno != ENOATTR && errno != ENODATA) {
+		result = -1;
+		goto out;
+	}
+	if (retval >= base_size)
+		result = 1;
+out:
+	saved_errno = errno;
+	close(fd);
+	errno = saved_errno;
+	return result;
 }
 
