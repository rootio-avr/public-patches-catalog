 #include "byteorder.h"
 #include "acl_ea.h"
 
+/*
+ * CVE-2026-54369: Open path_p safely (no symlink follow on the final
+ * component) and return an fd plus a /proc/self/fd/N path that subsequent
+ * xattr/stat calls can use atomically. Rejects symlinks with ENOTSUP and
+ * eliminates the path-based TOCTOU between getxattr() and stat().
+ */
+static int
+__acl_safe_open(const char *path_p, char *proc_path, size_t proc_path_size)
+{
+	struct stat st;
+	int fd;
+
+	if (path_p == NULL) {
+		errno = EFAULT;
+		return -1;
+	}
+	fd = open(path_p, O_PATH | O_NOFOLLOW | O_CLOEXEC);
+	if (fd < 0)
+		return -1;
+	if (fstat(fd, &st) != 0) {
+		int saved = errno;
+		close(fd);
+		errno = saved;
+		return -1;
+	}
+	if (S_ISLNK(st.st_mode)) {
+		close(fd);
+		errno = ENOTSUP;
+		return -1;
+	}
+	if (snprintf(proc_path, proc_path_size, "/proc/self/fd/%d", fd)
+	    >= (int)proc_path_size) {
+		close(fd);
+		errno = ENAMETOOLONG;
+		return -1;
+	}
+	return fd;
+}
+
