-			return acl_from_mode(st.st_mode);
-	} else
-		return NULL;
+			acl_ret = acl_from_mode(st.st_mode);
+	}
+	saved_errno = errno;
+	close(fd);
+	errno = saved_errno;
+	return acl_ret;
 }
 
