-			retval = getxattr(path_p, name, ext_acl_p, retval);
+			}
+			retval = getxattr(proc_path, name, ext_acl_p, retval);
 		}
 	}
 	if (retval > 0) {
-		acl_t acl = __acl_from_xattr(ext_acl_p, retval);
-		return acl;
+		acl_ret = __acl_from_xattr(ext_acl_p, retval);
 	} else if (retval == 0 || errno == ENOATTR || errno == ENODATA) {
 		struct stat st;
 
-		if (stat(path_p, &st) != 0)
+		if (fstat(fd, &st) != 0) {
+			saved_errno = errno;
+			close(fd);
+			errno = saved_errno;
