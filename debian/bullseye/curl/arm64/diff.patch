Subject: CVE-2023-46219: fopen: create short(er) temporary file name

Only using random letters in the name plus a ".tmp" extension.
Not by appending characters to the final file name.

This prevents creating overly long temporary filenames that could
exceed filesystem path length limits.

Origin: https://github.com/curl/curl/commit/73b65e94f3531179de45c6f3c836a610e3d0a846
Bug-Debian: https://security-tracker.debian.org/tracker/CVE-2023-46219

Backport notes:
- Adapted for curl 7.74.0 (Debian Bullseye)
- Uses Curl_rand_hex instead of Curl_rand_alnum (not available in 7.74.0)
- Increased random buffer size to compensate for hex vs alnum entropy difference
---
 lib/fopen.c | 70 ++++++++++++++++++++++++++++++++++++++++++++++++-----
 1 file changed, 64 insertions(+), 6 deletions(-)

--- a/lib/fopen.c
+++ b/lib/fopen.c
@@ -33,6 +33,7 @@
 
 #include "urldata.h"
 #include "rand.h"
+#include "dynbuf.h"
 #include "fopen.h"
 /* The last 3 #include files should be in this order */
 #include "curl_printf.h"
@@ -40,6 +41,51 @@
 #include "memdebug.h"
 
 /*
+  The dirslash() function breaks a null-terminated pathname string into
+  directory and filename components then returns the directory component up
+  to, *AND INCLUDING*, a final '/'. If there is no directory in the path,
+  this instead returns a "" string.
+
+  This function returns a pointer to malloc'ed memory.
+
+  The input path to this function is expected to have a file name part.
+*/
+
+#ifdef _WIN32
+#define PATHSEP "\\"
+#define IS_SEP(x) (((x) == '/') || ((x) == '\\'))
+#elif defined(MSDOS) || defined(__EMX__) || defined(OS2)
+#define PATHSEP "\\"
+#define IS_SEP(x) ((x) == '\\')
+#else
+#define PATHSEP "/"
+#define IS_SEP(x) ((x) == '/')
+#endif
+
+static char *dirslash(const char *path)
+{
+  size_t n;
+  struct dynbuf out;
+  DEBUGASSERT(path);
+  Curl_dyn_init(&out, CURL_MAX_INPUT_LENGTH);
+  n = strlen(path);
+  if(n) {
+    /* find the rightmost path separator, if any */
+    while(n && !IS_SEP(path[n-1]))
+      --n;
+    /* skip over all the path separators, if any */
+    while(n && IS_SEP(path[n-1]))
+      --n;
+  }
+  if(Curl_dyn_addn(&out, path, n))
+    return NULL;
+  /* if there was a directory, append a single trailing slash */
+  if(n && Curl_dyn_addn(&out, PATHSEP, 1))
+    return NULL;
+  return Curl_dyn_ptr(&out);
+}
+
+/*
  * Curl_fopen() opens a file for writing with a temp name, to be renamed
  * to the final name when completed. If there is an existing file using this
  * name at the time of the open, this function will clone the mode from that
@@ -50,25 +96,34 @@ CURLcode Curl_fopen(struct Curl_easy *da
                     FILE **fh, char **tempname)
 {
   CURLcode result = CURLE_WRITE_ERROR;
-  unsigned char randsuffix[9];
+  unsigned char randsuffix[41];
   char *tempstore = NULL;
   struct_stat sb;
   int fd = -1;
+  char *dir = NULL;
   *tempname = NULL;
 
-  if(stat(filename, &sb) == -1 || !S_ISREG(sb.st_mode)) {
-    /* a non-regular file, fallback to direct fopen() */
-    *fh = fopen(filename, FOPEN_WRITETEXT);
-    if(*fh)
-      return CURLE_OK;
+  dir = dirslash(filename);
+  if(!dir)
+    goto fail;
+
+  *fh = fopen(filename, FOPEN_WRITETEXT);
+  if(!*fh)
     goto fail;
+  if(fstat(fileno(*fh), &sb) == -1 || !S_ISREG(sb.st_mode)) {
+    /* a non-regular file, fallback to direct fopen() */
+    free(dir);
+    return CURLE_OK;
   }
+  fclose(*fh);
+  *fh = NULL;
 
   result = Curl_rand_hex(data, randsuffix, sizeof(randsuffix));
   if(result)
     goto fail;
 
-  tempstore = aprintf("%s.%s.tmp", filename, randsuffix);
+  /* The temp file name should not end up too long for the target file system */
+  tempstore = aprintf("%s%s.tmp", dir, randsuffix);
   if(!tempstore) {
     result = CURLE_OUT_OF_MEMORY;
     goto fail;
@@ -95,6 +150,7 @@ CURLcode Curl_fopen(struct Curl_easy *da
   if(!*fh)
     goto fail;
 
+  free(dir);
   *tempname = tempstore;
   return CURLE_OK;
 
@@ -105,6 +161,7 @@ fail:
   }
 
   free(tempstore);
+  free(dir);
 
   *tempname = NULL;
   return result;
Description: CVE-2026-8932: include mTLS material in conn-reuse & session-cache match
 libcurl reused a previously created connection even when some mTLS-related
 configuration option had been changed that should have prohibited reuse.
 Several TLS settings tied to client certificates (SSLCERTTYPE, SSLKEY,
 SSLKEYTYPE, KEYPASSWD, SSLKEYBLOB) were left out from the connection-pool
 configuration match checks and from the TLS session cache lookup, so two
 easy handles differing only on those options could silently inherit each
 other's authenticated identity.
 .
 This is an adapted (partial) backport for the Debian curl
 7.74.0-1.3+deb11u16 POST-QUILT source tree (i.e. after debian/patches/series
 has been applied by dpkg-source, so lib/urldata.h, lib/vtls/vtls.c and
 lib/url.c already carry ~60 prior debian patches including all the
 CVE-* backports through CVE-2025-9086). Context lines below match that
 post-quilt state, not vanilla upstream curl-7.74.0.
 .
 The upstream fix (curl commit 7541ae569d, released in 8.21.0) moves
 cert_type/key/key_type/key_passwd/key_blob from struct ssl_config_data
 into struct ssl_primary_config. That struct move is not directly back-
 portable to 7.74.0 because SSL_SET_OPTION(cert_type) et al. are
 referenced from ~23 sites across every TLS backend (openssl, gnutls,
 nss, mbedtls, sectransp, schannel, wolfssl, mesalink, gskit), and the
 target lacks the vtls_scache.[ch] session-cache module that received
 the second half of the upstream change.
 .
 The backport here keeps the existing SSL_SET_OPTION() macro semantics
 completely unchanged by ADDING the five mTLS fields to
 struct ssl_primary_config (rather than moving them out of
 struct ssl_config_data). It then:
   * populates the new ssl_primary_config.{cert_type,key,key_type,
     key_passwd,key_blob} in create_conn() (lib/url.c) in parallel with
     the existing ssl_config_data assignments, for both direct and proxy
     handles,
   * extends Curl_ssl_config_matches() so the connection-reuse predicate
     compares the five mTLS fields,
   * extends Curl_clone_primary_ssl_config() and
     Curl_free_primary_ssl_config() to cover the new fields.
 .
 Because in 7.74.0 the TLS session cache stores a full ssl_primary_config
 clone per slot and looks it up through Curl_ssl_config_matches()
 (see Curl_ssl_getsessionid() / Curl_ssl_addsessionid() in lib/vtls/vtls.c),
 extending the matcher automatically fixes the session-cache half in place
 without introducing the upstream ":CCERT"/clientcert peer-key rewrite,
 which has no analogue in this branch.
