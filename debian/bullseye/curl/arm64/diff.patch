Description: CVE-2026-6253 - Clear proxy credentials on redirect to prevent leak
 When following redirects that change the URL scheme (e.g., HTTP to HTTPS),
 the Proxy-Authorization header and proxy authentication state from the
 previous proxy could leak to a different proxy. This patch clears the
 cached proxy auth header and resets the proxy auth negotiation state
 on every redirect, ensuring that proxy credentials are re-established
 from the new connection's proxy configuration rather than carried over
 from the previous connection.
Origin: upstream, https://github.com/curl/curl/commit/188c2f166a20fa97c2325b2da7d0e5cecc13725f
Author: Daniel Stenberg <daniel@haxx.se>
Last-Update: 2026-05-01

--- a/lib/transfer.c
+++ b/lib/transfer.c
@@ -1698,6 +1698,16 @@
     }
   }
 
+#ifndef CURL_DISABLE_PROXY
+  /* Clear proxy credentials on redirect to prevent the Proxy-Authorization
+     header from leaking to a different proxy when following cross-scheme
+     redirects (CVE-2026-6253). The header will be rebuilt from the new
+     connection's proxy credentials if needed. */
+  Curl_safefree(data->state.aptr.proxyuserpwd);
+  data->state.authproxy.done = FALSE;
+  data->state.authproxy.multipass = FALSE;
+#endif
+
   if(type == FOLLOW_FAKE) {
     /* we're only figuring out the new url if we would've followed locations
        but now we're done so we can get out! */
diff --git a/lib/http.c b/lib/http.c
index c232ed4134..44eefb4596 100644
--- a/lib/http.c
+++ b/lib/http.c
@@ -720,8 +720,16 @@ output_auth_headers(struct connectdata *conn,
   }
   if(authstatus->picked == CURLAUTH_BEARER) {
     /* Bearer */
-    if((!proxy && data->set.str[STRING_BEARER] &&
-        !Curl_checkheaders(conn, "Authorization:"))) {
+    if(!proxy && data->set.str[STRING_BEARER] &&
+       /* Only send bearer to the original host or if explicitly allowed.
+          This prevents leaking the token on redirects (CVE-2026-3783),
+          including when .netrc has a matching entry for the redirected host. */
+       (!data->state.this_is_a_follow ||
+        data->set.allow_auth_to_other_hosts ||
+        (!data->state.first_host ||
+         (strcasecompare(data->state.first_host, conn->host.name) &&
+          data->state.first_remote_port == conn->remote_port))) &&
+       !Curl_checkheaders(conn, "Authorization:")) {
       auth = "Bearer";
       result = http_output_bearer(conn);
       if(result)
