Description: CVE-2026-1965 - Fix reuse of connections using HTTP Negotiate
 libcurl incorrectly reuses connections in Negotiate-authenticated
 requests. When an application authenticates to a server with one
 credential set, then attempts a second operation using different
 credentials while the original connection persists, the library
 erroneously reuses the authenticated connection, allowing the second
 request to unknowingly use the first user's credentials.
 .
 This patch adds Negotiate (SPNEGO) credential checking in
 ConnectionExists() mirroring the existing NTLM pattern, so that
 connections using Negotiate authentication are only reused when the
 credentials match.
 .
 Adapted from upstream commits for curl 7.74.0 (Debian Bullseye).
Origin: upstream, https://github.com/curl/curl/commit/34fa034d9a390c4bd6, https://github.com/curl/curl/commit/f1a39f221d57354990e3eeeddc3404aede2aff70
Author: Daniel Stenberg <daniel@haxx.se>
Last-Update: 2026-02-21

--- a/lib/url.c
+++ b/lib/url.c
@@ -1090,7 +1090,20 @@ ConnectionExists(struct Curl_easy *data,
   bool wantProxyNTLMhttp = FALSE;
 #endif
 #endif
 
+#ifdef USE_SPNEGO
+  bool wantNegoHTTP = ((data->state.authhost.want & CURLAUTH_NEGOTIATE) &&
+                       (needle->handler->protocol & PROTO_FAMILY_HTTP));
+#ifndef CURL_DISABLE_PROXY
+  bool wantProxyNegoHTTP = (needle->bits.proxy_user_passwd &&
+                            ((data->state.authproxy.want &
+                              CURLAUTH_NEGOTIATE) &&
+                             (needle->handler->protocol & PROTO_FAMILY_HTTP)));
+#else
+  bool wantProxyNegoHTTP = FALSE;
+#endif
+#endif
+
   *force_reuse = FALSE;
   *waitpipe = FALSE;
 
@@ -1429,6 +1441,61 @@ ConnectionExists(struct Curl_easy *data,
           /* Continue look up for a better connection */
           continue;
         }
 #endif
+#ifdef USE_SPNEGO
+        /* If we are looking for an HTTP+Negotiate connection, check if this
+           is already authenticating with the right credentials. If not, keep
+           looking so that we can reuse Negotiate connections if possible. */
+        if(wantNegoHTTP) {
+          if(Curl_timestrcmp(needle->user, check->user) ||
+             Curl_timestrcmp(needle->passwd, check->passwd)) {
+            /* we prefer a credential match, but this is at least a connection
+               that can be reused and "upgraded" to Negotiate */
+            if(check->http_negotiate_state == GSS_AUTHNONE)
+              chosen = check;
+            continue;
+          }
+        }
+        else if(check->http_negotiate_state != GSS_AUTHNONE) {
+          /* Connection is using Negotiate auth but we don't want Negotiate */
+          continue;
+        }
+
+#ifndef CURL_DISABLE_PROXY
+        /* Same for Proxy Negotiate authentication */
+        if(wantProxyNegoHTTP) {
+          /* Both check->http_proxy.user and check->http_proxy.passwd can be
+           * NULL */
+          if(!check->http_proxy.user || !check->http_proxy.passwd)
+            continue;
+
+          if(Curl_timestrcmp(needle->http_proxy.user,
+                             check->http_proxy.user) ||
+             Curl_timestrcmp(needle->http_proxy.passwd,
+                             check->http_proxy.passwd))
+            continue;
+        }
+        else if(check->proxy_negotiate_state != GSS_AUTHNONE) {
+          /* Proxy connection is using Negotiate auth but we don't want it */
+          continue;
+        }
+#endif
+        if(wantNegoHTTP || wantProxyNegoHTTP) {
+          /* Credentials are already checked, we can use this connection */
+          chosen = check;
+
+          if((wantNegoHTTP &&
+             (check->http_negotiate_state != GSS_AUTHNONE)) ||
+              (wantProxyNegoHTTP &&
+               (check->proxy_negotiate_state != GSS_AUTHNONE))) {
+            /* We must use this connection, no other */
+            *force_reuse = TRUE;
+            break;
+          }
+
+          /* Continue look up for a better connection */
+          continue;
+        }
+#endif
         if(canmultiplex) {
           /* We can multiplex if we want to. Let's continue looking for
              the optimal connection to use. */
