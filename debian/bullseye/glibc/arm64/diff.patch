Description: Fix CVE-2026-5435: out-of-bounds write in ns_sprintrrf TSIG handling
 The deprecated functions ns_sprintrrf, ns_printrr and fp_nquery in the
 GNU C Library fail to enforce the caller-supplied buffer length. The
 ns_t_tsig case handler reads past the end of the rdata buffer without
 bounds checking and uses an unchecked sprintf to write to the output
 buffer, resulting in an out-of-bounds write when printing TSIG records.
 .
 This patch removes the incorrect and incomplete TSIG field parsing code
 that operated on rdata without bounds checks, retaining only the safe
 algorithm name extraction via addname. The remaining TSIG fields will
 fall through to the hexdump path. Additionally, all four unchecked
 inet_ntop calls are guarded against NULL return to prevent strlen on
 an unwritten buffer.
Origin: upstream, https://sourceware.org/pipermail/libc-alpha/2026-April/177042.html
Author: Florian Weimer <fweimer@redhat.com>
Last-Update: 2026-05-01

--- a/resolv/ns_print.c
+++ b/resolv/ns_print.c
@@ -141,7 +141,8 @@
 	case ns_t_a:
 	  if (rdlen != (size_t)NS_INADDRSZ)
 			goto formerr;
-		(void) inet_ntop(AF_INET, rdata, buf, buflen);
+		if (inet_ntop(AF_INET, rdata, buf, buflen) == NULL)
+			goto formerr;
 		addlen(strlen(buf), &buf, &buflen);
 		break;
 
@@ -309,7 +310,8 @@
 	case ns_t_aaaa:
 	  if (rdlen != (size_t)NS_IN6ADDRSZ)
 			goto formerr;
-		(void) inet_ntop(AF_INET6, rdata, buf, buflen);
+		if (inet_ntop(AF_INET6, rdata, buf, buflen) == NULL)
+			goto formerr;
 		addlen(strlen(buf), &buf, &buflen);
 		break;
 
@@ -400,7 +402,8 @@
 			goto formerr;
 
 		/* Address. */
-		(void) inet_ntop(AF_INET, rdata, buf, buflen);
+		if (inet_ntop(AF_INET, rdata, buf, buflen) == NULL)
+			goto formerr;
 		addlen(strlen(buf), &buf, &buflen);
 		rdata += NS_INADDRSZ;
 
@@ -510,17 +513,8 @@
 
 	case ns_t_tsig: {
 		/* BEW - need to complete this */
-		int n;
 
 		T(len = addname(msg, msglen, &rdata, origin, &buf, &buflen));
-		T(addstr(" ", 1, &buf, &buflen));
-		rdata += 8; /*%< time */
-		n = ns_get16(rdata); rdata += INT16SZ;
-		rdata += n; /*%< sig */
-		n = ns_get16(rdata); rdata += INT16SZ; /*%< original id */
-		sprintf(buf, "%d", ns_get16(rdata));
-		rdata += INT16SZ;
-		addlen(strlen(buf), &buf, &buflen);
 		break;
