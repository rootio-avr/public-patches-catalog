+    /* Detect and prevent signed integer overflow */
+    if (len == INT_MAX) {
+      return XML_ERROR_NO_MEMORY;
+    }
     if (isXML && (len > xmlLen || uri[len] != xmlNamespace[len]))
       isXML = XML_FALSE;

@@ -3878,8 +3882,13 @@
