   XmlwfUserData *data = (XmlwfUserData *)userData;
   NotationList **notations;
-  int notationCount = 0;
+  size_t notationCount = 0;
   NotationList *p;
-  int i;
+  size_t i;

   /* How many notations do we have? */
   for (p = data->notationListHead; p != NULL; p = p->next)
@@ -372,6 +372,14 @@
