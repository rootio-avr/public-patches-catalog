Description: CVE-2026-24515 - Fix NULL pointer dereference in external entity parsing
 In libexpat before 2.7.4, XML_ExternalEntityParserCreate does not copy
 the unknown encoding handler user data from the parent parser. This
 leads to a NULL pointer dereference when the handler is invoked on the
 external entity parser.
 .
 This patch adds the missing copy of m_unknownEncodingHandlerData to
 ensure the external entity parser has access to the same user data
 as the parent parser.
Origin: upstream, https://github.com/libexpat/libexpat/commit/86fc914
Author: Sebastian Pipping <sebastian@pipping.org>
Last-Update: 2026-02-01

--- a/expat/lib/xmlparse.c
+++ b/expat/lib/xmlparse.c
@@ -1176,6 +1176,7 @@ XML_ExternalEntityParserCreate(XML_Parse
   XML_ExternalEntityRefHandler oldExternalEntityRefHandler;
   XML_SkippedEntityHandler oldSkippedEntityHandler;
   XML_UnknownEncodingHandler oldUnknownEncodingHandler;
+  void *oldUnknownEncodingHandlerData;
   XML_ElementDeclHandler oldElementDeclHandler;
   XML_AttlistDeclHandler oldAttlistDeclHandler;
   XML_EntityDeclHandler oldEntityDeclHandler;
@@ -1220,6 +1221,7 @@ XML_ExternalEntityParserCreate(XML_Parse
   oldExternalEntityRefHandler = parser->m_externalEntityRefHandler;
   oldSkippedEntityHandler = parser->m_skippedEntityHandler;
   oldUnknownEncodingHandler = parser->m_unknownEncodingHandler;
+  oldUnknownEncodingHandlerData = parser->m_unknownEncodingHandlerData;
   oldElementDeclHandler = parser->m_elementDeclHandler;
   oldAttlistDeclHandler = parser->m_attlistDeclHandler;
   oldEntityDeclHandler = parser->m_entityDeclHandler;
@@ -1279,6 +1281,7 @@ XML_ExternalEntityParserCreate(XML_Parse
