Description: CVE-2026-32777 - Fix infinite loop in entityValueProcessor
 libexpat before 2.7.5 allows an infinite loop while parsing DTD content.
 The entityValueProcessor function in xmlparse.c is missing a rejection
 check for XML_TOK_INSTANCE_START tokens, which can cause denial of
 service by exhausting CPU resources. This patch adds the missing check,
 matching the identical pattern already present in entityValueInitProcessor.
Origin: upstream, https://github.com/libexpat/libexpat/commit/55cda8c7125986e17d7e1825cba413bd94a35d02
Author: Sebastian Pipping <sebastian@pipping.org>
Last-Update: 2026-03-17

--- a/expat/lib/xmlparse.c
+++ b/expat/lib/xmlparse.c
@@ -4021,7 +4021,7 @@
     }
     /* If we get this token, we have the start of what might be a
        normal tag, but not a declaration (i.e. it doesn't begin with
-       "<!").  In a DTD context, that isn't legal.
+       "<!" or "<?").  In a DTD context, that isn't legal.
     */
     else if (tok == XML_TOK_INSTANCE_START) {
       *nextPtr = next;
@@ -4099,6 +4099,15 @@
       /* found end of entity value - can store it now */
       return storeEntityValue(parser, enc, s, end);
     }
+    /* If we get this token, we have the start of what might be a
+       normal tag, but not a declaration (i.e. it doesn't begin with
+       "<!" or "<?").  In a DTD context, that isn't legal.
+    */
+    else if (tok == XML_TOK_INSTANCE_START) {
+      *nextPtr = next;
+      return XML_ERROR_SYNTAX;
+    }
+
     start = next;
   }
 }
Description: CVE-2026-25210 - Integer overflow check for tag buffer reallocation
 The doContent function in libexpat does not properly determine the buffer
 size bufSize because there is no integer overflow check for tag buffer
 reallocation, potentially leading to memory corruption.
 .
 This patch introduces an integer overflow check before the tag buffer
 reallocation to prevent potential memory corruption.
Origin: upstream, commit:9c2d990389e6abe2e44527eeaa8b39f16fe859c7
Author: Matthew Fernandez <matthew.fernandez@gmail.com>
Last-Update: 2025-10-02

--- a/expat/lib/xmlparse.c
+++ b/expat/lib/xmlparse.c
@@ -2753,6 +2753,8 @@ doContent(XML_Parser parser, int startTa
           || (convert_res == XML_CONVERT_INPUT_INCOMPLETE)) {
             tag->name.strLen = convLen;
             break;
           }
+          if (SIZE_MAX / 2 < (size_t)(tag->bufEnd - tag->buf))
+            return XML_ERROR_NO_MEMORY;
           bufSize = (int)(tag->bufEnd - tag->buf) << 1;
           {
             char *temp = (char *)REALLOC(parser, tag->buf, bufSize);
