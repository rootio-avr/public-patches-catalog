 Description: CVE-2026-56408 - Waterproof copyString from integer overflow
 An attacker able to influence the length of a string passed to
 copyString() in expat/lib/xmlparse.c could trigger an integer
 overflow that leads to an under-sized allocation and subsequent
 heap memory corruption (CWE-190).
 .
 Upstream commit 16e2efd8 adds a single guard on a size_t-typed
 length counter in libexpat 2.8.2:
 .
   if (charsRequired > SIZE_MAX / sizeof(XML_Char))
     return NULL;
 .
 Debian bullseye ships expat 2.2.10 whose copyString has a different
 signature (takes an XML_Memory_Handling_Suite* rather than an
 XML_Parser) and uses an int-typed length counter incremented in a
 while loop. Applying the upstream guard verbatim would be a no-op
 on 64-bit platforms because `int > SIZE_MAX / sizeof(XML_Char)` is
 trivially false.
 .
 This backport adapts the guard to the 2.2.10 API:
   1. Detect wrap-around of the int counter itself while walking the
      string (charsRequired < 0 after increment).
   2. Detect wrap-around after adding one for the null terminator.
   3. After promoting to size_t, detect multiplication overflow of
      `charsRequired * sizeof(XML_Char)` against SIZE_MAX.
 In each case copyString() returns NULL, mirroring the upstream
 failure semantics so callers already handling an allocation
 failure will handle an over-long input the same way.
Origin: backport, https://github.com/libexpat/libexpat/commit/16e2efd867ea8567ffa012210b52ef5918e20817
Bug: https://github.com/libexpat/libexpat/issues/1276
Bug-Debian: https://bugs.debian.org/1140557
Author: Sebastian Pipping <sebastian@pipping.org>
Last-Update: 2026-07-08
---
--- a/expat/lib/xmlparse.c
+++ b/expat/lib/xmlparse.c
@@ -6900,9 +6900,18 @@
   /* First determine how long the string is */
   while (s[charsRequired] != 0) {
     charsRequired++;
+    /* Detect and prevent integer overflow of the int counter */
+    if (charsRequired < 0)
+      return NULL;
   }
   /* Include the terminator */
   charsRequired++;
+  if (charsRequired < 0)
+    return NULL;
+
+  /* Detect and prevent size_t overflow in the allocation size */
+  if ((size_t)charsRequired > SIZE_MAX / sizeof(XML_Char))
+    return NULL;
 
   /* Now allocate space for the copy */
   result = memsuite->malloc_fcn(charsRequired * sizeof(XML_Char));
Description: CVE-2026-56131 - protect XML_ResumeParser from being called from a handler
 The handler-reentrancy guards introduced for CVE-2026-50219 cover XML_Parse,
 XML_ParseBuffer, XML_GetBuffer, XML_ParserFree and XML_ParserReset, but not
 XML_ResumeParser, which drives the parser through parser->m_processor() in
 the same way.  A handler is therefore free to call
 XML_StopParser(parser, XML_TRUE) and then re-enter the parser via
 XML_ResumeParser, triggering the same use-after-free class of issue
 addressed by CVE-2026-50219 (GHSA-fchf-wvcc-qf9g / libexpat commit d5a654b).
 .
 This backport reuses the isCalledFromInsideHandler() helper (plus the
 supporting m_handlerCallDepth field and beforeHandler/afterHandler
 wrappers) already installed by the sibling CVE-2026-50219 backport that
 sits earlier in this quilt series.  All that is needed on top is the
 single-line guard added by upstream commit d5a654b to XML_ResumeParser.
 .
 The upstream commit also adds regression tests in expat/tests/handlers.c,
 expat/tests/handlers.h and expat/tests/misc_tests.c.  None of those files
 exist in expat 2.2.10 as shipped in Debian bullseye (tests are consolidated
 in expat/tests/runtests.c), so the test is ported into runtests.c instead.
 .
 The xmlparse.c hunk is rediffed against the bullseye tree after the
 earlier queued CVE patches (notably CVE-2026-50219) have already been
 applied, so context line numbers differ from a pristine 2.2.10 tree.
Origin: backport, https://github.com/libexpat/libexpat/commit/d5a654b4881f450827af5b3b7b72370a3bbf9a8f
Bug: https://github.com/libexpat/libexpat/security/advisories/GHSA-fchf-wvcc-qf9g
Author: Sebastian Pipping <sebastian@pipping.org>
Last-Update: 2026-07-14
---
--- a/expat/lib/xmlparse.c
+++ b/expat/lib/xmlparse.c
@@ -2118,7 +2118,7 @@
 XML_ResumeParser(XML_Parser parser) {
   enum XML_Status result = XML_STATUS_OK;
 
-  if (parser == NULL)
+  if ((parser == NULL) || isCalledFromInsideHandler(parser))
     return XML_STATUS_ERROR;
   if (parser->m_parsingStatus.parsing != XML_SUSPENDED) {
     parser->m_errorCode = XML_ERROR_NOT_SUSPENDED;
--- a/expat/tests/runtests.c
+++ b/expat/tests/runtests.c
@@ -7425,6 +7425,67 @@
 }
 END_TEST
 
+/* Regression test for CVE-2026-56131: XML_ResumeParser must not be
+ * callable from inside a handler.  Without the guard in
+ * XML_ResumeParser, resuming from a suspended handler drives the
+ * parser re-entrantly and re-invokes the handler, which upstream
+ * addressed by rejecting the call outright.
+ */
+typedef struct {
+  XML_Parser parser;
+  int callCount;
+} ResumeFromHandlerData;
+
+static void XMLCALL
+suspend_then_resume_character_handler(void *userData, const XML_Char *s,
+                                      int len) {
+  ResumeFromHandlerData *data = (ResumeFromHandlerData *)userData;
+
+  UNUSED_P(s);
+  UNUSED_P(len);
+  data->callCount++;
+  if (data->callCount > 1) {
+    /* Reached only if the guard under test is missing: XML_ResumeParser
+       would then have driven the parser re-entrantly and called us
+       again.  Bail out so the test fails via the assertion below
+       rather than recursing without bound. */
+    return;
+  }
+
+  /* Put the parser into XML_SUSPENDED so that, without the guard,
+     XML_ResumeParser would proceed into a re-entrant parse. */
+  if (XML_StopParser(data->parser, /*resumable=*/XML_TRUE) != XML_STATUS_OK)
+    fail("XML_StopParser inside handler failed");
+
+  /* Resuming the parser from inside a handler must be rejected. */
+  if (XML_ResumeParser(data->parser) != XML_STATUS_ERROR)
+    fail("XML_ResumeParser was not rejected from inside a handler");
+}
+
+START_TEST(test_misc_resume_parser_forbidden_from_handler) {
+  const char *const doc = "<doc>Hello world!</doc>";
+  XML_Parser parser = XML_ParserCreate(NULL);
+  ResumeFromHandlerData data;
+
+  data.parser = parser;
+  data.callCount = 0;
+  XML_SetUserData(parser, &data);
+  XML_SetCharacterDataHandler(parser, suspend_then_resume_character_handler);
+
+  /* The handler suspends the parser, so the top-level parse reports
+     suspension rather than completion.  The handler also asserts that
+     resuming from inside itself is rejected. */
+  if (XML_Parse(parser, doc, (int)strlen(doc), /*isFinal=*/XML_TRUE)
+      != XML_STATUS_SUSPENDED)
+    fail("Expected top-level XML_Parse to report XML_STATUS_SUSPENDED");
+  if (data.callCount != 1)
+    fail("Character handler was re-entered (guard missing)");
+
+  XML_ParserFree(parser);
+}
+END_TEST
+
+
 /* Test parser created for UTF-16LE is successful */
 START_TEST(test_misc_utf16le) {
   const char text[] =
@@ -11510,6 +11571,7 @@
   tcase_add_test(tc_misc, test_misc_version);
   tcase_add_test(tc_misc, test_misc_features);
