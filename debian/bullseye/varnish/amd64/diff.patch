2.43.0

Description: CVE-2026-34475 - Handle absolute form with empty path
 A deficiency in HTTP/1.1 request parsing in Varnish Cache can be used
 for cache poisoning or authentication bypass when req.url is passed
 unchecked to a backend that accepts absolute form URIs. This patch
 normalizes absolute-form URIs with an empty path, including
 http://example.com and http://example.com?/foo.
Origin: upstream, https://github.com/varnishcache/varnish-cache/commit/f27e9550aa30ad18e5196371d583e7131745088e
Author: Nils Goroll <nils.goroll@uplex.de>
Last-Update: 2026-05-07

--- a/bin/varnishd/http1/cache_http1_proto.c
+++ b/bin/varnishd/http1/cache_http1_proto.c
@@ -356,6 +356,8 @@ HTTP1_DissectRequest(struct http_conn *htc, struct http *hp)
 	uint16_t retval;
 	const char *p;
 	const char *b = NULL, *e;
+	char c = '\0';
+	char *t;
 
 	CHECK_OBJ_NOTNULL(htc, HTTP_CONN_MAGIC);
 	CHECK_OBJ_NOTNULL(hp, HTTP_MAGIC);
@@ -375,11 +377,27 @@ HTTP1_DissectRequest(struct http_conn *htc, struct http *hp)
 	    !strncasecmp(hp->hd[HTTP_HDR_URL].b, "https://", 8))
 		b = hp->hd[HTTP_HDR_URL].b + 8;
 	if (b) {
-		e = strchr(b, '/');
-		if (e) {
-			http_Unset(hp, H_Host);
-			http_PrintfHeader(hp, "Host: %.*s", (int)(e - b), b);
-			hp->hd[HTTP_HDR_URL].b = e;
+		e = strpbrk(b, "/?");
+		if (e == NULL)
+			e = hp->hd[HTTP_HDR_URL].e;
+		else
+			c = *e;
+		if (e == b)
+			return (400);
+		http_Unset(hp, H_Host);
+		http_PrintfHeader(hp, "Host: %.*s", (int)(e - b), b);
+		hp->hd[HTTP_HDR_URL].b = e;
+		if (Tlen(hp->hd[HTTP_HDR_URL]) == 0) {
+			if (!strcasecmp(hp->hd[HTTP_HDR_METHOD].b, "options"))
+				hp->hd[HTTP_HDR_URL].b = "*";
+			else
+				hp->hd[HTTP_HDR_URL].b = "/";
+			hp->hd[HTTP_HDR_URL].e =
+			    hp->hd[HTTP_HDR_URL].b + 1;
+		} else if (c == '?') {
+			hp->hd[HTTP_HDR_URL].b--;
+			t = TRUST_ME(hp->hd[HTTP_HDR_URL].b);
+			*t = '/';
 		}
 	}
 
--- a/bin/varnishtest/tests/r01255.vtc
+++ b/bin/varnishtest/tests/r01255.vtc
@@ -9,6 +9,7 @@ varnish v1 -vcl+backend {
 
 	sub vcl_deliver {
 		set resp.http.rxhost = req.http.host;
+		set resp.http.url = req.url;
 	}
 } -start
 
@@ -16,4 +17,29 @@ client c1 {
 	txreq -url http://www.example.com/bar
 	rxresp
 	expect resp.http.rxhost == www.example.com
+	expect resp.http.url == /bar
+
+	txreq -url http://www.example.com -hdr "host: another"
+	rxresp
+	expect resp.status == 200
+	expect resp.http.rxhost == www.example.com
+	expect resp.http.url == /
+
+	txreq -url http://www.example.com?/foo -hdr "host: another"
+	rxresp
+	expect resp.status == 200
+	expect resp.http.rxhost == www.example.com
+	expect resp.http.url == /?/foo
+
+	txreq -req OPTIONS -url http://www.example.com -hdr "host: another"
+	rxresp
+	expect resp.status == 200
+	expect resp.http.rxhost == www.example.com
+	expect resp.http.url == *
+} -run
+
+client c2 {
+	txreq -url http:///bar -hdr "host: another"
+	rxresp
+	expect resp.status == 400
 } -run
