Description: Fix heap-buffer-overflow in grid tile compositing for 4:2:0 chroma
 When copying tile pixel data to the output image for chroma-subsampled (4:2:0)
 channels with odd tile sizes, the copy size calculation can exceed the allocated
 plane buffer. This is because get_subsampled_size(y0) + get_subsampled_size(h-y0)
 can exceed get_subsampled_size(h) due to ceiling-division rounding. Fix by using
 get_subsampled_size() to compute proper subsampled offsets and plane dimensions,
 then clamping copy size to (plane_size - offset).
Origin: upstream, https://github.com/strukturag/libheif/commit/23903961e1237ecdb0779a65b423cb75f524d254
Author: Dirk Farin <dirk.farin@gmail.com>
Last-Update: 2026-05-21

--- a/libheif/heif_context.cc
+++ b/libheif/heif_context.cc
@@ -1561,15 +1561,27 @@
     }
 
-    int copy_width = std::min(src_width, w - x0);
-    int copy_height = std::min(src_height, h - y0);
-
-    copy_width *= tile_img->get_storage_bits_per_pixel(heif_channel_R) / 8;
-
-    int xs = x0, ys = y0;
-    xs *= tile_img->get_storage_bits_per_pixel(heif_channel_R) / 8;
-
-    for (int py = 0; py < copy_height; py++) {
-      memcpy(out_data + xs + (ys + py) * out_stride,
+    // Use subsampled dimensions to avoid chroma rounding mismatch OOB write.
+    // For 4:2:0 chroma with odd tile sizes, get_subsampled_size(y0) +
+    // get_subsampled_size(h - y0) can exceed get_subsampled_size(h) due to
+    // ceiling division, so we clamp to (plane_size - offset) instead.
+    int sub_x0, sub_y0;
+    get_subsampled_size(x0, y0, channel, chroma, &sub_x0, &sub_y0);
+
+    int plane_w, plane_h;
+    get_subsampled_size(w, h, channel, chroma, &plane_w, &plane_h);
+
+    int sub_src_w, sub_src_h;
+    get_subsampled_size(src_width, src_height, channel, chroma, &sub_src_w, &sub_src_h);
+
+    int copy_width = std::min(sub_src_w, plane_w - sub_x0);
+    int copy_height = std::min(sub_src_h, plane_h - sub_y0);
+
+    int bytes_per_pixel = tile_img->get_storage_bits_per_pixel(heif_channel_R) / 8;
+    copy_width *= bytes_per_pixel;
+    int xs = sub_x0 * bytes_per_pixel;
+
+    for (int py = 0; py < copy_height; py++) {
+      memcpy(out_data + xs + (sub_y0 + py) * out_stride,
              tile_data + py * tile_stride,
              copy_width);
     }
