Description: CVE-2026-6479 - Fix unbounded recursion in SSL/GSS negotiation
 A malicious client could alternate rejected SSL and GSS requests
 indefinitely, each adding a stack frame to ProcessStartupPacket(),
 until the backend crashed with a stack overflow. This converts the
 recursive call pattern into an iterative one using a goto loop.
Origin: upstream, https://git.postgresql.org/gitweb/?p=postgresql.git;a=commit;h=3b4e66739aa5bad84ad439ab9776e3b8dc4ef290
Author: PostgreSQL Global Development Group
Last-Update: 2026-05-20

--- a/src/backend/postmaster/postmaster.c
+++ b/src/backend/postmaster/postmaster.c
@@ -1948,6 +1948,7 @@
 	ProtocolVersion proto;
 	MemoryContext oldcontext;

+retry:
 	pq_startmsgread();

 	/*
@@ -2078,9 +2079,18 @@
 		/*
 		 * regular startup packet, cancel, etc packet should follow, but not
 		 * another SSL negotiation request, and a GSS request should only
-		 * follow if SSL was rejected (client may negotiate in either order)
+		 * follow if SSL was rejected (client may negotiate in either order).
 		 */
-		return ProcessStartupPacket(port, true, SSLok == 'S');
+		ssl_done = true;
+		if (SSLok == 'S')
+		{
+			/*
+			 * We are done with SSL and negotiated correctly, so consider the
+			 * same for GSS.
+			 */
+			gss_done = true;
+		}
+		goto retry;
 	}
 	else if (proto == NEGOTIATE_GSS_CODE && !gss_done)
 	{
@@ -2122,9 +2132,18 @@
 		/*
 		 * regular startup packet, cancel, etc packet should follow, but not
 		 * another GSS negotiation request, and an SSL request should only
-		 * follow if GSS was rejected (client may negotiate in either order)
+		 * follow if GSS was rejected (client may negotiate in either order).
 		 */
-		return ProcessStartupPacket(port, GSSok == 'G', true);
+		gss_done = true;
+		if (GSSok == 'G')
+		{
+			/*
+			 * We are done with GSS and negotiated correctly, so consider the
+			 * same for SSL.
+			 */
+			ssl_done = true;
+		}
+		goto retry;
 	}

 	/* Could add additional special packet types here */
