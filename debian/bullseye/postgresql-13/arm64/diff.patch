+
+/*
+ * Support for safe calculation of memory request sizes
+ *
+ * These functions perform the requested multiplication, but throw error
+ * if the result overflows size_t.
+ */
+static void
+mul_size_error(Size s1, Size s2) pg_attribute_noreturn();
+
+static void
+mul_size_error(Size s1, Size s2)
+{
+	ereport(ERROR,
+			(errcode(ERRCODE_PROGRAM_LIMIT_EXCEEDED),
+			 errmsg("invalid memory allocation request size %zu * %zu",
+					s1, s2)));
+}
+
+/*
+ * palloc_mul
+ *		Equivalent to palloc(s1 * s2), with overflow check.
+ */
+void *
+palloc_mul(Size s1, Size s2)
+{
+	Size		req;
+
+	if (unlikely(pg_mul_size_overflow(s1, s2, &req)))
+		mul_size_error(s1, s2);
+	return palloc(req);
+}
+
+/*
+ * palloc0_mul
+ *		Equivalent to palloc0(s1 * s2), with overflow check.
+ */
+void *
+palloc0_mul(Size s1, Size s2)
+{
+	Size		req;
+
+	if (unlikely(pg_mul_size_overflow(s1, s2, &req)))
+		mul_size_error(s1, s2);
+	return palloc0(req);
+}
+
+/*
+ * palloc_mul_extended
+ *		Equivalent to palloc_extended(s1 * s2, flags), with overflow check.
+ */
+void *
+palloc_mul_extended(Size s1, Size s2, int flags)
+{
+	Size		req;
+
+	if (unlikely(pg_mul_size_overflow(s1, s2, &req)))
+		mul_size_error(s1, s2);
+	return palloc_extended(req, flags);
+}
+
+/*
+ * repalloc_mul
+ *		Equivalent to repalloc(p, s1 * s2), with overflow check.
+ */
+void *
+repalloc_mul(void *p, Size s1, Size s2)
+{
+	Size		req;
+
+	if (unlikely(pg_mul_size_overflow(s1, s2, &req)))
+		mul_size_error(s1, s2);
+	return repalloc(p, req);
 }
