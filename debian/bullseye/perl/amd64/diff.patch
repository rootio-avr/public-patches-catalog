+++ b/cpan/IO-Compress/lib/IO/Uncompress/Unzip.pm
@@ -144,8 +144,8 @@
 
     while ($offset > 0)
     {
-        $c = length $offset
-            if length $offset < $c ;
+        $c = $offset
+            if $offset < $c ;
 
