Description: CVE-2026-42497 - Validate hardlink linkname in SECURE MODE
 Archive::Tar before 3.08 forwards tar header linkname to link() without
 rejecting absolute paths or '..' traversal segments. An attacker-crafted
 archive can create a hardlink to a victim file outside the extract
 directory; the post-extraction chmod/chown/utime then mutates the victim
 inode. This patch validates hardlink linkname against absolute paths and
 parent-directory traversal in SECURE MODE.
Origin: upstream, https://github.com/jib/archive-tar-new/commit/17c873492a05eddc0de18c1485e0b2cccd5a9158
Author: Jos Boumans <jib@cpan.org>
Last-Update: 2026-05-28
---
--- a/cpan/Archive-Tar/lib/Archive/Tar.pm
+++ b/cpan/Archive-Tar/lib/Archive/Tar.pm
@@ -957,6 +970,23 @@ sub _make_special_file {
                 $entry->linkname .q[' failed] if $fail;

     } elsif ( $entry->is_hardlink ) {
+        if( !$INSECURE_EXTRACT_MODE ) {
+            my $linkname = $entry->linkname;
+            if( File::Spec->file_name_is_absolute($linkname) ) {
+                $self->_error( qq[Hardlink '] . $entry->full_path .
+                    qq[' has absolute target '$linkname'. Not extracting ] .
+                    qq[under SECURE EXTRACT MODE: extraction itself chmods ] .
+                    qq[the shared inode.] );
+                return;
+            }
+            if( grep { $_ eq '..' } File::Spec->splitdir($linkname) ) {
+                $self->_error( qq[Hardlink '] . $entry->full_path .
+                    qq[' target '$linkname' attempts traversal. Not ] .
+                    qq[extracting under SECURE EXTRACT MODE: extraction ] .
+                    qq[itself chmods the shared inode.] );
+                return;
+            }
+        }
         my $fail;
         if( ON_UNIX ) {
             link( $entry->linkname, $file ) or $fail++;
