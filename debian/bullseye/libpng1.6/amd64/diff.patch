Description: Fix CVE-2026-40930: Consume chunk body in APNG push-mode discard paths
 Three inter-frame discard paths in png_push_read_chunk cleared
 PNG_HAVE_CHUNK_HEADER without consuming the chunk body and CRC.
 On the next png_process_data call, unconsumed attacker-controlled
 bytes inside an ignored ancillary chunk were reinterpreted as a
 fresh chunk header (chunk smuggling).
 .
 Backport of upstream faf0692 for Debian's libpng-1.6.37-apng patch:
 - Call png_crc_finish() on trailing-IDAT and ignored-chunk discard
   paths before clearing the chunk-header flag.
 - Restructure the trailing-fdAT path to check PNG_HAVE_fcTL before
   reading the sequence number, and consume body+CRC on discard.
 .
 Also include sibling fix 9ec49c2 (issue #854): pass push_length to
 png_ensure_sequence_number in png_push_read_IDAT so short fdAT
 chunks are rejected (prevents integer underflow of idat_size).
 Upstream recommends both commits for libpng-apng consumers.
Origin: backport, https://github.com/pnggroup/libpng/commit/faf06924688b62d7c1654b5ceddedbde66ffadb4
Origin: backport, https://github.com/pnggroup/libpng/commit/9ec49c2d56cec19107ddc458b648ce224c9697b3
Bug: https://github.com/pnggroup/libpng/security/advisories/GHSA-c4v6-gxrq-6g2x
Bug: https://github.com/pnggroup/libpng/issues/854
Author: Cosmin Truta <ctruta@gmail.com>
Last-Update: 2026-07-20

--- a/pngpread.c
+++ b/pngpread.c
@@ -211,19 +211,12 @@
             return;
          }
 
+         png_crc_finish(png_ptr, png_ptr->push_length);
          png_ptr->mode &= ~PNG_HAVE_CHUNK_HEADER;
          return;
       }
       else if (chunk_name == png_fdAT)
       {
-         if (png_ptr->buffer_size < 4)
-         {
-            png_push_save_buffer(png_ptr);
-            return;
-         }
-
-         png_ensure_sequence_number(png_ptr, 4);
-
          if (!(png_ptr->mode & PNG_HAVE_fcTL))
          {
             /* Discard trailing fdATs for frames other than the first */
@@ -236,6 +229,8 @@
                return;
             }
 
+            png_ensure_sequence_number(png_ptr, png_ptr->push_length);
+            png_crc_finish(png_ptr, png_ptr->push_length - 4);
             png_ptr->mode &= ~PNG_HAVE_CHUNK_HEADER;
             return;
          }
@@ -243,6 +238,13 @@
          else
          {
             /* frame data follows */
+            if (png_ptr->buffer_size < 4)
+            {
+               png_push_save_buffer(png_ptr);
+               return;
+            }
+
+            png_ensure_sequence_number(png_ptr, png_ptr->push_length);
             png_ptr->idat_size = png_ptr->push_length - 4;
             png_ptr->mode |= PNG_HAVE_IDAT;
             png_ptr->process_mode = PNG_READ_IDAT_MODE;
@@ -287,6 +289,7 @@
          }
          png_warning(png_ptr, "Skipped (ignored) a chunk "
                               "between APNG chunks");
+         png_crc_finish(png_ptr, png_ptr->push_length);
          png_ptr->mode &= ~PNG_HAVE_CHUNK_HEADER;
          return;
       }
@@ -732,7 +735,7 @@
 #ifdef PNG_READ_APNG_SUPPORTED
       if (png_ptr->num_frames_read > 0)
       {
-         png_ensure_sequence_number(png_ptr, 4);
+         png_ensure_sequence_number(png_ptr, png_ptr->push_length);
          png_ptr->idat_size -= 4;
       }
 #endif

