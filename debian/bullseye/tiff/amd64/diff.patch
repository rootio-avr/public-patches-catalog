Description: CVE-2025-8177 - Fix buffer overflow in setrow() in tools/thumbnail.c
 The expression (255*acc)/area in setrow() can exceed 255, causing an
 out-of-bounds read on the cmap array. This patch adds a bounds check
 to ensure the index does not exceed 255, and assigns a safe default
 value (cmap[0]) when it does. Adapted from upstream fix for v4.2.0
 which lacked the intermediate bounds-checking block.
Origin: upstream, https://gitlab.com/libtiff/libtiff/-/commit/e8c9d6c616b19438695fd829e58ae4fde5bfbc22
Author: Lee Howard <faxguy@howardsilvan.com>
Last-Update: 2025-06-23

--- a/tools/thumbnail.c
+++ b/tools/thumbnail.c
@@ -545,6 +545,14 @@
 	    }
 	    acc += bits[*src & mask1];
 	}
-	*row++ = cmap[(255*acc)/area];
+	if (255 * acc / area < 256)
+	{
+	    *row++ = cmap[(255*acc)/area];
+	}
+	else
+	{
+	    fprintf(stderr, "acc=%d, area=%d\n", acc, area);
+	    *row++ = cmap[0];
+	}
     }
 }
