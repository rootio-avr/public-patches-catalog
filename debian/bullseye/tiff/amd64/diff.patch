Description: CVE-2025-61144 - Fix buffer overflow in combineSeparateSamplesBytes
 tiffcrop: avoid buffer overflow in combineSeparateSamplesBytes by adding
 a MAX_SAMPLES bounds check to the debug dump loop. An attacker can craft
 a malicious TIFF file where spp exceeds MAX_SAMPLES (8), causing
 out-of-bounds access to the srcbuffs[] array.
Origin: upstream, https://gitlab.com/libtiff/libtiff/-/commit/88cf9dbb48f6e172629795ecffae35d5052f68aa
Author: Lee Howard <faxguy@howardsilvan.com>
Last-Update: 2026-02-24

--- a/tools/tiffcrop.c
+++ b/tools/tiffcrop.c
@@ -3785,7 +3785,7 @@
     {
     if ((dumpfile != NULL) && (level == 2))
       {
-      for (s = 0; s < spp; s++)
+      for (s = 0; (s < spp) && (s < MAX_SAMPLES); s++)
         {
         dump_info (dumpfile, format, "combineSeparateSamplesBytes","Input data, Sample %d", s);
         dump_buffer(dumpfile, format, 1, cols, row, srcbuffs[s] + (row * src_rowsize));
Description: CVE-2025-8176 - Fix use-after-free and off-by-one errors in tiffmedian and tiffdither
 A use-after-free vulnerability in LibTIFF up to 4.7.0 affects the
 get_histogram function of tools/tiffmedian.c. Processing a specially
 crafted TIFF file can trigger memory corruption. This patch combines
 three upstream fixes:
 1. Changes break to exit(EXIT_FAILURE) on TIFFReadScanline error in
    get_histogram() to prevent use-after-free (commit ce46f002).
 2. Fixes off-by-one loop start (i=1 to i=0) in tiffmedian.c and
    tiffdither.c so the first scanline is not skipped (commit 3994cf3b).
 3. Fixes boundary condition (i <= imagelength to i < imagelength) in
    tiffmedian.c quant_fsdither to prevent out-of-bounds access
    (commit ecc4ddbf).
Origin: upstream, https://gitlab.com/libtiff/libtiff/-/commit/ce46f002eca4148497363f80fab33f9396bcbeda
Author: Lee Howard <faxguy@howardsilvan.com>
Last-Update: 2026-02-15

--- a/tools/tiffmedian.c
+++ b/tools/tiffmedian.c
@@ -377,7 +377,10 @@
 	}
 	for (i = 0; i < imagelength; i++) {
 		if (TIFFReadScanline(in, inputline, i, 0) <= 0)
-			break;
+		{
+			fprintf(stderr, "Error reading scanline\n");
+			exit(EXIT_FAILURE);
+		}
 		inptr = inputline;
 		for (j = imagewidth; j-- > 0;) {
 			red = (*inptr++) & 0xff >> COLOR_SHIFT;
@@ -836,7 +839,7 @@
 	outline = (unsigned char *) _TIFFmalloc(TIFFScanlineSize(out));
 
 	GetInputLine(in, 0, goto bad);		/* get first line */
-	for (i = 1; i <= imagelength; ++i) {
+	for (i = 0; i < imagelength; ++i) {
 		SWAP(short *, thisline, nextline);
 		lastline = (i >= imax);
 		if (i <= imax)
@@ -907,7 +910,7 @@
 				nextptr += 3;
 			}
 		}
-		if (TIFFWriteScanline(out, outline, i-1, 0) < 0)
+		if (TIFFWriteScanline(out, outline, i, 0) < 0)
 			break;
 	}
 bad:
--- a/tools/tiffdither.c
+++ b/tools/tiffdither.c
@@ -98,7 +98,7 @@
 	nextptr = nextline;
 	for (j = 0; j < imagewidth; ++j)
 		*nextptr++ = *inptr++;
-	for (i = 1; i < imagelength; ++i) {
+	for (i = 0; i < imagelength; ++i) {
 		tmpptr = thisline;
 		thisline = nextline;
 		nextline = tmpptr;
@@ -141,7 +141,7 @@
 					nextptr[0] += v / 16;
 			}
 		}
-		if (TIFFWriteScanline(out, outline, i-1, 0) < 0)
+		if (TIFFWriteScanline(out, outline, i, 0) < 0)
 			goto skip_on_error;
 	}
 	goto exit_label;
