Description: CVE-2026-50256 - Fix stack-based buffer overflow in font alias resolution
 XLFDMAXFONTNAMELEN was 256 bytes, but libXfont2 defines MAXFONTNAMELEN as 1024
 and allows font names and alias targets up to that length in fonts.alias files.
 doListFontsAndAliases and doListFontsWithInfo copied the resolved alias target
 into a stack-allocated buffer of XLFDMAXFONTNAMELEN bytes; an alias target of
 257-1023 bytes overflowed the stack buffer.
 .
 Increase XLFDMAXFONTNAMELEN from 256 to 1024 to match libXfont2, and add
 explicit bounds checks before the memcpy/memmove of the resolved name so
 the server safely rejects oversized aliases instead of corrupting the stack.
Origin: upstream, https://gitlab.freedesktop.org/xorg/xserver/-/commit/bb5158f962dc935e58ef8b4b5fcb31be201a6e07
Author: Peter Hutterer <peter.hutterer@who-t.net>
Last-Update: 2026-06-06
---
--- a/include/closestr.h
+++ b/include/closestr.h
@@ -57,7 +57,12 @@ typedef struct _OFclosure {

 /* ListFontsWithInfo */

-#define XLFDMAXFONTNAMELEN	256
+/* libXfont2 allows font names/aliases up to MAXFONTNAMELEN (1024) bytes in
+ * fonts.alias files.  The server's pattern buffers must be large enough to
+ * hold resolved alias targets returned by the font library.
+ * ZDI-CAN-30136
+ */
+#define XLFDMAXFONTNAMELEN	1024
 typedef struct _LFWIstate {
     char pattern[XLFDMAXFONTNAMELEN];
     int patlen;
--- a/dix/dixfonts.c
+++ b/dix/dixfonts.c
@@ -671,6 +671,10 @@ doListFontsAndAliases(ClientPtr client, LFclosurePtr c)
                  * is BadFontName, indicating the alias resolution
                  * is complete.
                  */
+                if (resolvedlen > XLFDMAXFONTNAMELEN) {
+                    err = BadFontName;
+                    goto ContBadFontName;
+                }
                 memmove(tmp_pattern, resolved, resolvedlen);
                 if (c->haveSaved) {
                     char *tmpname;
@@ -934,6 +938,10 @@ doListFontsWithInfo(ClientPtr client, LFWIclosurePtr c)
                     memmove(c->savedName, name, namelen + 1);
                 aliascount = 20;
             }
+            if (namelen > XLFDMAXFONTNAMELEN) {
+                err = BadFontName;
+                goto ContBadFontName;
+            }
             memmove(c->current.pattern, name, namelen);
             c->current.patlen = namelen;
             c->current.max_names = 1;
Description: Fix CVE-2026-50264 out-of-bounds heap write in DRI2 do_get_buffers
 A client requesting multiple DRI2BufferBackLeft attachments plus a
 DRI2BufferFrontLeft can cause do_get_buffers() to write past the end of
 the buffers array because attachments are not deduplicated before the
 array is sized.
 .
 This patch combines two upstream commits:
   * b7aa65cc3bb11b792ce2a3f511ba9b863acb11c8 -- companion refactor that
     converts the (fake) front-buffer tracking to booleans so duplicate
     attachment requests no longer corrupt the counters.
   * 339c279514326134b0878fc23ce6e9520440ce7f -- the primary fix, which
     deduplicates attachments using a bit-set, rejects attachment values
     above DRI2BufferHiz, caps the count argument, and bounds the
     buffers array allocation by min(count, DRI2BufferHiz) + 1.
 .
 The companion commit's pre-image matches xorg-server 1.20.11 byte-for-byte
 in do_get_buffers, so the combined diff applies cleanly to bullseye.
Origin: upstream, https://gitlab.freedesktop.org/xorg/xserver/-/commit/b7aa65cc3bb11b792ce2a3f511ba9b863acb11c8
Origin: upstream, https://gitlab.freedesktop.org/xorg/xserver/-/commit/339c279514326134b0878fc23ce6e9520440ce7f
Bug: https://gitlab.freedesktop.org/xorg/xserver/-/merge_requests/2228
Author: Michel Dänzer <mdaenzer@redhat.com>
Last-Update: 2026-06-06

