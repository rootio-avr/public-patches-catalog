Description: CVE-2026-33999 - Fix buffer re-use in _XkbSetCompatMap
 If the "compat" buffer has previously been truncated, there will be
 unused space in the buffer. The code uses this space, but does not
 update the number of valid entries in the buffer.
 .
 In the best case, this leads to the new compat entries being ignored.
 In the worst case, if there are any "skipped" compat entries, the
 number of valid entries will be corrupted, potentially leading to a
 buffer read overrun when processing a future request.
 .
 Set the number of used "compat" entries when re-using previously
 allocated space in the buffer.
Origin: upstream, https://gitlab.freedesktop.org/xorg/xserver/-/commit/b024ae1749ee58c6fbf863b9a1f5dc440fee2e1b
Author: Peter Harris <pharris2@rocketsoftware.com>
Last-Update: 2026-01-15

--- a/xkb/xkb.c
+++ b/xkb/xkb.c
@@ -3003,7 +3003,7 @@ _XkbSetCompatMap(ClientPtr client, DeviceIntPtr dev,
                 return BadAlloc;
             }
         }
-        else if (req->truncateSI) {
+        else if (req->truncateSI || req->firstSI + req->nSI > compat->num_si) {
             compat->num_si = req->firstSI + req->nSI;
         }
         sym = &compat->sym_interpret[req->firstSI];
Description: CVE-2026-50256 - Fix stack-based buffer overflow in font alias resolution
 XLFDMAXFONTNAMELEN was 256 bytes, but libXfont2 defines MAXFONTNAMELEN as 1024
 and allows font names and alias targets up to that length in fonts.alias files.
 doListFontsAndAliases and doListFontsWithInfo copied the resolved alias target
 into a stack-allocated buffer of XLFDMAXFONTNAMELEN bytes; an alias target of
 257-1023 bytes overflowed the stack buffer.
 .
 Increase XLFDMAXFONTNAMELEN from 256 to 1024 to match libXfont2, and add
 explicit bounds checks before the memcpy/memmove of the resolved name so
 the server safely rejects oversized aliases instead of corrupting the stack.
Origin: upstream, https://gitlab.freedesktop.org/xorg/xserver/-/commit/bb5158f962dc935e58ef8b4b5fcb31be201a6e07
Author: Peter Hutterer <peter.hutterer@who-t.net>
Last-Update: 2026-06-06
---
--- a/include/closestr.h
+++ b/include/closestr.h
@@ -57,7 +57,12 @@ typedef struct _OFclosure {

 /* ListFontsWithInfo */

-#define XLFDMAXFONTNAMELEN	256
+/* libXfont2 allows font names/aliases up to MAXFONTNAMELEN (1024) bytes in
+ * fonts.alias files.  The server's pattern buffers must be large enough to
+ * hold resolved alias targets returned by the font library.
+ * ZDI-CAN-30136
+ */
+#define XLFDMAXFONTNAMELEN	1024
 typedef struct _LFWIstate {
     char pattern[XLFDMAXFONTNAMELEN];
     int patlen;
--- a/dix/dixfonts.c
+++ b/dix/dixfonts.c
@@ -671,6 +671,10 @@ doListFontsAndAliases(ClientPtr client, LFclosurePtr c)
                  * is BadFontName, indicating the alias resolution
                  * is complete.
                  */
+                if (resolvedlen > XLFDMAXFONTNAMELEN) {
+                    err = BadFontName;
+                    goto ContBadFontName;
+                }
                 memmove(tmp_pattern, resolved, resolvedlen);
                 if (c->haveSaved) {
                     char *tmpname;
@@ -934,6 +938,10 @@ doListFontsWithInfo(ClientPtr client, LFWIclosurePtr c)
                     memmove(c->savedName, name, namelen + 1);
                 aliascount = 20;
             }
+            if (namelen > XLFDMAXFONTNAMELEN) {
+                err = BadFontName;
+                goto ContBadFontName;
+            }
             memmove(c->current.pattern, name, namelen);
             c->current.patlen = namelen;
             c->current.max_names = 1;
Description: CVE-2026-34000 already fixed in Debian bullseye-security
 Debian xorg-server 2:1.20.11-1+deb11u17 already carries request-length
 validation for XkbSetGeometry in
 debian/patches/09_xkb-add-request-length-validation-for-XkbSetGeometry.patch.
 The original local patch duplicated the key-alias bounds check in xkb/xkb.c
 before Debian's quilt stack was applied, causing that Debian patch's final
 hunk to fail during the package build.
 .
 This marker patch keeps the os-patcher CVE entry applicable for this source
 version without reapplying already-present code changes.
Author: Root.io
Last-Update: 2026-06-10
---
--- /dev/null
+++ b/ROOT-CVE-2026-34000.md
@@ -0,0 +1,8 @@
+# CVE-2026-34000
+
+Debian bullseye-security xorg-server `2:1.20.11-1+deb11u17` already carries
+the XkbSetGeometry request-length validation in
+`debian/patches/09_xkb-add-request-length-validation-for-XkbSetGeometry.patch`.
+
+This marker file prevents the local patch series from reapplying the same
+`xkb/xkb.c` key-alias bounds check before Debian's quilt stack runs.
Description: CVE-2026-34001 - Fix use-after-free in miSyncTriggerFence()
 When walking the list of fences to trigger, miSyncTriggerFence() may
 call TriggerFired() for the current trigger, which ends up calling
 SyncAwaitTriggerFired(). SyncAwaitTriggerFired() frees the entire
 await resource, which removes all triggers from that await - including
 pNext which may be another trigger from the same await attached to
 the same fence. On the next iteration, ptl = pNext points to freed
 memory. To avoid the issue, restart the iteration from the beginning
 of the list each time a trigger fires, since the callback can modify
 the list.
Origin: upstream, https://gitlab.freedesktop.org/xorg/xserver/-/commit/f19ab94ba9c891d801231654267556dc7f32b5e0
Author: Olivier Fourdan <ofourdan@redhat.com>
Last-Update: 2026-04-25

--- a/miext/sync/misync.c
+++ b/miext/sync/misync.c
@@ -131,16 +131,22 @@ miSyncDestroyFence(SyncFence * pFence)
 void
 miSyncTriggerFence(SyncFence * pFence)
 {
-    SyncTriggerList *ptl, *pNext;
+    SyncTriggerList *ptl;
+    Bool triggered;

     pFence->funcs.SetTriggered(pFence);

     /* run through triggers to see if any fired */
-    for (ptl = pFence->sync.pTriglist; ptl; ptl = pNext) {
-        pNext = ptl->next;
-        if ((*ptl->pTrigger->CheckTrigger) (ptl->pTrigger, 0))
-            (*ptl->pTrigger->TriggerFired) (ptl->pTrigger);
-    }
+    do {
+        triggered = FALSE;
+        for (ptl = pFence->sync.pTriglist; ptl; ptl = ptl->next) {
+            if ((*ptl->pTrigger->CheckTrigger) (ptl->pTrigger, 0)) {
+                (*ptl->pTrigger->TriggerFired) (ptl->pTrigger);
+                triggered = TRUE;
+                break;
+            }
+        }
+    } while (triggered);
 }

 SyncScreenFuncsPtr
Description: CVE-2026-34003 - Add bound checking in XKB request validation
