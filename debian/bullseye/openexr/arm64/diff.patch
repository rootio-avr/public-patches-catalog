Description: Fix CVE-2026-41142 - integer overflow in ImageChannel::resize
 ImageChannel::resize() computed _numPixels as the product of two int
 values without overflow checking and without validating that the
 sampling rates were positive. With crafted dimensions the multiplication
 could overflow size_t (or invoke undefined behavior with zero/negative
 sampling), leading to under-sized buffer allocations and subsequent
 out-of-bounds writes.
 .
 This patch reproduces the upstream fix:
   * Reject _xSampling < 1 or _ySampling < 1 with ArgExc up front so the
     subsequent modulo and division operations are well-defined.
   * Compute _numPixels in uint64_t and throw ArgExc when the product
     would exceed size_t's range.
 .
 The accompanying upstream test (testImageChannel) is added under
 OpenEXR/IlmImfUtilTest/ to validate the new sampling-rate checks.
Origin: upstream, https://github.com/AcademySoftwareFoundation/openexr/commit/0592ee539f33c122c90f09238579b902d838afb4
Author: OpenEXR Project Contributors
Last-Update: 2026-05-27

--- a/OpenEXR/IlmImfUtil/ImfImageChannel.cpp
+++ b/OpenEXR/IlmImfUtil/ImfImageChannel.cpp
@@ -41,6 +41,9 @@
 #include "ImfImageChannel.h"
 #include "ImfImageLevel.h"
 #include <Iex.h>
+
+#include <cstdint>
+#include <limits>

 using namespace IMATH_NAMESPACE;
 using namespace IEX_NAMESPACE;
@@ -83,6 +86,13 @@
 void
 ImageChannel::resize ()
 {
+    if (_xSampling < 1 || _ySampling < 1)
+    {
+        throw ArgExc (
+            "The x and y sampling rates for an image channel must be at "
+            "least 1.");
+    }
+
     const Box2i& dataWindow = level().dataWindow();

     if (dataWindow.min.x % _xSampling || dataWindow.min.y % _ySampling)
@@ -104,7 +114,17 @@

     _pixelsPerRow =    width  / _xSampling;
     _pixelsPerColumn = height / _ySampling;
-    _numPixels = _pixelsPerRow * _pixelsPerColumn;
+
+    const uint64_t w64 = static_cast<uint64_t> (_pixelsPerRow);
+    const uint64_t h64 = static_cast<uint64_t> (_pixelsPerColumn);
+    const uint64_t maxPixels =
+        static_cast<uint64_t> (std::numeric_limits<size_t>::max ());
+    if (w64 != 0 && h64 > maxPixels / w64)
+    {
+        throw ArgExc ("Image channel dimensions too large.");
+    }
+
+    _numPixels = static_cast<size_t> (w64 * h64);
 }


