+        Box2i tileRange = OPENEXR_IMF_INTERNAL_NAMESPACE::dataWindowForTile (
+            ifd->tileDesc, ifd->minX, ifd->maxX, ifd->minY, ifd->maxY,
+            dx, dy, lx, ly);
+        size_t expectedSize = ifd->bytesPerPixel *
+            static_cast<size_t>((tileRange.max.x - tileRange.min.x + 1) *
+                               (tileRange.max.y - tileRange.min.y + 1));
+        if (static_cast<size_t>(dataSize) != expectedSize)
+            throw IEX_NAMESPACE::InputExc (
+                "Packed size does not match unpacked size for uncompressed tile data.");
+    }
+
+
     
