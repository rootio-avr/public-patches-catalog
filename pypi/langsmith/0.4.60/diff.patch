+        (["text/plain", "/etc/passwd"], True),  # list, str path (exploit shape)
+        (("text/plain", pathlib.Path("/etc/passwd")), True),  # tuple, Path
+        (["text/plain", pathlib.Path("/etc/passwd")], True),  # list, Path
+        (b"inline", False),  # bare bytes
