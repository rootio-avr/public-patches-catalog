+            dangerously_allow_filesystem=False,
+        )
+
+
+def test_reject_filesystem_attachments_allows_inline_bytes():
+    # Should not raise.
+    _reject_filesystem_attachments(
+        {"ok": ("text/plain", b"data")}, dangerously_allow_filesystem=False
+    )
+
+
