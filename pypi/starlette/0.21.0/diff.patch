Backport of upstream commit 764dab0dcfb9033d75442d7a359645c9f94648c6 to starlette 0.21.0.

CVE-2026-48710 / GHSA-86qp-5c8j-p5mr (BadHost): starlette did not validate
the HTTP Host header before using it to rebuild request.url. A malformed
Host header (containing /, ?, #, @, \, or space) could cause
request.url.path to diverge from scope["path"], allowing bypass of
middleware/endpoint security checks that rely on request.url.

This backport applies only the security-relevant changes to URL.__init__
in starlette/datastructures.py (a new _HOST_RE regex and an extra guard
on the host_header branch). The unrelated typing-import reorganization
from the upstream commit is intentionally not backported because target
0.21.0 still uses the older `import typing` style. The companion test
addition from tests/test_datastructures.py is omitted because the PyPI
sdist for starlette 0.21.0 does not ship the tests/ directory.

Origin: upstream, https://github.com/Kludex/starlette/commit/764dab0dcfb9033d75442d7a359645c9f94648c6

--- a/starlette/datastructures.py
+++ b/starlette/datastructures.py
@@ -1,3 +1,4 @@
+import re
 import tempfile
 import typing
 from collections.abc import Sequence
@@ -19,6 +20,9 @@ _KeyType = typing.TypeVar("_KeyType")
 # that is, you can't do `Mapping[str, Animal]()["fido"] = Dog()`
 _CovariantValueType = typing.TypeVar("_CovariantValueType", covariant=True)

+# Rejects Host header chars (/, ?, #, @, ...) that would let urlsplit produce a path differing from scope["path"].
+_HOST_RE = re.compile(r"^([a-z0-9.-]+|\[[a-f0-9]*:[a-f0-9.:]+\])(?::[0-9]+)?$", re.IGNORECASE)
+

 class URL:
     def __init__(
@@ -41,7 +45,7 @@ class URL:
                     host_header = value.decode("latin-1")
                     break

-            if host_header is not None:
+            if host_header is not None and _HOST_RE.fullmatch(host_header):
                 url = f"{scheme}://{host_header}{path}"
             elif server is None:
                 url = path
