         if name.startswith(prefix):
@@ -64,6 +67,12 @@ try:
     core = _ImagingFtNotInstalled()


+def _string_length_check(text):
+    if MAX_STRING_LENGTH is not None and len(text) > MAX_STRING_LENGTH:
+        msg = "too many characters in string"
+        raise ValueError(msg)
+
+
 _UNSPECIFIED = object()


