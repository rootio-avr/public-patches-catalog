@@ -696,6 +696,10 @@ class PyCodec:

         if extents:
             (x0, y0, x1, y1) = extents
+
+            if x0 < 0 or y0 < 0 or x1 > self.im.size[0] or y1 > self.im.size[1]:
+                msg = "Tile cannot extend outside image"
