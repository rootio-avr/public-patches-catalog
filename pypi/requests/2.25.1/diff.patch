+def _urllib3_request_context(request, verify):
+    """
+    Extract urllib3 connection pool parameters from a request and verify setting.
+
+    :param request: The PreparedRequest being sent.
+    :param verify: Either a boolean or a string path to a CA bundle.
+    :returns: A tuple of (host_params, pool_kwargs) for connection_from_host.
+    """
+    host_params = {}
+    pool_kwargs = {}
+    parsed_request_url = urlparse(request.url)
+    scheme = parsed_request_url.scheme.lower()
+    port = parsed_request_url.port
+    cert_reqs = "CERT_REQUIRED"
+    if verify is False:
+        cert_reqs = "CERT_NONE"
+    if isinstance(verify, str):
+        pool_kwargs["ca_certs"] = verify
+    pool_kwargs["cert_reqs"] = cert_reqs
+    host_params = {
+        "scheme": scheme,
+        "host": parsed_request_url.hostname,
+        "port": port,
+    }
+    return host_params, pool_kwargs
 
 
