+        # (defence-in-depth): bypass OctKey.import_key by setting raw_value
+        # post-hoc.
+        empty_key = OctKey.import_key("rfc")
+        empty_key._raw_value = b""
+        from joserfc._rfc7518.jws_algs import HMACAlgorithm
+        alg = HMACAlgorithm(256)
