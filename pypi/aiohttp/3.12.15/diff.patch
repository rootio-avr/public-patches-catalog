+def test_save_load_json_preserves_host_only_scope(tmp_path) -> None:
+    """Regression: host-only cookies must not leak to subdomains after save/load.
+
+    CVE-2026-54279: prior to the fix, CookieJar.save() persisted only
+    ``_cookies`` and dropped ``_host_only_cookies``, so a cookie received
+    without an explicit ``Domain`` attribute (host-only) would, after a
+    save/load round-trip, be sent to subdomains it never should have.
+    """
+    file_path = pathlib.Path(str(tmp_path)) / "host_only.json"
+    issuer = URL("https://auth.example.com/login")
+    subdomain = URL("https://sub.auth.example.com/")
+
+    jar_save = CookieJar()
+    jar_save.update_cookies({"sid": "hostonly"}, response_url=issuer)
+    # Sanity: host-only scope holds before save.
+    assert ("auth.example.com", "sid") in jar_save._host_only_cookies
+    assert "sid" not in jar_save.filter_cookies(subdomain)
+    assert "sid" in jar_save.filter_cookies(issuer)
+    jar_save.save(file_path=file_path)
+
+    jar_load = CookieJar()
+    jar_load.load(file_path=file_path)
+
+    # Host-only scope must survive the round-trip.
+    assert ("auth.example.com", "sid") in jar_load._host_only_cookies
+    assert "sid" not in jar_load.filter_cookies(subdomain)
+    assert "sid" in jar_load.filter_cookies(issuer)
+
+
