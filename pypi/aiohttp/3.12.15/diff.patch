+def test_save_load_json_preserves_max_age_deadline(tmp_path) -> None:
+    """Regression: Max-Age cookies must keep their absolute deadline across save/load.
+
+    Previously, save() dropped the absolute deadline from ``_expirations`` and
+    the next load() would either lose the cookie or, after this fix, restart
+    its clock from ``now + Max-Age``. The fix persists the absolute deadline
+    so the load is exact.
