+def test_request_cookies_many_invalid(caplog: pytest.LogCaptureFixture) -> None:
+    """CVE-2025-69230: many invalid cookies must not cause one log per cookie.
+
+    Backport of upstream PR #11890 regression test, adapted for 3.8.6's
+    stdlib SimpleCookie code path. The defensive aggregation in
+    BaseRequest.cookies must emit at most one DEBUG-level record even
+    when thousands of invalid cookie names are present.
+    """
+    bad = "bad" + chr(1) + "name"
+    cookie = "; ".join(f"{bad}{i}=1" for i in range(3000))
+    req = make_mocked_request("GET", "/", headers=CIMultiDict(COOKIE=cookie))
+
+    with caplog.at_level(logging.DEBUG, logger="aiohttp.internal"):
+        cookies = req.cookies
+
+    aiohttp_records = [r for r in caplog.record_tuples if r[0] == "aiohttp.internal"]
+    assert len(aiohttp_records) <= 1
+    if aiohttp_records:
+        _, level, msg = aiohttp_records[0]
+        assert level == logging.DEBUG
+        assert "Cannot load cookie" in msg
+    assert cookies == {}
 
 
