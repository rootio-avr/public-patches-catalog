+    @staticmethod
+    def _bounded_decompress(data: bytes, wbits: int) -> bytes:
+        """Decompress *data* enforcing DEFAULT_MAX_DECOMPRESS_SIZE.
+
+        Mitigates CVE-2025-69223 (zip-bomb DoS) by capping the decompressed
+        output size. Uses zlib.decompressobj with max_length and loops over
+        unconsumed_tail so a small compressed multipart part cannot expand
+        to unbounded memory.
+        """
+        from .http_exceptions import DEFAULT_MAX_DECOMPRESS_SIZE
+
+        decompressor = zlib.decompressobj(wbits=wbits)
+        out = b""
+        remaining_input = data
+        while True:
+            allowed = DEFAULT_MAX_DECOMPRESS_SIZE - len(out) + 1
+            if allowed <= 0:
+                allowed = 1
+            piece = decompressor.decompress(remaining_input, allowed)
+            out += piece
+            if len(out) > DEFAULT_MAX_DECOMPRESS_SIZE:
+                raise RuntimeError(
+                    "Decompressed data exceeds the configured limit of %d bytes"
+                    % DEFAULT_MAX_DECOMPRESS_SIZE
+                )
+            if not decompressor.unconsumed_tail:
+                break
+            remaining_input = decompressor.unconsumed_tail
+        tail = decompressor.flush()
+        out += tail
+        if len(out) > DEFAULT_MAX_DECOMPRESS_SIZE:
+            raise RuntimeError(
+                "Decompressed data exceeds the configured limit of %d bytes"
+                % DEFAULT_MAX_DECOMPRESS_SIZE
+            )
