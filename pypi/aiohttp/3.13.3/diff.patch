+class _ClosingPayload(Payload):
+    """Payload test double that records whether close() ran."""
+
+    def __init__(self) -> None:
+        super().__init__(None)
+        self.close_called = False
+        self.started = asyncio.Event()
+        self.release = asyncio.Event()
+        self.fail = False
