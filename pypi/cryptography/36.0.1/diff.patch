+def _marvin_synthetic(key, ciphertext, default_len=None):
+    # Implicit-rejection (Marvin) synthetic message generator.
+    # Returns a deterministic pseudo-random byte string keyed by a per-key
+    # secret so that retries on the same ciphertext yield the same output and
+    # an attacker cannot extract entropy from observing failures.
+    secret = getattr(key, "_marvin_implicit_key", None)
+    if secret is None:
+        secret = os.urandom(32)
+        try:
+            object.__setattr__(key, "_marvin_implicit_key", secret)
+        except Exception:
+            pass
+    k = (key.key_size + 7) // 8
+    if default_len is None:
+        default_len = max(0, k - 11)
+    out = b""
+    counter = 0
+    while len(out) < default_len:
+        out += _hmac.new(
+            secret,
+            ciphertext + counter.to_bytes(4, "big"),
+            hashlib.sha256,
+        ).digest()
+        counter += 1
+    return out[:default_len]
+
