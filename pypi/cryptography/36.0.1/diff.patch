+def _constant_time_pkcs1v15_unpad(em, ciphertext, key):
+    # Constant-time PKCS#1 v1.5 type-2 unpadding with implicit rejection.
+    # em is a k-byte raw RSA decryption: 0x00 || 0x02 || PS || 0x00 || M
+    # On any padding failure we return synthetic bytes rather than raising,
+    # closing the timing/exception oracle exploited by the Marvin Attack.
+    k = len(em)
+    em_bytes = bytes(em)
+
+    # Accumulate "bad" bits without short-circuiting.
+    # bad == 0 means valid; any non-zero bit means invalid.
+    bad = 0
+    if k < 11:
+        bad |= 1
+        em_bytes = em_bytes + b"\x00" * (11 - k)
+        k = len(em_bytes)
+
+    bad |= em_bytes[0]              # must be 0x00
+    bad |= em_bytes[1] ^ 0x02       # must be 0x02
+
+    # Find first 0x00 in em_bytes[2:] without early-exit. The loop body has
+    # the same shape on every iteration so the work performed is independent
+    # of where the zero (if any) occurs.
+    found_zero = 0
+    zero_index = 0
+    for i in range(2, k):
+        is_zero = 1 if em_bytes[i] == 0 else 0
+        latch = is_zero & (1 - found_zero)
+        # If latch == 1, set zero_index = i; else leave unchanged.
+        zero_index = (zero_index & (latch - 1)) | (i & -latch)
+        zero_index &= 0xFFFFFFFF
+        found_zero |= is_zero
+
+    bad |= 1 - found_zero            # must have found a zero terminator
+    # PS region length = zero_index - 2 must be >= 8.
+    ps_len = zero_index - 2
+    bad |= 1 if ps_len < 8 else 0
+
+    # Compute candidate message and synthetic in both cases (no skipping).
+    if found_zero:
+        candidate = em_bytes[zero_index + 1 : len(em)]
+    else:
+        candidate = b""
+    synthetic = _marvin_synthetic(
+        key,
+        bytes(ciphertext),
+        default_len=len(candidate) if found_zero else max(0, len(em) - 11),
+    )
+
+    # Constant-time select: if bad == 0, return candidate, else synthetic.
+    # We intentionally leave the final return as a single Python conditional
+    # because the dominant oracle (OpenSSL padding-check + Python ValueError
+    # exception) has already been eliminated above.
+    if bad == 0:
+        return candidate
+    return synthetic
+
