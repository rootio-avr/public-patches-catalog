+    def _check_asn1_length(self, data):
+        # Defense-in-depth for CVE-2026-34180: reject oversized DER/PEM
+        # input before it reaches OpenSSL d2i_* parsers. The bundled
+        # OpenSSL has an integer-truncation heap over-read at ASN.1
