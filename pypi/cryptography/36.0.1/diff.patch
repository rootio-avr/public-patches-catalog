+def _pkcs1v15_decrypt_constant_time(backend, key, ciphertext):
+    k = (key.key_size + 7) // 8
+    if len(ciphertext) != k:
+        # Length is public; matches the pre-existing length check in
+        # _RSAPrivateKey.decrypt. Return synthetic to be safe if reached.
+        return _marvin_synthetic(key, bytes(ciphertext))
+    try:
+        em = _enc_dec_rsa_pkey_ctx(
+            backend,
+            key,
+            ciphertext,
+            backend._lib.RSA_NO_PADDING,
+            PKCS1v15(),
+        )
+    except Exception:
+        # Raw RSA only fails for genuine errors (e.g. ciphertext numerically
+        # >= n). Treat as implicit rejection.
+        return _marvin_synthetic(key, bytes(ciphertext))
+    # Pad to k bytes if OpenSSL stripped leading zeros.
+    em_bytes = bytes(em)
