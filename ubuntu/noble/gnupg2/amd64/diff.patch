Description: CVE-2025-68972 - Fix form feed detection in cleartext signature verification
 In GnuPG through 2.4.8, if a signed message has \f (form feed) at the end
 of a plaintext line, an adversary can construct a modified message that
 places additional text after the signed material, such that signature
 verification succeeds. This occurs because armor.c inserts form feed to
 mark truncated lines (commit 976e9d608, Nov 2022) but plaintext.c does not
 detect it during signature hash calculation.
 .
 This patch adds form feed detection in the cleartext signature hash
 calculation in plaintext.c. When form feed is encountered (indicating a
 truncated line from armor.c), it is included in the hash calculation to
 ensure that any modification after the truncated line will cause signature
 verification to fail.
Origin: upstream, mailing list submission (http://www.mail-archive.com/gnupg-devel@gnupg.org/msg00710.html)
Author: Werner Koch <wk@gnupg.org>
Last-Update: 2026-01-15

--- a/g10/plaintext.c
+++ b/g10/plaintext.c
@@ -439,7 +439,9 @@ handle_plaintext (PKT_plaintext * pt, md_filter_context_t * mfx,
 	}
       pt->buf = NULL;
     }
-  else /* Clear text signature - don't hash the last CR,LF.   */
+  else /* Clear text signature - don't hash the last CR,LF.
+        * Also detect form feed which indicates a truncated line
+        * inserted by armor.c for overlong lines.  */
     {
       int state = 0;

@@ -476,6 +478,14 @@ handle_plaintext (PKT_plaintext * pt, md_filter_context_t * mfx,
 		state = 1;
 	      else if (c == '\n')
 		state = 2;
+	      else if (c == '\f')
+		{
+		  /* Form feed indicates a truncated line from armor.c.
+		   * Include it in the hash to ensure signature verification
+		   * fails if content after the truncated line is modified.  */
+		  gcry_md_putc (mfx->md, c);
+		  state = 2;  /* Treat as end of line */
+		}
 	      else
 		gcry_md_putc (mfx->md, c);
 	    }
@@ -483,6 +493,13 @@ handle_plaintext (PKT_plaintext * pt, md_filter_context_t * mfx,
 	    {
 	      if (c == '\n')
 		state = 2;
+	      else if (c == '\f')
+		{
+		  /* Form feed after CR - hash both CR and FF */
+		  gcry_md_putc (mfx->md, '\r');
+		  gcry_md_putc (mfx->md, c);
+		  state = 2;  /* Treat as end of line */
+		}
 	      else
 		{
 		  gcry_md_putc (mfx->md, '\r');
