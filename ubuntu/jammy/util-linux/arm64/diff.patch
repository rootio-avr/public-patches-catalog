Description: CVE-2026-27456 - Fix TOCTOU race condition in mount SUID binary
 A race condition exists in util-linux's mount utility where the SUID
 binary validates file paths with user privileges then reopens them as
 root without confirming the path hasn't changed. This allows a local
 unprivileged user to replace the source file with a symlink pointing to
 any root-owned file or device between path resolution and open().
 .
 This patch adds a LOOPDEV_FL_NOFOLLOW flag to the loop device context
 that prevents symlink following in both path canonicalization and file
 open. When set, loopcxt_set_backing_file() uses strdup() instead of
 canonicalize_path() (which follows symlinks via realpath()), and
 loopcxt_setup_device() adds O_NOFOLLOW to open() flags. The flag is
 activated for non-root (restricted) mount operations.
 .
 Adapted from upstream commit for v2.37.2: hook_loopdev.c changes mapped
 to context_loopdev.c, ul_canonicalize_path() mapped to canonicalize_path().
Origin: upstream, https://github.com/util-linux/util-linux/commit/5e390467b26a3cf3fecc04e1a0d482dff3162fc4
Author: Karel Zak <kzak@redhat.com>
Last-Update: 2026-04-22

--- a/include/loopdev.h	2026-06-03 14:23:14.021120577 +0530
+++ b/include/loopdev.h	2026-06-03 14:23:23.745582684 +0530
@@ -135,7 +135,8 @@
 	LOOPDEV_FL_NOIOCTL	= (1 << 6),
 	LOOPDEV_FL_DEVSUBDIR	= (1 << 7),
 	LOOPDEV_FL_CONTROL	= (1 << 8),	/* system with /dev/loop-control */
-	LOOPDEV_FL_SIZELIMIT	= (1 << 9)
+	LOOPDEV_FL_SIZELIMIT	= (1 << 9),
+	LOOPDEV_FL_NOFOLLOW	= (1 << 10)	/* O_NOFOLLOW, don't follow symlinks */
 };
 
 /*
--- a/lib/loopdev.c	2026-06-03 14:23:14.023940060 +0530
+++ b/lib/loopdev.c	2026-06-03 14:23:47.752785310 +0530
@@ -1170,7 +1170,10 @@
 	if (!lc)
 		return -EINVAL;
 
-	lc->filename = canonicalize_path(filename);
+	if (lc->flags & LOOPDEV_FL_NOFOLLOW)
+		lc->filename = strdup(filename);
+	else
+		lc->filename = canonicalize_path(filename);
 	if (!lc->filename)
 		return -errno;
 
@@ -1293,6 +1296,7 @@
 	int file_fd, dev_fd, mode = O_RDWR, rc = -1, cnt = 0, err, again;
 	int errsv = 0;
 	int fallback = 0;
+	int flags = O_CLOEXEC;
 
 	if (!lc || !*lc->device || !lc->filename)
 		return -EINVAL;
@@ -1305,9 +1309,12 @@
 	if (lc->config.info.lo_flags & LO_FLAGS_READ_ONLY)
 		mode = O_RDONLY;
 
-	if ((file_fd = open(lc->filename, mode | O_CLOEXEC)) < 0) {
+	if (lc->flags & LOOPDEV_FL_NOFOLLOW)
+		flags |= O_NOFOLLOW;
+
+	if ((file_fd = open(lc->filename, mode | flags)) < 0) {
 		if (mode != O_RDONLY && (errno == EROFS || errno == EACCES))
-			file_fd = open(lc->filename, mode = O_RDONLY);
+			file_fd = open(lc->filename, (mode = O_RDONLY) | flags);
 
 		if (file_fd < 0) {
 			DBG(SETUP, ul_debugobj(lc, "open backing file failed: %m"));
--- a/libmount/src/context_loopdev.c	2026-06-03 14:23:14.026491934 +0530
+++ b/libmount/src/context_loopdev.c	2026-06-03 14:23:58.231890930 +0530
@@ -289,7 +289,8 @@
 	}
 
 	DBG(LOOP, ul_debugobj(cxt, "not found; create a new loop device"));
-	rc = loopcxt_init(&lc, 0);
+	rc = loopcxt_init(&lc,
+			mnt_context_is_restricted(cxt) ? LOOPDEV_FL_NOFOLLOW : 0);
 	if (rc)
 		goto done_no_deinit;
 	if (loopval) {
