Description: Fix build failure when pam_extrausers binaries are missing
 This patch makes the build resilient to missing pam_extrausers binaries
 by conditionally removing them from the install file and making permission
 settings conditional.
Author: Auto-generated fix
Last-Updated: 2024-11-11

--- a/debian/rules
+++ b/debian/rules
@@ -41,6 +41,10 @@ override_dh_install:
 ifneq (,$(findstring libpam-modules, $(shell dh_listpackages)))
 	dh_install -plibpam-modules -Xpam_cracklib
 endif
+	# Remove references to pam_extrausers binaries if they don't exist
+	@if [ ! -f debian/tmp/sbin/pam_extrausers_chkpwd ] || [ ! -f debian/tmp/sbin/pam_extrausers_update ]; then \
+		sed -i '/pam_extrausers_chkpwd/d; /pam_extrausers_update/d' $(d)/libpam-modules-bin.install; \
+	fi
 	dh_install -Nlibpam-modules
 	# Make sure the md5sums for the templates we ship are
 	# recognized by pam-auth-update.
@@ -78,6 +82,8 @@ override_dh_fixperms:
 ifneq (,$(findstring libpam-modules, $(shell dh_listpackages)))
 	chgrp shadow $(d)/libpam-modules-bin/sbin/unix_chkpwd
 	chmod 02755 $(d)/libpam-modules-bin/sbin/unix_chkpwd
-	chgrp shadow $(d)/libpam-modules-bin/sbin/pam_extrausers_chkpwd
-	chmod 02755 $(d)/libpam-modules-bin/sbin/pam_extrausers_chkpwd
+	@if [ -f $(d)/libpam-modules-bin/sbin/pam_extrausers_chkpwd ]; then \
+		chgrp shadow $(d)/libpam-modules-bin/sbin/pam_extrausers_chkpwd; \
+		chmod 02755 $(d)/libpam-modules-bin/sbin/pam_extrausers_chkpwd; \
+	fi
 endif
