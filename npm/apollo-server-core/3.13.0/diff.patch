# Patch for GHSA-9q82-xgwf-vj6h
# Fix XS-Search CSRF bypass via GET requests with arbitrary Content-Type headers
#
# Vulnerability: A browser bug introduced in 2025 fails to follow CORS spec,
# allowing an attacker to send GET requests with non-application/json
# Content-Type headers without triggering a preflight. Combined with Apollo
# Server's CSRF prevention (which relies on preflight being triggered for
# non-safelisted content types), this bypasses CSRF protection and enables
# read-only XS-Search-style attacks against servers using cookies or HTTP
# Basic Auth for authentication.
#
# Fix: GET requests with a Content-Type header whose essence is not
# application/json are now rejected with HTTP 415. GET requests with no
# Content-Type header continue to be allowed.
#
# Severity: medium (CVSS 6.3)
# Affected version: 3.13.0
# Advisory: https://github.com/advisories/GHSA-9q82-xgwf-vj6h
# Upstream commit: https://github.com/apollographql/apollo-server/commit/ada12001c4e95b5c779d80314a5a32e33087b5cf
# Note: Upstream fix targets @apollo/server v5 (packages/server/src/runHttpQuery.ts).
#       This is a backport to apollo-server-core v3.13.0 (dist/runHttpQuery.js).
#       Dist-based patch: whatwg-mimetype is already imported in the compiled bundle.
#       No build step required.
--- a/dist/runHttpQuery.js
+++ b/dist/runHttpQuery.js
@@ -148,6 +148,15 @@
             requestPayload = httpRequest.query;
             break;
         case 'GET':
+            {
+                const contentType = httpRequest.request.headers.get('content-type');
+                if (contentType !== null) {
+                    const contentTypeParsed = whatwg_mimetype_1.default.parse(contentType);
+                    if (contentTypeParsed === null || contentTypeParsed.essence !== 'application/json') {
+                        throw new HttpQueryError(415, 'GET requests may not have a content-type header other than application/json.');
+                    }
+                }
+            }
             if (!httpRequest.query || Object.keys(httpRequest.query).length === 0) {
                 throw new HttpQueryError(400, 'GET query missing.');
             }
