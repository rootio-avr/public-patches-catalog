diff --git a/lib/validateAsymmetricKey.js b/lib/validateAsymmetricKey.js
new file mode 100644
index 0000000..b4b1f6e
--- /dev/null
+++ b/lib/validateAsymmetricKey.js
@@ -0,0 +1,92 @@
+var ASYMMETRIC_KEY_DETAILS_SUPPORTED = require('./asymmetricKeyDetailsSupported');
+var RSA_PSS_KEY_DETAILS_SUPPORTED = require('./rsaPssKeyDetailsSupported');
+
+var allowedAlgorithmsForKeys = {
+  'ec': ['ES256', 'ES384', 'ES512'],
+  'rsa': ['RS256', 'PS256', 'RS384', 'PS384', 'RS512', 'PS512'],
+  'rsa-pss': ['PS256', 'PS384', 'PS512']
+};
+
+var allowedCurves = {
+  ES256: 'prime256v1',
+  ES384: 'secp384r1',
+  ES512: 'secp521r1',
+};
+
+module.exports = function(algorithm, key) {
+  if (!algorithm || !key) return;
+
+  // For v8.5.1, we need to convert the key to a KeyObject to check its type
+  // This requires Node.js >= 11.6.0 for createPublicKey/createPrivateKey
+  var crypto;
+  var keyObject;
+
+  try {
+    crypto = require('crypto');
+    if (!crypto.createPrivateKey) {
+      // Node.js version too old to support KeyObject, skip validation
+      return;
+    }
+
+    // Try to create a KeyObject from the key
+    try {
+      keyObject = crypto.createPrivateKey(key);
+    } catch (e) {
+      try {
+        keyObject = crypto.createPublicKey(key);
+      } catch (e2) {
+        // If we can't create a KeyObject, skip validation
+        return;
+      }
+    }
+  } catch (e) {
+    // crypto module not available or error, skip validation
+    return;
+  }
+
+  var keyType = keyObject.asymmetricKeyType;
+  if (!keyType) return;
+
+  var allowedAlgorithms = allowedAlgorithmsForKeys[keyType];
+
+  if (!allowedAlgorithms) {
+    throw new Error('Unknown key type "' + keyType + '".');
+  }
+
+  if (allowedAlgorithms.indexOf(algorithm) === -1) {
+    throw new Error('"alg" parameter for "' + keyType + '" key type must be one of: ' + allowedAlgorithms.join(', ') + '.')
+  }
+
+  /*
+   * Ignore the next block from test coverage because it gets executed
+   * conditionally depending on the Node version. Not ignoring it would
+   * prevent us from reaching the target % of coverage for versions of
+   * Node under 15.7.0.
+   */
+  /* istanbul ignore next */
+  if (ASYMMETRIC_KEY_DETAILS_SUPPORTED) {
+    if (keyType === 'ec') {
+      var keyCurve = keyObject.asymmetricKeyDetails.namedCurve;
+      var allowedCurve = allowedCurves[algorithm];
+
+      if (keyCurve !== allowedCurve) {
+        throw new Error('"alg" parameter "' + algorithm + '" requires curve "' + allowedCurve + '".');
+      }
+    } else if (keyType === 'rsa-pss') {
+      if (RSA_PSS_KEY_DETAILS_SUPPORTED) {
+        var length = parseInt(algorithm.slice(-3), 10);
+        var hashAlgorithm = keyObject.asymmetricKeyDetails.hashAlgorithm;
+        var mgf1HashAlgorithm = keyObject.asymmetricKeyDetails.mgf1HashAlgorithm;
+        var saltLength = keyObject.asymmetricKeyDetails.saltLength;
+
+        if (hashAlgorithm !== 'sha' + length || mgf1HashAlgorithm !== hashAlgorithm) {
+          throw new Error('Invalid key for this operation, its RSA-PSS parameters do not meet the requirements of "alg" ' + algorithm + '.');
+        }
+
+        if (saltLength !== undefined && saltLength > length >> 3) {
+          throw new Error('Invalid key for this operation, its RSA-PSS parameter saltLength does not meet the requirements of "alg" ' + algorithm + '.')
+        }
+      }
+    }
+  }
+}
