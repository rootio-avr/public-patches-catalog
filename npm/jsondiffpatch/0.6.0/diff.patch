From b418384d09fb11fbd51126d07407beeacc22b07f Mon Sep 17 00:00:00 2001
Date: Tue, 6 Jan 2026 14:43:23 +0530
Subject: [PATCH] patch

---
 lib/formatters/html.js | 21 +++++++++++++++------
 1 file changed, 15 insertions(+), 6 deletions(-)

diff --git a/lib/formatters/html.js b/lib/formatters/html.js
index 6770f01..f2e9362 100644
--- a/lib/formatters/html.js
+++ b/lib/formatters/html.js
@@ -1,8 +1,16 @@
 import BaseFormatter from './base.js';
 class HtmlFormatter extends BaseFormatter {
     typeFormattterErrorFormatter(context, err) {
-        // eslint-disable-next-line @typescript-eslint/restrict-template-expressions
-        context.out(`<pre class="jsondiffpatch-error">${err}</pre>`);
+        const message =
+            typeof err === 'object' &&
+            err !== null &&
+            'message' in err &&
+            typeof err.message === 'string'
+                ? err.message
+                : String(err);
+        context.out(
+            `<pre class="jsondiffpatch-error">${htmlEscape(message)}</pre>`
+        );
     }
     formatValue(context, value) {
         context.out(`<pre>${htmlEscape(JSON.stringify(value, null, 2))}</pre>`);
@@ -35,8 +43,8 @@ class HtmlFormatter extends BaseFormatter {
     }
     nodeBegin(context, key, leftKey, type, nodeType) {
         const nodeClass = `jsondiffpatch-${type}${nodeType ? ` jsondiffpatch-child-node-type-${nodeType}` : ''}`;
-        context.out(`<li class="${nodeClass}" data-key="${leftKey}">` +
-            `<div class="jsondiffpatch-property-name">${leftKey}</div>`);
+        context.out(`<li class="${nodeClass}" data-key="${htmlEscape(leftKey)}">` +
+            `<div class="jsondiffpatch-property-name">${htmlEscape(leftKey)}</div>`);
     }
     nodeEnd(context) {
         context.out('</li>');
@@ -113,8 +121,9 @@ class HtmlFormatter extends BaseFormatter {
         context.out('</div>');
     }
 }
-function htmlEscape(text) {
-    let html = text;
+function htmlEscape(value) {
+    if (typeof value === 'number') return value;
+    let html = String(value);
     const replacements = [
         [/&/g, '&amp;'],
         [/</g, '&lt;'],
-- 
