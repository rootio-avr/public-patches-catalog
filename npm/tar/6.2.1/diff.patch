From 1343f420d023ed8bd0579133922c0acb7e018bbd Mon Sep 17 00:00:00 2001
Date: Tue, 20 Jan 2026 13:38:57 +0530
Subject: [PATCH] fix: sanitize absolute linkpaths properly

Fixes CVE-2026-23745 / GHSA-8qq5-rm4j-mr97

This patch prevents path traversal attacks by properly sanitizing both
the 'path' and 'linkpath' fields of tar entries. Previously, only the
'path' field was sanitized, allowing attackers to exploit absolute paths
in 'linkpath' to create symbolic links or hard links that escape the
extraction directory.

The fix introduces a new STRIPABSOLUTEPATH method that validates and
sanitizes both fields, rejecting entries with '..' path components and
stripping absolute path prefixes when preservePaths is disabled.

---
 lib/unpack.js | 53 ++++++++++++++++++++++++++++++++++-----------------
 1 file changed, 35 insertions(+), 18 deletions(-)

diff --git a/lib/unpack.js b/lib/unpack.js
index 03172e2..3799562 100644
--- a/lib/unpack.js
+++ b/lib/unpack.js
@@ -32,6 +32,7 @@ const SYMLINK = Symbol('symlink')
 const HARDLINK = Symbol('hardlink')
 const UNSUPPORTED = Symbol('unsupported')
 const CHECKPATH = Symbol('checkPath')
+const STRIPABSOLUTEPATH = Symbol('stripAbsolutePath')
 const MKDIR = Symbol('mkdir')
 const ONERROR = Symbol('onError')
 const PENDING = Symbol('pending')
@@ -244,6 +245,37 @@ class Unpack extends Parser {
     }
   }
 
+  // return false if we need to skip this file
+  // return true if the field was successfully sanitized
+  [STRIPABSOLUTEPATH] (entry, field) {
+    const p = entry[field]
+    if (!p || this.preservePaths) {
+      return true
+    }
+
+    const parts = p.split('/')
+    if (parts.includes('..') || isWindows && /^[a-z]:\.\.$/i.test(parts[0])) {
+      this.warn('TAR_ENTRY_ERROR', `${field} contains '..'`, {
+        entry,
+        [field]: p,
+      })
+      // not ok!
+      return false
+    }
+
+    // strip off the root
+    const [root, stripped] = stripAbsolutePath(p)
+    if (root) {
+      // ok, but triggers warning about stripping root
+      entry[field] = String(stripped)
+      this.warn('TAR_ENTRY_INFO', `stripping ${root} from absolute ${field}`, {
+        entry,
+        [field]: p,
+      })
+    }
+    return true
+  }
+
   [CHECKPATH] (entry) {
     const p = normPath(entry.path)
     const parts = p.split('/')
@@ -274,24 +306,9 @@ class Unpack extends Parser {
       return false
     }
 
