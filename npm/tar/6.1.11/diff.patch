+'use strict'
+// Regression test for CVE-2026-59871 (GHSA-w8wr-v893-vjvp).
+// All-digit PAX path/linkpath (and other string) values must stay strings and
+// must not be coerced into JS numbers; only known numeric fields are cast.
+const t = require('tap')
+const Pax = require('../lib/pax.js')
+
+t.test('string fields stay string (CVE-2026-59871)', t => {
+  t.same(
+    Pax.parse(
+      '14 path=12345\n18 linkpath=54321\n13 WAT=12345\n15 ctime=12345\n',
+      null,
+      false
+    ),
+    {
+      atime: null,
+      charset: null,
+      comment: null,
+      ctime: new Date('1970-01-01T03:25:45.000Z'),
+      gid: null,
+      gname: null,
+      linkpath: '54321',
+      mtime: null,
+      path: '12345',
+      size: null,
+      uid: null,
+      uname: null,
+      dev: null,
+      ino: null,
+      nlink: null,
+      global: false,
+    }
+  )
+  t.equal(typeof Pax.parse('14 path=12345\n', null, false).path, 'string')
+  t.equal(typeof Pax.parse('18 linkpath=54321\n', null, false).linkpath, 'string')
+  t.end()
+})

