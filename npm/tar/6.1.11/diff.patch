@@ -0,0 +1,71 @@
+'use strict'
+// Regression test for CVE-2026-59873:
+// tar's Parser did not bound the ratio of decompressed to compressed bytes,
+// allowing a small gzip "bomb" to expand into a huge amount of data. The fix
+// adds a maxDecompressionRatio guard (default 1000) that aborts parsing when
+// the decompressed:compressed ratio is exceeded.
+const t = require('tap')
+const Parser = require('../lib/parse.js')
+const makeTar = require('./make-tar.js')
+const zlib = require('zlib')
+
+// A tiny gzip blob that expands to 8 MiB of data — a classic decompression
+// bomb. The zeroed payload compresses to almost nothing, so the ratio is huge.
+const makeCompressedBomb = () => {
+  const payload = Buffer.alloc(8 * 1024 * 1024)
+  return zlib.gzipSync(makeTar([
+    {
+      path: 'bomb',
+      size: payload.length,
+      type: 'File',
+    },
+    payload,
+    '',
+    '',
+  ]))
+}
+
+t.test('max decompression ratio', t => {
+  const bomb = makeCompressedBomb()
+
+  t.test('parsing aborts by default', t => {
+    const p = new Parser({})
+    t.throws(() => p.end(bomb), {
+      tarCode: 'TAR_ABORT',
+      recoverable: false,
+      message: /max decompression ratio exceeded/,
+    }, 'parsing aborts on the bomb')
+    // aborting a second time is a no-op
+    p.abort(new Error('hello'))
+    t.end()
+  })
+
+  t.test('aborting only happens one time', t => {
+    const p = new Parser({})
+    t.throws(() => p.abort(new Error('hello')), {
+      message: 'hello',
+      tarCode: 'TAR_ABORT',
+      recoverable: false,
+    })
+    // this is ignored, since we already aborted
+    p.end(bomb)
+    t.end()
+  })
+
+  t.test('parsing can disable the limit explicitly', t => {
+    let bytesRead = 0
+    const p = new Parser({
+      maxDecompressionRatio: Infinity,
+      onentry (e) {
+        e.on('data', c => (bytesRead += c.length))
+      },
+    })
+    p.on('end', () => {
+      t.equal(bytesRead, 8 * 1024 * 1024)
+      t.end()
+    })
+    p.end(bomb)
+  })
+
+  t.end()
+})
