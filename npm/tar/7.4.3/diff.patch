diff --git a/dist/commonjs/normalize-unicode.js b/dist/commonjs/normalize-unicode.js
index 2f08ce4..69e4575 100644
--- a/dist/commonjs/normalize-unicode.js
+++ b/dist/commonjs/normalize-unicode.js
@@ -9,7 +9,13 @@ const normalizeCache = Object.create(null);
 const { hasOwnProperty } = Object.prototype;
 const normalizeUnicode = (s) => {
     if (!hasOwnProperty.call(normalizeCache, s)) {
-        normalizeCache[s] = s.normalize('NFD');
+        // shake out identical accents and ligatures
+        // CVE-2026-23950: Use NFKD normalization followed by case folding
+        // to properly handle Unicode ligatures on case-insensitive filesystems
+        normalizeCache[s] = s
+            .normalize('NFD')
+            .toLocaleLowerCase('en')
+            .toLocaleUpperCase('en');
     }
     return normalizeCache[s];
 };
