--- /dev/null
+++ b/test/cve-2026-59871.test.js
@@ -0,0 +1,40 @@
+'use strict'
+// CVE-2026-59871 / GHSA-w8wr-v893-vjvp regression test.
+//
+// parseKVLine used to infer types by regex: any all-numeric PAX value was
+// coerced to a Number. A numeric-looking `path` (e.g. `path=12345`) therefore
+// became a Number instead of a String, which crashed extraction downstream
+// (normalizeWindowsPaths / string operations on a Number).
+//
+// The fix parses values according to an allow-list keyed on the field name:
+// string-only fields stay strings, date fields become Date, numeric fields
+// are coerced, and unknown keys are ignored.
+const assert = require('assert')
+const Pax = require('../lib/pax.js')
+
+// path/linkpath are string-only fields: a numeric-looking value stays a string.
+const parsed = Pax.parse(
+  '14 path=12345\n18 linkpath=54321\n13 WAT=12345\n15 ctime=12345\n',
+  null,
+  false
+)
+
+assert.strictEqual(parsed.path, '12345', 'numeric-looking path must stay a String')
+assert.strictEqual(typeof parsed.path, 'string')
+assert.strictEqual(parsed.linkpath, '54321', 'numeric-looking linkpath must stay a String')
+assert.strictEqual(typeof parsed.linkpath, 'string')
+
+// unknown keys are ignored
+assert.strictEqual(parsed.WAT, undefined, 'unknown PAX keys must be ignored')
+
+// date fields become Date objects
+assert.ok(parsed.ctime instanceof Date, 'ctime must be a Date')
+assert.strictEqual(parsed.ctime.getTime(), 12345 * 1000)
+
+// numeric fields are still coerced to Number
+const nums = Pax.parse('9 gid=20\n9 uid=24\n', null, false)
+assert.strictEqual(nums.gid, 20)
+assert.strictEqual(typeof nums.gid, 'number')
+assert.strictEqual(nums.uid, 24)
+
+console.log('CVE-2026-59871 regression test passed')

