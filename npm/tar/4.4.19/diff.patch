+'use strict'
+// Regression test for CVE-2026-59873: guard against explosive decompression
+// (decompression bombs) via the maxDecompressionRatio option on the Parser.
+// A ~8MiB tar of zeros compresses to a few KiB of gzip, giving a
+// decompressed:compressed ratio well above the default 1000 limit.
+const t = require('tap')
+const Parse = require('../lib/parse.js')
+const Header = require('../lib/header.js')
+const zlib = require('zlib')
+
+const makeCompressedBomb = payloadSize => {
+  const header = Buffer.alloc(512)
+  new Header({
+    path: 'bomb',
+    size: payloadSize,
+    type: 'File',
+    mode: 0o644,
+    mtime: new Date(0),
+  }).encode(header, 0)
+  const body = Buffer.alloc(Math.ceil(payloadSize / 512) * 512)
+  const end = Buffer.alloc(1024)
+  return zlib.gzipSync(Buffer.concat([header, body, end]))
+}
+const payloadSize = 8 * 1024 * 1024
+const bomb = makeCompressedBomb(payloadSize)
+
+t.test('parsing aborts a decompression bomb by default', t => {
+  const p = new Parse({})
+  let aborted = null
+  p.on('error', er => { aborted = er })
+  p.on('warn', () => {})
+  p.end(bomb)
+  t.ok(aborted, 'emitted an error')
+  t.match(aborted && aborted.message, /max decompression ratio exceeded/,
+    'aborted with the max decompression ratio error')
+  t.end()
+})
+
+t.test('aborting only happens one time', t => {
+  const p = new Parse({})
+  const errors = []
+  p.on('error', er => errors.push(er))
+  p.on('warn', () => {})
+  p.abort('hello', new Error('hello'))
+  const countAfterFirst = errors.length
+  // this second abort is ignored
+  p.abort('again', new Error('again'))
+  t.equal(errors.length, countAfterFirst, 'second abort is a no-op')
+  t.equal(errors[0].message, 'hello', 'first abort reason wins')
+  t.end()
+})
+
+t.test('parsing can disable the limit explicitly', t => {
+  let bytesRead = 0
+  const p = new Parse({
+    maxDecompressionRatio: Infinity,
+    onentry (e) {
+      e.on('data', c => (bytesRead += c.length))
+      e.resume()
+    },
+  })
+  p.on('end', () => {
+    t.equal(bytesRead, payloadSize, 'read the whole payload, no abort')
+    t.end()
+  })
+  p.on('error', er => {
+    t.fail('should not abort when limit disabled: ' + er.message)
+    t.end()
+  })
+  p.end(bomb)
+})
