+'use strict';
+
+var PROTO_KEY = '__proto__';
+var PROTOTYPE_CHAIN_KEYS = { constructor: true, prototype: true };
+
+function hasOwnProperty(baseRef, key) {
+  return (
+    (typeof baseRef === 'object' || typeof baseRef === 'function') &&
+    baseRef !== null &&
+    Object.prototype.hasOwnProperty.call(baseRef, key)
+  );
+}
+
+function isChainKey(key) {
+  return Object.prototype.hasOwnProperty.call(PROTOTYPE_CHAIN_KEYS, key);
+}
+
+function isBlockedPrototypeKey(baseRef, key, isEnd) {
+  if (key === PROTO_KEY) {
+    return true;
+  }
+
+  // Function.prototype is a shared prototype object; reading or assigning
+  // through it can expose or affect objects created by that constructor.
+  if (key === 'prototype' && typeof baseRef === 'function') {
+    return true;
+  }
+
+  // `constructor` and `prototype` are valid own data fields. They are only
+  // dangerous when traversal would fall through to inherited prototype-chain
+  // properties such as Object.constructor.prototype.
+  return !isEnd && isChainKey(key) && !hasOwnProperty(baseRef, key);
+}
+
+function hasBlockedUnknownPrototypePath(keys, startIndex) {
+  // If an earlier safe segment is missing, the RHS may create it. Before
+  // evaluating RHS we can only allow the path when the remaining unresolved
+  // suffix does not contain keys that could later traverse prototypes.
+  for (var i = startIndex; i < keys.length; i++) {
+    var key = keys[i];
+    var isEnd = i === keys.length - 1;
+    if (key === PROTO_KEY || (!isEnd && isChainKey(key))) {
+      return true;
+    }
+  }
+  return false;
+}
+
+module.exports = {
+  PROTO_KEY: PROTO_KEY,
+  hasOwnProperty: hasOwnProperty,
+  isBlockedPrototypeKey: isBlockedPrototypeKey,
+  hasBlockedUnknownPrototypePath: hasBlockedUnknownPrototypePath,
+};
