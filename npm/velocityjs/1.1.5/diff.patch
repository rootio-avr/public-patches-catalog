diff --git a/src/compile/prototype-guard.js b/src/compile/prototype-guard.js
new file mode 100644
index 0000000..77273c3
--- /dev/null
+++ b/src/compile/prototype-guard.js
@@ -0,0 +1,42 @@
+'use strict';
+
+var PROTO_KEY = '__proto__';
+var PROTOTYPE_CHAIN_KEYS = { constructor: true, prototype: true };
+
+function hasOwnProperty(baseRef, key) {
+  return (
+    (typeof baseRef === 'object' || typeof baseRef === 'function') &&
+    baseRef !== null &&
+    Object.prototype.hasOwnProperty.call(baseRef, key)
+  );
+}
+
+/**
+ * Blocks the property keys used to walk from a template-controlled reference
+ * up to `Function` (`__proto__`, inherited `constructor`/`prototype`), which
+ * is the gadget chain used to reach RCE from untrusted templates.
+ *
+ * `isEnd` marks whether `key` is the last segment of the path being resolved.
+ * Assigning a literal `constructor`/`prototype` field as the final segment of
+ * a `#set` (creating an own data property) is harmless, so it's only treated
+ * as dangerous when it isn't the final segment and isn't already an own
+ * property, i.e. when it would be used to keep walking the prototype chain.
+ */
+function isBlockedPrototypeKey(baseRef, key, isEnd) {
+  if (key === PROTO_KEY) {
+    return true;
+  }
+
+  // Function.prototype is a shared prototype object; reading or assigning
+  // through it can expose or affect every object created by that constructor.
+  if (key === 'prototype' && typeof baseRef === 'function') {
+    return true;
+  }
+
+  return !isEnd && PROTOTYPE_CHAIN_KEYS.hasOwnProperty(key) && !hasOwnProperty(baseRef, key);
+}
+
+module.exports = {
+  hasOwnProperty: hasOwnProperty,
+  isBlockedPrototypeKey: isBlockedPrototypeKey
+};
