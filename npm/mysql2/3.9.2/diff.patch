+'use strict';
+
+// Regression test for CVE-2024-21507 (parser cache poisoning, CWE-20).
+// Field/table values that contain the old ':' and '/' delimiters must no
+// longer collapse into a colliding parser-cache key. Grounded in upstream
+// test/unit/parsers/cache-key-serialization.js
+// @ 0d54b0ca6498c823098426038162ef10df02c818.
+
+const assert = require('assert');
+const _keyFromFields =
+  require('../../../lib/parsers/parser_cache.js')._keyFromFields;
+
+const options = {};
+const config = {};
+
+// Two DIFFERENT field sets that produced an IDENTICAL key under the old
+// delimiter-based ("name:columnType:length:schema:table:flags:characterSet")
+// string concatenation:
+//   fieldsA -> "a:b:c:undefined:undefined:undefined:undefined"
+//   fieldsB -> "a:b:c:undefined:undefined:undefined:undefined"
+const fieldsA = [
+  {
+    name: 'a:b',
+    columnType: 'c',
+    length: undefined,
+    schema: undefined,
+    table: undefined,
+    flags: undefined,
+    characterSet: undefined,
+  },
+];
+const fieldsB = [
+  {
+    name: 'a',
+    columnType: 'b',
+    length: 'c',
+    schema: undefined,
+    table: undefined,
+    flags: undefined,
+    characterSet: undefined,
+  },
+];
+
+const keyA = _keyFromFields('binary', fieldsA, options, config);
+const keyB = _keyFromFields('binary', fieldsB, options, config);
+
+// The fix must keep these distinct (no cache poisoning / key collision).
+assert.notStrictEqual(keyA, keyB);
+
+// Keys are now JSON-serialized and must parse cleanly.
+assert(JSON.parse(keyA));
+assert(JSON.parse(keyB));
+
+// Field values containing delimiter / quote characters must still yield
+// valid JSON keys (mirrors upstream "forcing delimiters on strings" case).
+const trickyFields = [
+  {
+    name: ':',
+    columnType: '©',
+    length: undefined,
+    schema: '/',
+    table: ',',
+    flags: '_',
+    characterSet: '❌',
+  },
+];
+const trickyKey = _keyFromFields('binary', trickyFields, { timezone: '""`\'' }, config);
+assert(JSON.parse(trickyKey));

