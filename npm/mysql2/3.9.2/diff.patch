+'use strict';
+
+// Regression test for CVE-2024-21509 (prototype pollution via result object creation).
+//
+// Grounded in the upstream fix commit 4a964a3910a4b8de008696c554ab1b492e9b4691:
+//   test/esm/unit/parsers/prototype-binary-results.test.mjs
+//   test/esm/unit/parsers/prototype-text-results.test.mjs
+// Those tests require a live MySQL server (poku + connection.query/execute). This target
+// (mysql2 3.9.2) predates the ESM/poku migration and runs plain CommonJS unit tests with
+// `require('assert')`, so this test drives the row parsers directly with a stub packet --
+// no DB, no build -- while asserting the same fixed behavior the upstream tests assert:
+//   * the parsed row object has a null prototype (Object.getPrototypeOf(row) === null),
+//   * it does NOT inherit Object.prototype members (typeof row.toString === 'undefined'),
+//   * parsed column values still keep their own prototypes (2..toString() works),
+//   * a column aliased "__proto__" must NOT pollute Object.prototype.
+
+const assert = require('assert');
+const Types = require('../../../lib/constants/types.js');
+const getTextParser = require('../../../lib/parsers/text_parser.js');
+const getBinaryParser = require('../../../lib/parsers/binary_parser.js');
+
+// Two columns, one of them maliciously aliased "__proto__" (the attacker-controlled
+// column alias that CVE-2024-21509 abuses), plus a normal "test" column.
+const fields = [
+  { name: 'test', columnType: Types.LONG },
+  { name: '__proto__', columnType: Types.LONG },
+];
+
+const options = {};
+const config = {};
+
+// Stub packet: the compiled parser for LONG columns calls parseLengthCodedIntNoBigCheck()
+// (text) / readSInt32() (binary); the binary path also reads a status byte and null-bitmap
+// bytes via readInt8(). Returning 0 for the bitmap bytes marks every column as non-null.
+function makeStubPacket() {
+  return {
+    readInt8() {
+      return 0;
+    },
+    parseLengthCodedIntNoBigCheck() {
+      return 2;
+    },
+    readSInt32() {
+      return 2;
+    },
+  };
+}
+
+function assertCleanRow(row, label) {
+  assert.strictEqual(
+    Object.getPrototypeOf(row),
+    null,
+    `${label}: row object must have a null prototype`,
+  );
+  assert.strictEqual(
+    typeof row.toString,
+    'undefined',
+    `${label}: row object must not inherit Object.prototype members`,
+  );
+  // End-user values must still behave normally (they keep their own prototypes).
+  assert.strictEqual(row.test, 2, `${label}: normal column value preserved`);
+  assert.strictEqual(
+    typeof row.test.toString,
+    'function',
+    `${label}: parsed values keep their own prototype`,
+  );
+  // The malicious "__proto__" alias is stored as a plain own data property and does not
+  // reassign the object's prototype.
+  assert.strictEqual(
+    Object.prototype.hasOwnProperty.call(row, '__proto__'),
+    true,
+    `${label}: "__proto__" column stored as own property`,
+  );
+}
+
+// --- Text protocol row parser ---
+const TextRow = getTextParser(fields, options, config);
+const textRow = new TextRow(fields);
+const textResult = textRow.next(makeStubPacket(), fields, options);
+assertCleanRow(textResult, 'text parser');
+
+// --- Binary protocol row parser ---
+const BinaryRow = getBinaryParser(fields, options, config);
+const binaryRow = new BinaryRow(fields);
+const binaryResult = binaryRow.next(makeStubPacket(), fields, options);
+assertCleanRow(binaryResult, 'binary parser');
+
+// Global sanity check: parsing an attacker-controlled "__proto__" alias must never leak
+// onto the global Object.prototype.
+assert.strictEqual(
+  {}.polluted,
+  undefined,
+  'Object.prototype must not be polluted after parsing',
+);
+assert.strictEqual(
+  typeof Object.prototype.__proto__polluted,
+  'undefined',
+  'Object.prototype must not gain attacker-controlled members',
+);
+
+// eslint-disable-next-line no-console
+console.log('CVE-2024-21509 prototype-pollution regression test passed');
