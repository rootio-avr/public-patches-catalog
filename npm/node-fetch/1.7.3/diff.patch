+// CVE-2022-0235: use WHATWG URL parser for redirect-target comparison
+var URL = require('url').URL;
+
+// Determine whether `destination` is the same host as `original` or a subdomain of it.
+// Used to decide whether to forward `authorization`/`cookie`/`www-authenticate`/`cookie2`
+// headers across a redirect.
+function isDomainOrSubdomain(destination, original) {
+	var orig = new URL(original).hostname;
+	var dest = new URL(destination).hostname;
+	return orig === dest || (orig[orig.length - dest.length - 1] === '.' && orig.endsWith(dest));
+}
