# CVE-2025-6545: pbkdf2 returns predictable/zero-filled output for non-normalized
# or unsupported digest algorithm names.
#
# The JS-fallback pbkdf2 implementation (lib/sync.js, lib/sync-browser.js) silently
# accepted any string as the digest name. When the name was non-canonical (e.g.
# 'SHA-1', 'Sha256', 'sha-256') or referenced a Node-valid-but-here-unimplemented
# algorithm (e.g. 'sha3-512', 'blake2b512'), the lookup `sizes[digest]` returned
# undefined, the HMAC step produced unusable output, and the derived key buffer
# was returned containing predictable / zero-filled memory rather than throwing.
#
# Fix: normalize the digest name (lowercase + map dashed aliases such as 'sha-1'
# to 'sha1'), validate it against the supported sizes table, and throw a
# TypeError for any unsupported digest. Adapted from upstream commit
# 26d4fd391e00ed806840ea1ef7341937985f4ba8 (browserify/pbkdf2). Style preserved
# to match v3.1.2 (2-space indent, no semicolons, no `__proto__: null` to avoid
# requiring a stricter eslint config). No new runtime dependencies are introduced.
#
# Origin: https://github.com/browserify/pbkdf2/commit/26d4fd391e00ed806840ea1ef7341937985f4ba8
--- a/lib/sync.js
+++ b/lib/sync.js
@@ -9,6 +9,15 @@ var sizes = {
   ripemd160: 20
 }

+var mapping = {
+  'sha-1': 'sha1',
+  'sha-224': 'sha224',
+  'sha-256': 'sha256',
+  'sha-384': 'sha384',
+  'sha-512': 'sha512',
+  'ripemd-160': 'ripemd160'
+}
+
 var createHmac = require('create-hmac')
 var Buffer = require('safe-buffer').Buffer

@@ -21,24 +30,29 @@ function pbkdf2 (password, salt, iterations, keylen, digest) {
   password = toBuffer(password, defaultEncoding, 'Password')
   salt = toBuffer(salt, defaultEncoding, 'Salt')

-  digest = digest || 'sha1'
+  var lowerDigest = (digest || 'sha1').toLowerCase()
+  var mappedDigest = Object.prototype.hasOwnProperty.call(mapping, lowerDigest) ? mapping[lowerDigest] : lowerDigest
+  var size = Object.prototype.hasOwnProperty.call(sizes, mappedDigest) ? sizes[mappedDigest] : undefined
+  if (typeof size !== 'number' || !size) {
+    throw new TypeError('Digest algorithm not supported: ' + digest)
+  }

   var DK = Buffer.allocUnsafe(keylen)
   var block1 = Buffer.allocUnsafe(salt.length + 4)
   salt.copy(block1, 0, 0, salt.length)

   var destPos = 0
-  var hLen = sizes[digest]
+  var hLen = size
   var l = Math.ceil(keylen / hLen)

   for (var i = 1; i <= l; i++) {
     block1.writeUInt32BE(i, salt.length)

-    var T = createHmac(digest, password).update(block1).digest()
+    var T = createHmac(mappedDigest, password).update(block1).digest()
     var U = T

     for (var j = 1; j < iterations; j++) {
-      U = createHmac(digest, password).update(U).digest()
+      U = createHmac(mappedDigest, password).update(U).digest()
       for (var k = 0; k < hLen; k++) T[k] ^= U[k]
     }

