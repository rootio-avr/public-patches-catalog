Fix CVE-2024-37890: DoS when handling request with many HTTP headers

A request with a number of headers exceeding the server.maxHeadersCount
threshold could be used to crash a ws server due to NULL Pointer Dereference
when calling toLowerCase() on undefined Upgrade header.

This patch checks if the Upgrade header is undefined before attempting to
call toLowerCase() on it.

Origin: upstream, https://github.com/websockets/ws/commit/22c28763234aa75a7e1b76f5c01c181260d7917f
Bug: https://github.com/websockets/ws/issues/2230

--- a/lib/websocket-server.js
+++ b/lib/websocket-server.js
@@ -184,12 +184,14 @@ class WebSocketServer extends EventEmitter {
       req.headers['sec-websocket-key'] !== undefined
         ? req.headers['sec-websocket-key'].trim()
         : false;
+    const upgrade = req.headers.upgrade;
     const version = +req.headers['sec-websocket-version'];
     const extensions = {};

     if (
       req.method !== 'GET' ||
-      req.headers.upgrade.toLowerCase() !== 'websocket' ||
+      upgrade === undefined ||
+      upgrade.toLowerCase() !== 'websocket' ||
       !key ||
       !keyRegex.test(key) ||
       (version !== 8 && version !== 13) ||
