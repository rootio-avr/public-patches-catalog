+		const ctCalled = vm.run(`
+			let ctInvocations = 0;
+			class Fake1 extends Promise {
+				static get [Symbol.species](){
+					return function(executor){
+						ctInvocations++;
+						executor(function(){}, function(){});
+					};
+				}
+			}
