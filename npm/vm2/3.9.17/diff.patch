+	const g = ({}).__lookupGetter__;
+	const a = Buffer.apply;
+	const p = a.apply(g, [Buffer, ['__proto__']]);
+	const op = p.call(p.call(p.call(p.call(Buffer.of()))));
+	const ho = op.constructor; // host Object
+`;
