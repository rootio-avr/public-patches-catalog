 	VMScript
 } = require('./script');
+const {
+	inspect
+} = require('util');

 const objectDefineProperties = Object.defineProperties;

@@ -365,6 +368,8 @@ class VM extends EventEmitter {
 			_allowAsync: {__proto__: null, value: allowAsync}
 		});

