+'use strict';
+
+/*
+ * Regression test for CVE-2020-7676 — AngularJS jqLite mutation-XSS via
+ * regex-based HTML replacement (CWE-79).
+ *
+ * Grounded in the upstream fix's own regression test:
+ *   angular/angular.js commit 2df43c07779137d1bddf7f3b282a1287a8634acd (PR #17028)
+ *   test/jqLiteSpec.js -> describe('jqLite') > describe('security') >
+ *   it("shouldn't unsanitize sanitized code")
+ * The payloads below are the Masato Kinugawa / Cure53 cases from that block.
+ *
+ * The shipped angular@1.3.0 npm package is a flat bundle (angular.js at the
+ * package root, no test/ dir, no jasmine/karma), so this is a self-contained
+ * Node + jsdom script rather than a karma spec. It exercises the same jqLite
+ * parse path (angular.element(payload) -> .append) the upstream test uses, and
+ * asserts the FIXED behavior: sanitized markup must stay sanitized, i.e. jqLite
+ * must NOT re-interpret it into a live <img onerror> node and the injected
+ * onerror marker must NOT fire.
+ *
+ * Dependency: jsdom (a real HTML parser is required to observe the re-parse —
+ * a string check is insufficient). The pre-patch PoC in this pipeline used
+ * jsdom@19 under node:20-slim; any recent jsdom works.
+ *
+ * Exit 0 = patched/secure. Non-zero (assertion throw) = still vulnerable.
+ */
+
+var assert = require('assert');
+var path = require('path');
+var JSDOM = require('jsdom').JSDOM;
+
+var dom = new JSDOM('<!DOCTYPE html><html><head></head><body></body></html>', {
+  url: 'http://localhost/',
+  pretendToBeVisual: true
+});
+
+global.window = dom.window;
+global.document = dom.window.document;
+global.navigator = dom.window.navigator;
+
+// XSS marker spy: set only if an injected event handler actually executes.
+// Mirrors upstream `window.xss = jasmine.createSpy('xss')`.
+var xssHits = [];
+window.xss = function (n) {
+  xssHits.push(n);
+};
+
+// Load the patched bundle that sits next to this test's package root.
+require(path.join(__dirname, '..', 'angular.js'));
+var angular = window.angular;
+
+assert.strictEqual(typeof angular.element, 'function',
+  'angular.element must be available');
+
+// The fix ships an opt-in to restore the old (insecure) behavior; its presence
+// is a cheap signal that the CVE-2020-7676 fix is actually applied.
+assert.strictEqual(typeof angular.UNSAFE_restoreLegacyJqLiteXHTMLReplacement, 'function',
+  'CVE-2020-7676 fix missing: UNSAFE_restoreLegacyJqLiteXHTMLReplacement is not defined');
+
+// Cure53 / Masato Kinugawa payloads from the upstream "security" block.
+// The <option>...</select>...<img onerror> case specifically exercises the
+// wrapMap / jqLiteBuildFragment rewrite this patch changes.
+var payloads = [
+  '<img alt="<x" title="/><img src=url404 onerror=xss(0)>">',
+  '<style><style/><img src=url404 onerror=xss(2)>',
+  '<title><title /><img src=url404 onerror=xss(4)>',
+  '<noscript/><img src=url404 onerror=xss(10)>',
+  '<option><style></option></select><img src=url404 onerror=xss(12)></style>'
+];
+
+var container = angular.element('<div></div>');
+angular.element(document.body).append(container);
+
+payloads.forEach(function (htmlString) {
+  var element = angular.element('<div></div>');
+  container.append(element);
+  element.append(angular.element(htmlString));
+});
+
+// Give any (mis)parsed <img onerror> a tick to attempt to dispatch, then assert
+// the FIXED behavior on both signals used by this pipeline's PoC.
+window.setTimeout(function () {
+  try {
+    // Signal 1 (upstream semantics): the onerror marker must never fire.
+    assert.strictEqual(xssHits.length, 0,
+      'CVE-2020-7676 regression: jqLite unsanitized markup and xss() fired for payload(s) ' +
+      JSON.stringify(xssHits));
+
+    // Signal 2 (deterministic, headless): no live <img onerror> node should
+    // have been produced from the sanitized input. This is the exact signal
+    // the pre-patch PoC used to confirm the vulnerability.
+    var leaked = document.querySelectorAll('img[onerror]');
+    assert.strictEqual(leaked.length, 0,
+      'CVE-2020-7676 regression: jqLite produced ' + leaked.length +
+      ' live <img onerror> node(s) from sanitized markup');
+
+    delete window.xss;
+    console.log('OK: CVE-2020-7676 fixed — sanitized markup stayed sanitized ' +
+      '(no xss() fired, no img[onerror] leaked)');
+    process.exit(0);
+  } catch (e) {
+    console.error(e.message);
+    process.exit(1);
+  }
+}, 1000);

