From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
Date: Mon, 03 Mar 2026 00:00:00 +0000
Subject: [PATCH] CVE-2026-27699: Validate filenames before download to prevent path traversal

---
 dist/Client.js | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/dist/Client.js b/dist/Client.js
index d91aa92..36a58a5 100644
--- a/dist/Client.js
+++ b/dist/Client.js
@@ -617,6 +617,12 @@ class Client {
     async _downloadFromWorkingDir(localDirPath) {
         await ensureLocalDirectory(localDirPath);
         for (const file of await this.list()) {
+            const hasInvalidName = !file.name || (0, path_1.basename)(file.name) !== file.name;
+            if (hasInvalidName) {
+                const safeName = JSON.stringify(file.name);
+                this.ftp.log(`Invalid filename from server listing, will skip file. (${safeName})`);
+                continue;
+            }
             const localPath = (0, path_1.join)(localDirPath, file.name);
             if (file.isDirectory) {
                 await this.cd(file.name);
