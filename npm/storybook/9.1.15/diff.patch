diff --git a/code/core/src/core-server/utils/validate-websocket-token.ts b/code/core/src/core-server/utils/validate-websocket-token.ts
new file mode 100644
index 0000000..ec4ff57
--- /dev/null
+++ b/code/core/src/core-server/utils/validate-websocket-token.ts
@@ -0,0 +1,20 @@
+import { timingSafeEqual } from 'node:crypto';
+
+/**
+ * Validates a secret token using constant-time comparison to prevent timing attacks.
+ *
+ * @returns `true` if tokens match, `false` otherwise
+ */
+export function isValidToken(token: string | null, expectedToken: string): boolean {
+  if (!token || !expectedToken) {
+    return false;
+  }
+
+  const a = Buffer.from(token, 'utf8');
+  const b = Buffer.from(expectedToken, 'utf8');
+  try {
+    return a.length === b.length && timingSafeEqual(a, b);
+  } catch {
+    return false;
+  }
+}
