CVE-2018-16487: Prevent prototype pollution in _.merge

This patch prevents Object.prototype from being augmented via
the merge, mergeWith, and defaultsDeep functions by:
1. Blocking __proto__ key writes (direct prototype pollution)
2. Blocking any property writes to Object.prototype itself (indirect pollution)

Backported from upstream fix commit 90e6199a161b6445b01454517b40ef65ebecd2ad

--- a/lodash.js
+++ b/lodash.js
@@ -1565,7 +1565,12 @@
             value = result;
           }
         }
-        object[key] = value;
+        // CVE-2018-16487: Prevent prototype pollution
+        // Block __proto__ writes and any writes to Object.prototype
+        if (key === '__proto__' || object === objectProto) {
+          return;
+        }
+        object[key] = value;
       });
     }


