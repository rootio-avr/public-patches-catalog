CVE-2026-48815: tighten verifyOIDs raw extnValue comparison

Backport of sigstore/sigstore-js@7845532 (packages/verify/src/policy.ts +
key/index.ts) to v1.5.2's packages/client/src/ca/verify/signer.ts. In 1.5.2
verifyOIDs may fall through to comparing against a decoded inner UTF8String
sub, which lets a crafted multi-sub extension satisfy an OID policy without
matching the actual extnValue bytes. This patch tries the raw-bytes match
first, then only falls back to the inner-sub match when the extension body
has EXACTLY ONE sub (the well-formed UTF8String-wrap case). Multi-sub
structures — the CVE-2026-48815 attack surface — no longer satisfy an OID
check by unwrapping arbitrary nested ASN.1. Preserves backward-compat with
newer-style single-sub UTF8String extensions (e.g. Fulcio
1.3.6.1.4.1.57264.1.20 "build trigger" = UTF8String("workflow_dispatch")).

--- a/packages/client/src/ca/verify/signer.ts
+++ b/packages/client/src/ca/verify/signer.ts
@@ -141,12 +141,23 @@ function verifyOIDs(
       return false;
     }

-    // Check to see if this is a newer style extension with an embedded
-    // UTF8String, or an older style extension with a raw string
-    if (valueObj.subs.length > 0) {
-      return valueObj.subs[0].value.equals(expectedExtension.value);
-    } else {
-      return valueObj.value.equals(expectedExtension.value);
+    // Match against the raw extnValue contents. This aligns with the
+    // upstream OID-extension verification path (sigstore/sigstore-js#1658)
+    // which compares against ext.subs[len-1].value.
+    if (valueObj.value.equals(expectedExtension.value)) {
+      return true;
     }
+
+    // Backward-compat: some newer-style extensions wrap the value in a
+    // single UTF8String sub. Only accept the decoded-sub match when the
+    // extension body has exactly one sub; multi-sub structures are the
+    // CVE-2026-48815 attack surface (arbitrary nested ASN.1 could
+    // otherwise satisfy an OID policy without matching the raw extension
+    // bytes).
+    if (valueObj.subs.length === 1) {
+      return valueObj.subs[0].value.equals(expectedExtension.value);
+    }
+
+    return false;
   });
 }
