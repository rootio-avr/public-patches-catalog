+'use strict'
+
+const { test } = require('tap')
+const { fetch } = require('../..')
+const { createServer } = require('http')
+const { once, getEventListeners } = require('events')
+
+// Regression test for AIKIDO-2024-10065 (CWE-401).
+//
+// undici's fetch() attaches an 'abort' listener to the caller-provided
+// AbortSignal on every call. Before the fix it was never released on normal
+// completion, so reusing one long-lived AbortController/AbortSignal across many
+// fetch() calls let the signal's 'abort' listeners accumulate unbounded, which
+// tripped a MaxListenersExceededWarning (old cap: 100) and leaked memory.
+//
+// The fix raises the per-signal listener cap (100 -> 1500) and releases the
+// listener through buildAbort()/the finalizer, keeping the count bounded.
+//
+// Grounded in upstream test/fetch/long-lived-abort-controller.js
+// @ c0a0bb5b8ba50d921a7903870ba86af5200f8be2 (nodejs/undici PR #3158), which
+// fires 2000 requests against one shared signal and asserts no warning is
+// emitted. Trimmed to a smaller request count here (still above the old cap of
+// 100, well under the raised cap of 1500) to keep the regression cheap while
+// preserving the same signal.
+test('fetch does not leak abort listeners on a long-lived AbortController', async (t) => {
+  t.plan(2)
+
+  const server = createServer((req, res) => {
+    res.writeHead(200, { 'content-type': 'text/plain' })
+    res.end('Hello World!')
+  }).listen(0)
+
+  t.teardown(server.close.bind(server))
+  await once(server, 'listening')
+
+  // Capture any MaxListenersExceededWarning produced while hammering the signal.
+  let maxListenersWarning = null
+  const onWarning = (warning) => {
+    if (warning.name === 'MaxListenersExceededWarning') {
+      maxListenersWarning = warning
+    }
+  }
+  process.on('warning', onWarning)
+  t.teardown(() => process.off('warning', onWarning))
+
+  // A single controller / signal shared across every request: the leak scenario.
+  const controller = new AbortController()
+  const { signal } = controller
+
+  const requestCount = 200
+  for (let i = 0; i < requestCount; i++) {
+    const res = await fetch(`http://localhost:${server.address().port}`, { signal })
+    await res.text() // drain the body so the request settles
+  }
+
+  // Post-fix the raised cap absorbs the shared signal's listeners; pre-fix the
+  // old cap of 100 would have been breached and a warning emitted.
+  t.equal(maxListenersWarning, null, 'no MaxListenersExceededWarning was emitted')
+
+  // The signal's live 'abort' listener count stays bounded (at most one per
+  // outstanding request) rather than growing without limit.
+  const abortListeners = getEventListeners(signal, 'abort').length
+  t.ok(
+    abortListeners <= requestCount,
+    `abort listener count stayed bounded (${abortListeners} <= ${requestCount})`
+  )
+})
