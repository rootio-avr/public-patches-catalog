+
+var str = Flatted.stringify(chain);
+console.log('stringify', '✅');
+
+var parsed = Flatted.parse(str);
+
+var current = parsed;
+for (i = 0; i < AMOUNT; i++) {
+  current = current[0];
+}
+console.log(current);
+console.log('parse', '✅');

