# Patch for CVE-2026-33036
# Fix entity expansion limit bypass via standard/HTML entities in fast-xml-parser
#
# replaceEntitiesValue() in OrderedObjParser.js only enforced expansion counting
# on DOCTYPE-defined entities. The lastEntities loop (handling standard XML entities
# &lt;, &gt;, &quot;, &apos; and numeric references &#NNN;/&#xHH;) and the
# htmlEntities loop performed no counting at all, allowing an attacker to supply
# 1M+ numeric/standard entity references and force heavy memory allocation and
# CPU usage — even when strict maxTotalExpansions limits were configured.
#
# Fix: Add expansion count tracking (entityExpansionCount += matches.length) and
# maxTotalExpansions enforcement to both the lastEntities and htmlEntities loops,
# matching the existing pattern already used for docTypeEntities. Also converts
# for-in to for-of with Object.keys() to avoid prototype chain enumeration.
#
# Severity: high (CVSS 3.1: 7.5)
# Affected versions: 4.0.0-beta.3 - 5.5.5
# Fixed in: 5.5.6
# Upstream commit: https://github.com/NaturalIntelligence/fast-xml-parser/commit/bd26122c838e6a55e7d7ac49b4ccc01a49999a01
# Advisory: https://github.com/NaturalIntelligence/fast-xml-parser/security/advisories/GHSA-8gc5-j5rx-235r

--- a/src/xmlparser/OrderedObjParser.js
+++ b/src/xmlparser/OrderedObjParser.js
@@ -488,7 +488,7 @@ const replaceEntitiesValue = function (val, tagName, jPath) {
   }

   // Replace DOCTYPE entities
-  for (let entityName in this.docTypeEntities) {
+  for (const entityName of Object.keys(this.docTypeEntities)) {
     const entity = this.docTypeEntities[entityName];
     const matches = val.match(entity.regx);

@@ -520,19 +520,37 @@ const replaceEntitiesValue = function (val, tagName, jPath) {
       }
     }
   }
-  if (val.indexOf('&') === -1) return val;  // Early exit
-
   // Replace standard entities
-  for (let entityName in this.lastEntities) {
+  for (const entityName of Object.keys(this.lastEntities)) {
     const entity = this.lastEntities[entityName];
+    const matches = val.match(entity.regex);
+    if (matches) {
+      this.entityExpansionCount += matches.length;
+      if (entityConfig.maxTotalExpansions &&
+        this.entityExpansionCount > entityConfig.maxTotalExpansions) {
+        throw new Error(
+          `Entity expansion limit exceeded: ${this.entityExpansionCount} > ${entityConfig.maxTotalExpansions}`
+        );
+      }
+    }
     val = val.replace(entity.regex, entity.val);
   }
-  if (val.indexOf('&') === -1) return val;  // Early exit
+  if (val.indexOf('&') === -1) return val;

   // Replace HTML entities if enabled
   if (this.options.htmlEntities) {
-    for (let entityName in this.htmlEntities) {
+    for (const entityName of Object.keys(this.htmlEntities)) {
       const entity = this.htmlEntities[entityName];
+      const matches = val.match(entity.regex);
+      if (matches) {
+        this.entityExpansionCount += matches.length;
+        if (entityConfig.maxTotalExpansions &&
+          this.entityExpansionCount > entityConfig.maxTotalExpansions) {
+          throw new Error(
+            `Entity expansion limit exceeded: ${this.entityExpansionCount} > ${entityConfig.maxTotalExpansions}`
+          );
+        }
+      }
       val = val.replace(entity.regex, entity.val);
     }
   }

# Patch for CVE-2026-33349
# Fix entity protection limits bypass via zero/falsy values in fast-xml-parser
#
# DocTypeReader.js uses JavaScript truthy checks to evaluate maxEntitySize.
# When a developer explicitly sets maxEntitySize to 0 — intending to disallow
# all entity values — the falsy nature of 0 in JS causes the guard condition
# to short-circuit, completely bypassing the limit. Similarly, setting
# maxTotalExpansions, maxExpansionDepth, or maxExpandedLength to 0 or a
# negative value allows unbounded entity expansion, enabling XML entity
# expansion Denial of Service.
#
# Fix 1 (DocTypeReader.js): Change falsy check `this.options.maxEntitySize &&`
#   to explicit null check `this.options.maxEntitySize != null &&` so that
#   maxEntitySize=0 is treated as "limit to 0 bytes" rather than "no limit".
# Fix 2 (OptionsBuilder.js): Wrap all numeric limit defaults with Math.max(1, ...)
#   to ensure none of the entity protection options can be set to a non-positive
#   value via the object config form of processEntities.
#
# Severity: medium (CVSS 3.1: 5.9)
# Affected versions: 4.0.0-beta.3 - 5.5.6
# Fixed in: 5.5.7
# Upstream commit: https://github.com/NaturalIntelligence/fast-xml-parser/commit/239b64aa1fc5c5455ddebbbb54a187eb68c9fdb7
# Advisory: https://github.com/NaturalIntelligence/fast-xml-parser/security/advisories/GHSA-jp2q-39xq-3w4g

--- a/src/xmlparser/DocTypeReader.js
+++ b/src/xmlparser/DocTypeReader.js
@@ -122,7 +122,7 @@ class DocTypeReader {

         // Validate entity size
         if (this.options.enabled !== false &&
-            this.options.maxEntitySize &&
+            this.options.maxEntitySize != null &&
             entityValue.length > this.options.maxEntitySize) {
             throw new Error(
                 `Entity "${entityName}" size (${entityValue.length}) exceeds maximum allowed size (${this.options.maxEntitySize})`
--- a/src/xmlparser/OptionsBuilder.js
+++ b/src/xmlparser/OptionsBuilder.js
@@ -66,10 +66,10 @@ function normalizeProcessEntities(value) {
   // Object config - merge with defaults
   if (typeof value === 'object' && value !== null) {
     return {
       enabled: value.enabled !== false, // default true if not specified
-      maxEntitySize: value.maxEntitySize ?? 10000,
-      maxExpansionDepth: value.maxExpansionDepth ?? 10,
-      maxTotalExpansions: value.maxTotalExpansions ?? 1000,
-      maxExpandedLength: value.maxExpandedLength ?? 100000,
+      maxEntitySize: Math.max(1, value.maxEntitySize ?? 10000),
+      maxExpansionDepth: Math.max(1, value.maxExpansionDepth ?? 10),
+      maxTotalExpansions: Math.max(1, value.maxTotalExpansions ?? 1000),
+      maxExpandedLength: Math.max(1, value.maxExpandedLength ?? 100000),
       allowedTags: value.allowedTags ?? null,
       tagFilter: value.tagFilter ?? null
     };

# Patch for CVE-2026-41650
# Fix XML comment and CDATA injection via unescaped delimiters in XMLBuilder
