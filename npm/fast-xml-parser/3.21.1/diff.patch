# Patch for CVE-2023-26920
# Fix prototype pollution via __proto__ tag or attribute names in fast-xml-parser
#
# When XML input contains __proto__ as an element or attribute name, the parser
# assigns properties to Object.prototype instead of a normal object key.
#
# Fix: Rename __proto__ to #__proto__ during parsing in addChild, buildAttributesMap,
# and tag name handling for opening/self-closing tags.
#
# Severity: high
# Affected versions: < 4.1.2 (including 3.x)
# Fixed in: 4.1.2
# Upstream commit: https://github.com/NaturalIntelligence/fast-xml-parser/commit/2b032a4f799c63d83991e4f992f1c68e4dd05804
# Advisory: https://github.com/NaturalIntelligence/fast-xml-parser/security/advisories/GHSA-x3cc-x39p-42qx

--- a/src/xmlNode.js
+++ b/src/xmlNode.js
@@ -7,6 +7,7 @@
   this.attrsMap = {}; //attributes map
   this.val = val; //text only
   this.addChild = function(child) {
+    if (child.tagname === "__proto__") child.tagname = "#__proto__";
     if (Array.isArray(this.child[child.tagname])) {
       //already presents
       this.child[child.tagname].push(child);
--- a/src/xmlstr2xmlnode.js
+++ b/src/xmlstr2xmlnode.js
@@ -136,18 +136,20 @@
     for (let i = 0; i < len; i++) {
       const attrName = resolveNameSpace(matches[i][1], options);
       if (attrName.length) {
+        let aName = options.attributeNamePrefix + attrName;
+        if (aName === "__proto__") aName = "#__proto__";
         if (matches[i][4] !== undefined) {
           if (options.trimValues) {
             matches[i][4] = matches[i][4].trim();
           }
           matches[i][4] = options.attrValueProcessor(matches[i][4], attrName);
-          attrs[options.attributeNamePrefix + attrName] = parseValue(
+          attrs[aName] = parseValue(
             matches[i][4],
             options.parseAttributeValue,
             options.numParseOptions
           );
         } else if (options.allowBooleanAttributes) {
-          attrs[options.attributeNamePrefix + attrName] = true;
+          attrs[aName] = true;
         }
       }
     }
@@ -279,6 +281,7 @@
             tagExp = tagExp.substr(0, tagExp.length - 1);
           }
 
+          if (tagName === "__proto__") tagName = "#__proto__";
           const childNode = new xmlNode(tagName, currentNode, '');
           if(tagName !== tagExp){
             childNode.attrsMap = buildAttributesMap(tagExp, options);
@@ -286,6 +289,7 @@
           currentNode.addChild(childNode);
         }else{//opening tag
 
+          if (tagName === "__proto__") tagName = "#__proto__";
           const childNode = new xmlNode( tagName, currentNode );
           if (options.stopNodes.length && options.stopNodes.includes(childNode.tagname)) {
             childNode.startIndex=closeIndex;

# Patch for CVE-2026-41650
# Fix CDATA injection via unescaped ]]> delimiters in fast-xml-parser v3 builder
#
# v3.21.1 uses src/json2xml.js (not xmlbuilder/) for JSON-to-XML conversion.
# replaceCDATAstr() and replaceCDATAarr() embed user-controlled CDATA values
# without escaping ]]> sequences, allowing XML injection.
#
# Note: v3.21.1 has no comment builder API, so only CDATA paths are affected.
#
# Fix: Escape ]]> in CDATA content using the standard split-and-rejoin pattern.
#
# Severity: medium
# Affected versions: prior to 5.7.0
# Fixed in: 5.7.0
# Advisory: https://github.com/NaturalIntelligence/fast-xml-parser/security/advisories/GHSA-gh4j-gqv2-49f6

--- a/src/json2xml.js
+++ b/src/json2xml.js
@@ -173,23 +173,27 @@ function processTextOrObjNode (object, key, level) {
   }
 }
 
+function escapeCdata(val) {
+  return String(val).replace(/\]\]>/g, ']]]]><![CDATA[>');
+}
+
 function replaceCDATAstr(str, cdata) {
   str = this.options.tagValueProcessor('' + str);
   if (this.options.cdataPositionChar === '' || str === '') {
-    return str + '<![CDATA[' + cdata + ']]' + this.tagEndChar;
+    return str + '<![CDATA[' + escapeCdata(cdata) + ']]' + this.tagEndChar;
   } else {
-    return str.replace(this.options.cdataPositionChar, '<![CDATA[' + cdata + ']]' + this.tagEndChar);
+    return str.replace(this.options.cdataPositionChar, '<![CDATA[' + escapeCdata(cdata) + ']]' + this.tagEndChar);
   }
 }
 
 function replaceCDATAarr(str, cdata) {
   str = this.options.tagValueProcessor('' + str);
   if (this.options.cdataPositionChar === '' || str === '') {
-    return str + '<![CDATA[' + cdata.join(']]><![CDATA[') + ']]' + this.tagEndChar;
+    return str + '<![CDATA[' + cdata.map(escapeCdata).join(']]><![CDATA[') + ']]' + this.tagEndChar;
   } else {
     for (let v in cdata) {
-      str = str.replace(this.options.cdataPositionChar, '<![CDATA[' + cdata[v] + ']]>');
+      str = str.replace(this.options.cdataPositionChar, '<![CDATA[' + escapeCdata(cdata[v]) + ']]>');
     }
     return str + this.newLine;
   }
