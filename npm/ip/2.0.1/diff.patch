Description: Fix CVE-2024-29415 SSRF via isPrivate/isPublic bypass
 The ip package through 2.0.1 for Node.js allows SSRF because some IP
 addresses (such as 127.1, 01200034567, 012.1.2.3, 000:0:0000::01, and
 ::fFFf:127.0.0.1) are improperly categorized as globally routable via
 isPublic(). This is an incomplete fix for CVE-2023-42282.
 .
 This patch uses Node.js native net library (net.isIPv4, net.isIPv6, and
 net.SocketAddress) to properly validate and normalize IP addresses before
 checking private/loopback ranges, rejecting malformed octal/hex addresses.
Origin: upstream, https://github.com/indutny/node-ip/pull/144
Author: Yufan You
Last-Update: 2024-02-21

--- a/lib/ip.js
+++ b/lib/ip.js
@@ -1,6 +1,7 @@
 const ip = exports;
 const { Buffer } = require('buffer');
 const os = require('os');
+const net = require('net');

 ip.toBuffer = function (ip, buff, offset) {
   offset = ~~offset;
@@ -82,15 +83,17 @@
   return result;
 };

-const ipv4Regex = /^(\d{1,3}\.){3,3}\d{1,3}$/;
-const ipv6Regex = /^(::)?(((\d{1,3}\.){3}(\d{1,3}){1})?([0-9a-f]){0,4}:{0,2}){1,8}(::)?$/i;
+ip.isV4Format = net.isIPv4;

-ip.isV4Format = function (ip) {
-  return ipv4Regex.test(ip);
-};
+ip.isV6Format = net.isIPv6;

-ip.isV6Format = function (ip) {
-  return ipv6Regex.test(ip);
+ip.normalize = function (addr) {
+  const family = net.isIPv4(addr) ? 'ipv4' : net.isIPv6(addr) ? 'ipv6' : null;
+  if (family === null) {
+    throw new Error(`Invalid ip address: ${addr}`);
+  }
+  const { address } = new net.SocketAddress({ address: addr, family });
+  return address;
 };

 function _normalizeFamily(family) {
@@ -306,26 +309,13 @@
 };

 ip.isPrivate = function (addr) {
-  // check loopback addresses first
-  if (ip.isLoopback(addr)) {
-    return true;
-  }
+  addr = ip.normalize(addr);

-  // ensure the ipv4 address is valid
-  if (!ip.isV6Format(addr)) {
