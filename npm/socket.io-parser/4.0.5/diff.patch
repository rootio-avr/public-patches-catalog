Description: Fix CVE-2023-32695 - Check the format of the event name
 A specially crafted Socket.IO packet can trigger an uncaught exception
 on the Socket.IO server, thus killing the Node.js process. This patch
 adds validation to ensure the first element of EVENT/BINARY_EVENT
 payload is a string or number, preventing malicious packets like
 '2[{"toString":"foo"}]' from causing a TypeError.
Origin: upstream, https://github.com/socketio/socket.io-parser/commit/3b78117bf6ba7e99d7a5cfc1ba54d0477554a7f3
Author: Damien Arrachequesne <damien.arrachequesne@gmail.com>
Applied-By: Automated Security Patching System
Applied-Date: 2025-12-22
Bug: CVE-2023-32695
Bug-Debian: https://security-tracker.debian.org/tracker/CVE-2023-32695
CVSS: 7.5 (HIGH)
CWE: CWE-754 (Improper Check for Unusual or Exceptional Conditions)
Last-Update: 2025-12-22

--- a/dist/index.js
+++ b/dist/index.js
@@ -217,7 +217,8 @@ export class Decoder extends Emitter<{}, {}, DecoderReservedEvents> {
                 return typeof payload === "string" || typeof payload === "object";
             case PacketType.EVENT:
             case PacketType.BINARY_EVENT:
-                return Array.isArray(payload) && payload.length > 0;
+                return (Array.isArray(payload) &&
+                    (typeof payload[0] === "string" || typeof payload[0] === "number"));
             case PacketType.ACK:
             case PacketType.BINARY_ACK:
                 return Array.isArray(payload);
