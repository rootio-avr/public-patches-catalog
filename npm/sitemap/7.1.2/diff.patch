+import { tmpdir } from 'os';
+import { resolve } from 'path';
+import { Readable } from 'stream';
+import { simpleSitemapAndIndex } from '../lib/sitemap-simple';
+import {
+  SitemapStream,
+  streamToPromise,
+  closetag,
+} from '../lib/sitemap-stream';
+import { XMLToSitemapItemStream, parseSitemap } from '../lib/sitemap-parser';
+import { ErrorLevel } from '../lib/types';
+import {
+  validateURL,
+  validateXSLUrl,
+  validatePath,
+  validateLimit,
+  validatePublicBasePath,
+} from '../lib/validation';
+
+const DANGEROUS_URLS = [
+  'javascript:alert(1)',
+  'data:text/html,<script>alert(1)</script>',
+  'file:///etc/passwd',
+  'ftp://example.com/resource',
+  'vbscript:msgbox(1)',
+];
+
+describe('URL protocol allow-list (CWE-20 protocol injection)', () => {
+  describe('validateURL', () => {
+    it.each(DANGEROUS_URLS)('rejects dangerous scheme: %s', (url) => {
+      expect(() => validateURL(url, 'hostname')).toThrow(
+        'must use http:// or https:// protocol'
+      );
+    });
+
+    it('rejects empty string', () => {
+      expect(() => validateURL('', 'hostname')).toThrow(
+        'must be a non-empty string'
+      );
+    });
+
+    it('rejects over-length URLs', () => {
+      const long = 'https://example.com/' + 'a'.repeat(2048);
+      expect(() => validateURL(long, 'hostname')).toThrow(
+        'exceeds maximum length'
+      );
+    });
+
+    it('accepts http and https URLs', () => {
+      expect(() => validateURL('http://example.com', 'hostname')).not.toThrow();
+      expect(() =>
+        validateURL('https://example.com/path', 'hostname')
+      ).not.toThrow();
+    });
+  });
+
+  describe('validateXSLUrl', () => {
+    it('rejects non-http(s) xslUrl', () => {
+      expect(() => validateXSLUrl('javascript:alert(1)')).toThrow(
+        'must use http:// or https:// protocol'
+      );
+    });
+
+    it('rejects xslUrl with script content', () => {
+      expect(() =>
+        validateXSLUrl('https://example.com/<script>alert(1)</script>.xsl')
+      ).toThrow('contains potentially malicious content');
+    });
+
+    it('accepts a valid https xslUrl', () => {
+      expect(() =>
+        validateXSLUrl('https://example.com/style.xsl')
+      ).not.toThrow();
+    });
+  });
+
+  describe('validatePath / validatePublicBasePath / validateLimit', () => {
+    it('rejects path traversal', () => {
+      expect(() => validatePath('../etc/passwd', 'destinationDir')).toThrow(
+        'path traversal'
+      );
+    });
+
+    it('rejects null byte in path', () => {
+      expect(() => validatePath('foo\0bar', 'destinationDir')).toThrow(
+        'null byte'
+      );
+    });
+
+    it('rejects traversal in publicBasePath', () => {
+      expect(() => validatePublicBasePath('../secret')).toThrow(
+        'path traversal'
+      );
+    });
+
+    it('rejects out-of-range and non-integer limits', () => {
+      expect(() => validateLimit(0)).toThrow('Invalid limit');
+      expect(() => validateLimit(50001)).toThrow('Invalid limit');
+      expect(() => validateLimit(1.5)).toThrow('Invalid limit');
+      expect(() => validateLimit(NaN)).toThrow('Invalid limit');
+      expect(() => validateLimit(1)).not.toThrow();
+      expect(() => validateLimit(50000)).not.toThrow();
+    });
+  });
+});
+
+describe('SitemapStream security validation', () => {
+  it.each(DANGEROUS_URLS)(
+    'throws when constructed with dangerous hostname: %s',
+    (url) => {
+      expect(() => new SitemapStream({ hostname: url })).toThrow(
+        'must use http:// or https:// protocol'
+      );
+    }
+  );
+
+  it('throws when constructed with dangerous xslUrl', () => {
+    expect(
+      () => new SitemapStream({ xslUrl: 'javascript:alert(1)' })
+    ).toThrow('must use http:// or https:// protocol');
+  });
+
+  it('rejects custom namespaces containing script injection', () => {
+    expect(
+      () =>
+        new SitemapStream({
+          xmlns: {
+            news: false,
+            video: false,
+            image: false,
+            xhtml: false,
+            custom: ['xmlns:x="javascript:alert(1)"'],
+          },
+        })
+    ).toThrow('malicious content');
+  });
+
+  it('still constructs and emits with a valid https hostname', async () => {
+    const sms = new SitemapStream({ hostname: 'https://example.com' });
+    sms.write('/path');
+    sms.end();
+    const output = (await streamToPromise(sms)).toString();
+    expect(output).toContain('<loc>https://example.com/path</loc>');
+    expect(output).toContain(closetag);
+  });
+
+  it('accepts a valid https xslUrl', () => {
+    expect(
+      () => new SitemapStream({ xslUrl: 'https://example.com/style.xsl' })
+    ).not.toThrow();
+  });
+});
+
+describe('simpleSitemapAndIndex security validation', () => {
+  it.each(DANGEROUS_URLS)(
+    'rejects dangerous hostname: %s',
+    async (url) => {
+      await expect(
+        simpleSitemapAndIndex({
+          hostname: url,
+          destinationDir: tmpdir(),
+          sourceData: ['/foo'],
+          gzip: false,
+        })
+      ).rejects.toThrow('must use http:// or https:// protocol');
+    }
+  );
+
+  it('rejects destinationDir path traversal', async () => {
+    await expect(
+      simpleSitemapAndIndex({
+        hostname: 'https://example.com',
+        destinationDir: '../../etc',
+        sourceData: ['/foo'],
+        gzip: false,
+      })
+    ).rejects.toThrow('path traversal');
+  });
+
+  it('rejects out-of-range limit', async () => {
+    await expect(
+      simpleSitemapAndIndex({
+        hostname: 'https://example.com',
+        destinationDir: tmpdir(),
+        sourceData: ['/foo'],
+        limit: 0,
+        gzip: false,
+      })
+    ).rejects.toThrow('Invalid limit');
+  });
+});
+
+describe('XMLToSitemapItemStream security validation', () => {
+  const parseXml = (xml: string): Promise<any[]> =>
+    parseSitemap(Readable.from([xml]));
+
+  it.each(['javascript:alert(1)', 'data:text/html,x', 'file:///etc/passwd'])(
+    'drops <loc> with dangerous scheme: %s',
+    async (url) => {
+      const xml = `<?xml version="1.0" encoding="UTF-8"?><urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"><url><loc>${url}</loc></url></urlset>`;
+      const items = await parseXml(xml);
+      // The dangerous URL must not be ingested as the item url
+      expect(items[0] && items[0].url).not.toBe(url);
+    }
+  );
+
+  it('keeps a valid http(s) <loc>', async () => {
+    const xml = `<?xml version="1.0" encoding="UTF-8"?><urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"><url><loc>https://example.com/page</loc></url></urlset>`;
+    const items = await parseXml(xml);
+    expect(items[0].url).toBe('https://example.com/page');
+  });
+
+  it('records an error in THROW mode for a dangerous <loc>', async () => {
+    const xml = `<?xml version="1.0" encoding="UTF-8"?><urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"><url><loc>javascript:alert(1)</loc></url></urlset>`;
+    await expect(
+      new Promise((resolvePromise, reject) => {
+        Readable.from([xml])
+          .pipe(
+            new XMLToSitemapItemStream({
+              level: ErrorLevel.THROW,
+              logger: false,
+            })
+          )
+          .on('data', () => undefined)
+          .on('end', resolvePromise)
+          .on('error', reject);
+      })
+    ).rejects.toThrow('http:// or https://');
+  });
+});
