+++ b/package.json
@@ -9,7 +9,8 @@
   },
   "dependencies": {
     "inherits": "^2.0.1",
-    "safe-buffer": "^5.0.1"
+    "safe-buffer": "^5.0.1",
+    "to-buffer": "^1.2.0"
