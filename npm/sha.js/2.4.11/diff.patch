Fix CVE-2025-9288: support multi-byte wide typed arrays

The vulnerability occurs when multi-byte typed arrays (Uint16Array,
Uint32Array, etc.) are passed to the hash update function. The original
code incorrectly uses the typed array's element length and element values
instead of properly converting to bytes first.

This patch uses the to-buffer package to properly convert all input types
including multi-byte typed arrays to their byte representation before hashing.

Origin: upstream, https://github.com/browserify/sha.js/commit/f2a258e9f2d0fcd113bfbaa49706e1ac0d979ba5
Bug: https://github.com/browserify/sha.js/pull/78

--- a/hash.js
+++ b/hash.js
@@ -1,4 +1,5 @@
 var Buffer = require('safe-buffer').Buffer
+var toBuffer = require('to-buffer')

 // prototype class for hash functions
 function Hash (blockSize, finalSize) {
@@ -9,10 +10,7 @@ function Hash (blockSize, finalSize) {
 }

 Hash.prototype.update = function (data, enc) {
-  if (typeof data === 'string') {
-    enc = enc || 'utf8'
-    data = Buffer.from(data, enc)
-  }
+  data = toBuffer(data, enc || 'utf8')

   var block = this._block
   var blockSize = this._blockSize
