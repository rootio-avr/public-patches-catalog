Fix CVE-2026-25639: Denial of Service via __proto__ Key in mergeConfig
Origin: upstream, https://github.com/axios/axios/commit/d7ff1409c68168d3057fc3891f911b2b92616f9e

The mergeConfig function crashes with a TypeError when processing
configuration objects containing __proto__ as an own property. An
attacker can trigger this by providing a malicious configuration
object created via JSON.parse(), causing denial of service.

This patch adds a guard to skip dangerous prototype-related keys
(__proto__, constructor, prototype) in both mergeConfig and the
utils.merge utility, and uses hasOwnProp to safely look up merge
strategies in mergeMap.

--- a/lib/core/mergeConfig.js
+++ b/lib/core/mergeConfig.js
@@ -96,8 +96,9 @@
     headers: (a, b , prop) => mergeDeepProperties(headersToObject(a), headersToObject(b),prop, true)
   };

   utils.forEach(Object.keys(Object.assign({}, config1, config2)), function computeConfigValue(prop) {
-    const merge = mergeMap[prop] || mergeDeepProperties;
+    if (prop === "__proto__" || prop === "constructor" || prop === "prototype") return;
+    const merge = utils.hasOwnProp(mergeMap, prop) ? mergeMap[prop] : mergeDeepProperties;
     const configValue = merge(config1[prop], config2[prop], prop);
     (utils.isUndefined(configValue) && merge !== mergeDirectKeys) || (config[prop] = configValue);
   });

