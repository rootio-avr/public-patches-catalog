Description: Fix CVE-2026-44496 ReDoS in axios cookies.read()
 The read(name) helper interpolated the caller-supplied cookie name into a
 RegExp without escaping, allowing crafted names to trigger catastrophic
 backtracking. Replace the RegExp lookup with a literal "; " split and an
 exact name comparison, matching the upstream fix in axios commit
 3c7ef0f64d23a9eb2eefb32afb9dd8ce2c15a1c8 (PR #10833) but kept in the
 ES5/CommonJS style of the 0.27.x branch.
 Test-file hunks were removed because tests are not present in the published
 npm tarball (dist-based patching applies to lib/ only).
Origin: backport, https://github.com/axios/axios/commit/3c7ef0f64d23a9eb2eefb32afb9dd8ce2c15a1c8
Forwarded: not-needed
Last-Update: 2026-06-12

--- a/lib/helpers/cookies.js
+++ b/lib/helpers/cookies.js
@@ -32,8 +32,17 @@
         },
 
         read: function read(name) {
-          var match = document.cookie.match(new RegExp('(^|;\\s*)(' + name + ')=([^;]*)'));
-          return (match ? decodeURIComponent(match[3]) : null);
+          // Avoid building a RegExp from `name` (CVE-2026-44496 ReDoS): split
+          // on the literal "; " separator and compare names exactly.
+          var cookies = document.cookie.split('; ');
+          for (var i = 0; i < cookies.length; i++) {
+            var cookie = cookies[i];
+            var eq = cookie.indexOf('=');
+            if (eq !== -1 && cookie.slice(0, eq) === name) {
+              return decodeURIComponent(cookie.slice(eq + 1));
+            }
+          }
+          return null;
         },
 
         remove: function remove(name) {

